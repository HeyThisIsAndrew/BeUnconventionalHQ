# Cloudflare Pages reads this file and applies these HTTP response headers.
# https://developers.cloudflare.com/pages/configuration/headers/
#
# Security headers applied to every route.

/*
  # Stop browsers from MIME-sniffing a response away from its declared type.
  X-Content-Type-Options: nosniff
  # Send origin only on cross-site navigations; full URL stays same-origin.
  Referrer-Policy: strict-origin-when-cross-origin
  # Prevent other sites from framing our pages (clickjacking protection).
  X-Frame-Options: SAMEORIGIN
  # Disable powerful browser features the site does not use.
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  # Force HTTPS for one year (site is HTTPS-only on Cloudflare Pages).
  Strict-Transport-Security: max-age=31536000
  # Restrict where content may load from. Allowlist matches the site's real
  # dependencies: Google Tag Manager/Analytics (scripts + beacons), YouTube
  # embeds, and https image CDNs (YouTube thumbs, Substack, Unsplash).
  # 'unsafe-inline' is required by GTM and the site's inline island scripts.
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; img-src 'self' data: https:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com; frame-src 'self' https://www.youtube.com https://www.youtube-nocookie.com https://www.googletagmanager.com; connect-src 'self' https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com

# The embedded Sanity Studio (/admin, injected by @sanity/astro's
# studioBasePath) is an internal tool: tell crawlers to keep it out of search
# results entirely. Header-based because the page markup is generated by the
# integration, so there's no template to put a <meta> tag in.
#
# KNOWN LIMITATION: the site-wide CSP above does not allow connections to
# *.sanity.io, so the hosted Studio at /admin cannot reach the Sanity API in
# production. If you want the hosted Studio to work (vs. running `npx sanity
# dev` locally), /admin needs its own CSP: detach the global one here with
# "! Content-Security-Policy" and set a Studio-friendly policy including
# connect-src https://*.sanity.io wss://*.sanity.io — then verify in the
# browser console, because Cloudflare JOINS duplicate headers (two CSPs
# enforce as their intersection, which would break it further).
/admin
  X-Robots-Tag: noindex, nofollow
/admin/*
  X-Robots-Tag: noindex, nofollow
