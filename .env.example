# Copy to .env for local development. In production these live in the
# Cloudflare environment (Settings → Environment variables, encrypted).

# --- YouTube Data API v3 (issues #20/#21) ---
# Google Cloud Console → enable "YouTube Data API v3" → create API key.
# Used by: scripts/sync-youtube.mjs (video ingestion) and
#          /api/live-status.json (live detection).
YOUTUBE_API_KEY=

# Optional — defaults to the Be Unconventional HQ channel.
# YOUTUBE_CHANNEL_ID=UCXqU6781pQgYXDExLvMw2Og

# --- Twitch live detection (optional — endpoint ignores Twitch until all
#     three are set; see scripts/live-status.md) ---
# dev.twitch.tv → register an application → client id + secret.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_CHANNEL_LOGIN=

# --- Sanity (write access; NEVER needed by the site itself) ---
# manage.sanity.io → project → API → Tokens → "Editor" token.
# Used by the Sanity Studio at /admin (image hosting + the legacy schema).
# NOT used by scripts/sync-youtube.mjs --execute — that script writes
# straight to src/data/videos.json since the local-JSON pivot (epic #34).
SANITY_WRITE_TOKEN=

# Cloudflare Turnstile
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Resend API
RESEND_API_KEY=

