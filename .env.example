# Copy to .env for local development. In production these live in the
# Cloudflare environment (Settings → Environment variables, encrypted).

# --- YouTube Data API v3 (issues #20/#21) ---
# Google Cloud Console → enable "YouTube Data API v3" → create API key.
# Used by: scripts/sync-youtube.mjs (video ingestion) and
#          /api/live-status.json (live detection).
YOUTUBE_API_KEY=

# Optional — defaults to the Be Unconventional HQ channel.
# YOUTUBE_CHANNEL_ID=UCXqU6781pQgYXDExLvMw2Og

# --- Sanity (write access; NEVER needed by the site itself) ---
# manage.sanity.io → project → API → Tokens → "Editor" token.
# Used ONLY by scripts/sync-youtube.mjs --execute.
SANITY_WRITE_TOKEN=
