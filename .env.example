# Google Tag Manager container ID (from tagmanager.google.com, format: GTM-XXXXXXX)
# The PUBLIC_ prefix tells Astro this value is safe to embed in client-side code.
# GTM is disabled entirely when this is unset (e.g. local dev without analytics).
PUBLIC_GTM_ID=

# YouTube Data API v3 key (Google Cloud → APIs & Services → Credentials).
# SERVER/BUILD ONLY — NO `PUBLIC_` prefix, or it would ship to the browser.
# Read as process.env.YOUTUBE_API_KEY (Node scripts) or
# locals.runtime.env.YOUTUBE_API_KEY (Cloudflare edge). Restrict the key by API
# (YouTube Data API v3) + HTTP referrer in Google Cloud. Powers metadata
# ingestion (#21) and live detection (#20).
YOUTUBE_API_KEY=

# The Be Unconventional HQ channel the data layer reads from.
YOUTUBE_CHANNEL_ID=UCXqU6781pQgYXDExLvMw2Og

# ── Sanity (YouTube → Sanity sync; see docs/youtube-sync.md) ─────────────────
# Project + dataset default to the values in astro.config.mjs if unset.
SANITY_PROJECT_ID=38nhxsib
SANITY_DATASET=production
SANITY_API_VERSION=2024-03-01
# Write token with Editor permission — REQUIRED to run the sync with --execute.
# SERVER/BUILD ONLY, never PUBLIC_, never committed. Create at
# sanity.io/manage → project → API → Tokens.
SANITY_WRITE_TOKEN=
