const socialLinks = [
  { label: 'YouTube', href: site.socials.youtube },
  { label: 'Instagram', href: site.socials.instagram },
  { label: 'TikTok', href: site.socials.tiktok },
  { label: 'Threads', href: site.socials.threads },
  { label: 'Twitter', href: site.socials.twitter },
  { label: 'Facebook', href: site.socials.facebook },
  { label: 'Substack', href: site.socials.substack },
  { label: 'Letterboxd', href: site.socials.letterboxd }
];
---

<Layout title={title} description={description}>
  <main class="links-hub">
    <div class="links-container">
      <!-- Profile & Brand Section -->
      <section class="links-profile-header animate-on-scroll">
        <div class="links-profile-image-wrapper">
          <img src="/profile.jpg" alt="Be Unconventional HQ" class="links-profile-img" />
          <div class="links-profile-glow"></div>
        </div>
        <div class="links-brand-stack">
          <p class="links-kicker">WE’RE NERD CULTURE GETS CINEMATIC</p>
          <h1 class="links-title-stack">
            <span class="links-word-be">Be</span>
            <span class="links-word-unconventional">Unconventional</span>
            <span class="links-word-hq">HQ</span>
          </h1>
          <p class="links-subtitle">
            SOMETIMES UNCONVENTIONAL IS THE ONLY WAY FORWARD
          </p>
        </div>
      </section>

      <!-- Main Navigation -->
      <section class="animate-on-scroll" data-delay="100">
        <div class="links-grid">
          {mainLinks.map((link) => (
            <a href={link.href} class="links-card">
              <span class="links-label">{link.label}</span>
              <span class="links-arrow">→</span>
            </a>
          ))}
        </div>
      </section>

      <!-- Social Icons -->
      <section class="animate-on-scroll" data-delay="200">
        <div class="links-socials-row">
          {socialLinks.map((social) => (
            <a href={social.href} target="_blank" rel="noopener noreferrer" class="links-social-icon" aria-label={social.label} set:html={socialIcons[social.label]}>
            </a>
          ))}
        </div>
      </section>

      <!-- Featured Content Bento -->
      <section class="animate-on-scroll" data-delay="300">
        <h2 class="links-section-title">Featured Content</h2>
        <div class="links-bento-grid">
          <!-- Featured Videos -->
          {featuredVideos.map((video) => (
            <a href={video.link} target="_blank" class="links-bento-item">
              <div class="links-bento-image">
                <img src={video.thumbnail} alt={video.title} />
                <span class="links-bento-badge">VIDEO</span>
              </div>
              <div class="links-bento-content">
                <h3 class="links-bento-title">{video.title}</h3>
              </div>
            </a>
          ))}

          <!-- Featured Articles -->
          {featuredArticles.map((article) => (
            <a href={article.link} target="_blank" class="links-bento-item">
              <div class="links-bento-image">
                <img src={article.image} alt={article.title} />
                <span class="links-bento-badge">ARTICLE</span>
              </div>
              <div class="links-bento-content">
                <h3 class="links-bento-title">{article.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- Substack Embed / CTA -->
      <section class="animate-on-scroll" data-delay="400">
        <div class="links-newsletter">
          <h3>The Editorial Feed</h3>
          <p>Deep dives into cinema, gaming, and culture delivered to your inbox.</p>
          <a href="https://beunconventionalhq.substack.com/" target="_blank" class="cta-button-primary">Subscribe on Substack</a>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  /* Local overrides to hide site chrome on links page */
  :global(#navbar), :global(.site-footer) {
    display: none !important;
  }
</style>
