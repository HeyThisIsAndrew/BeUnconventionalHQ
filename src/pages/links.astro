---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site.js';
import { getArticles } from './articles.astro';
import { getVideos } from './videos.astro';

const title = `Links | ${site.name}`;
const description = 'Connect with Be Unconventional HQ across all platforms.';

const articles = await getArticles();
const videos = await getVideos();

const featuredArticles = articles.slice(0, 2);
const featuredVideos = videos.slice(0, 2);

const mainLinks = [
  { label: 'Latest Videos', href: '/videos', icon: 'play' },
  { label: 'Editorial Articles', href: '/articles', icon: 'edit' },
  { label: 'The Feed', href: '/feed', icon: 'rss' },
];

const socialLinks = [
  { label: 'YouTube', href: 'https://www.youtube.com/@BeUnconventionalHQ', icon: 'youtube' },
  { label: 'Instagram', href: 'https://www.instagram.com/beunconventionalhq', icon: 'instagram' },
  { label: 'TikTok', href: 'https://www.tiktok.com/@beunconventional', icon: 'tiktok' },
  { label: 'Substack', href: 'https://beunconventionalhq.substack.com/', icon: 'substack' },
  { label: 'Threads', href: 'https://www.threads.com/@beunconventionalhq', icon: 'threads' },
  { label: 'Facebook', href: 'https://www.facebook.com/profile.php?id=61557980693320&sk=mentions', icon: 'facebook' },
  { label: 'Beacons', href: 'https://beacons.ai/beunconventional', icon: 'link' },
];
---

<Layout title={title} description={description}>
  <main class="links-hub">
    <div class="links-container">
      <!-- Profile Section -->
      <section class="profile-header animate-on-scroll">
        <div class="profile-image-wrapper">
          <img src="/profile.jpg" alt="Be Unconventional HQ" class="profile-img" />
          <div class="profile-glow"></div>
        </div>
        <h1 class="profile-name">Be Unconventional HQ</h1>
        <p class="profile-tagline">Where Nerd Culture Gets Cinematic</p>
      </section>

      <!-- Main Navigation -->
      <section class="links-section animate-on-scroll" data-delay="100">
        <div class="links-grid">
          {mainLinks.map((link) => (
            <a href={link.href} class="link-card main-link">
              <span class="link-label">{link.label}</span>
              <span class="link-arrow">→</span>
            </a>
          ))}
        </div>
      </section>

      <!-- Social Icons -->
      <section class="socials-section animate-on-scroll" data-delay="200">
        <div class="socials-row">
          {socialLinks.map((social) => (
            <a href={social.href} target="_blank" rel="noopener noreferrer" class="social-icon-btn" aria-label={social.label}>
              <span class="icon-label">{social.label.charAt(0)}</span>
            </a>
          ))}
        </div>
      </section>

      <!-- Featured Content Bento -->
      <section class="featured-section animate-on-scroll" data-delay="300">
        <h2 class="section-title-subtle">Featured Content</h2>
        <div class="bento-grid">
          <!-- Featured Videos -->
          {featuredVideos.map((video) => (
            <a href={video.link} target="_blank" class="bento-item video-bento">
              <div class="bento-image-wrapper">
                <img src={video.thumbnail} alt={video.title} />
                <div class="bento-overlay">
                  <span class="bento-badge">VIDEO</span>
                </div>
              </div>
              <div class="bento-content">
                <h3 class="bento-title">{video.title}</h3>
              </div>
            </a>
          ))}

          <!-- Featured Articles -->
          {featuredArticles.map((article) => (
            <a href={article.link} target="_blank" class="bento-item article-bento">
              <div class="bento-image-wrapper">
                <img src={article.image} alt={article.title} />
                <div class="bento-overlay">
                  <span class="bento-badge">ARTICLE</span>
                </div>
              </div>
              <div class="bento-content">
                <h3 class="bento-title">{article.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- Substack Embed / CTA -->
      <section class="newsletter-section animate-on-scroll" data-delay="400">
        <div class="newsletter-card">
          <h3>The Editorial Feed</h3>
          <p>Deep dives into cinema, gaming, and culture delivered to your inbox.</p>
          <a href="https://beunconventionalhq.substack.com/" target="_blank" class="cta-button-primary">Subscribe on Substack</a>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  /* Override layout defaults for links page */
  :global(#navbar), :global(.site-footer) {
    display: none !important;
  }

  .links-hub {
    min-height: 100vh;
    background: radial-gradient(circle at top, #1a0505 0%, #0a0a0a 100%);
    padding: 4rem 1.5rem;
    display: flex;
    justify-content: center;
  }

  .links-container {
    width: 100%;
    max-width: 580px;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* Profile */
  .profile-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .profile-image-wrapper {
    position: relative;
    width: 96px;
    height: 96px;
    margin-bottom: 1.5rem;
  }

  .profile-img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-accent);
    position: relative;
    z-index: 2;
  }

  .profile-glow {
    position: absolute;
    inset: -10px;
    background: var(--color-accent);
    filter: blur(20px);
    opacity: 0.3;
    border-radius: 50%;
    z-index: 1;
  }

  .profile-name {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .profile-tagline {
    color: var(--color-white-muted);
    font-size: 0.9rem;
    letter-spacing: 0.05em;
  }

  /* Links Grid */
  .links-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .link-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    text-decoration: none;
    color: var(--color-white);
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.2, 1);
  }

  .link-card:hover {
    background: rgba(204, 0, 0, 0.1);
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(204, 0, 0, 0.15);
  }

  .link-label {
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .link-arrow {
    opacity: 0.5;
    transition: transform 0.3s ease;
  }

  .link-card:hover .link-arrow {
    transform: translateX(4px);
    opacity: 1;
  }

  /* Socials */
  .socials-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }

  .social-icon-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: var(--color-white);
    transition: all 0.3s ease;
  }

  .social-icon-btn:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    transform: scale(1.1);
    box-shadow: 0 0 15px rgba(204, 0, 0, 0.4);
  }

  /* Bento Grid */
  .section-title-subtle {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-white-muted);
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .bento-item {
    background: var(--color-surface);
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.3s ease;
  }

  .bento-item:hover {
    border-color: var(--color-accent);
    transform: scale(1.02);
  }

  .bento-image-wrapper {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
  }

  .bento-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .bento-item:hover img {
    transform: scale(1.1);
  }

  .bento-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
    display: flex;
    align-items: flex-start;
    padding: 0.75rem;
  }

  .bento-badge {
    font-size: 0.5rem;
    font-weight: 800;
    background: var(--color-accent);
    color: white;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .bento-content {
    padding: 1rem;
  }

  .bento-title {
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-white);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Newsletter */
  .newsletter-card {
    background: linear-gradient(135deg, rgba(204, 0, 0, 0.1), rgba(0,0,0,0.3));
    border: 1px solid rgba(204, 0, 0, 0.2);
    padding: 2rem;
    border-radius: 20px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .newsletter-card h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
  }

  .newsletter-card p {
    font-size: 0.9rem;
    color: var(--color-white-muted);
    line-height: 1.5;
  }

  @media (max-width: 480px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
