  TikTok: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>`,
  Threads: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" fill="currentColor"><path d="M427.5 299.7C429.7 300.6 431.7 301.6 433.8 302.5C463 316.6 484.4 337.7 495.6 363.9C511.3 400.4 512.8 459.7 465.3 507.1C429.1 543.3 385 559.6 322.7 560.1L322.4 560.1C252.2 559.6 198.3 536 162 489.9C129.7 448.9 113.1 391.8 112.5 320.3L112.5 319.8C113 248.3 129.6 191.2 161.9 150.2C198.2 104.1 252.2 80.5 322.4 80L322.7 80C393 80.5 447.6 104 485 149.9C503.4 172.6 517 199.9 525.6 231.6L485.2 242.4C478.1 216.6 467.4 194.6 453 177C423.8 141.2 380 122.8 322.5 122.4C265.5 122.9 222.4 141.2 194.3 176.8C168.1 210.1 154.5 258.3 154 320C154.5 381.7 168.1 429.9 194.3 463.3C222.3 498.9 265.5 517.2 322.5 517.7C373.9 517.3 407.9 505.1 436.2 476.8C468.5 444.6 467.9 405 457.6 380.9C451.5 366.7 440.5 354.9 425.7 346C422 372.9 413.9 394.3 401 410.8C383.9 432.6 359.6 444.4 328.3 446.1C304.7 447.4 282 441.7 264.4 430.1C243.6 416.3 231.4 395.3 230.1 370.8C227.6 322.5 265.8 287.8 325.3 284.4C346.4 283.2 366.2 284.1 384.5 287.2C382.1 272.4 377.2 260.6 369.9 252C359.9 240.3 344.3 234.3 323.7 234.2L323 234.2C306.4 234.2 284 238.8 269.7 260.5L235.3 236.9C254.5 207.8 285.6 191.8 323.1 191.8L323.9 191.8C386.5 192.2 423.8 231.3 427.6 299.5L427.4 299.7L427.5 299.7zM271.5 368.5C272.8 393.6 299.9 405.3 326.1 403.8C351.7 402.4 380.7 392.4 385.6 330.6C372.4 327.7 357.8 326.2 342.2 326.2C337.4 326.2 332.6 326.3 327.8 326.6C284.9 329 270.6 349.8 271.6 368.4L271.5 368.5z"/></svg>`,
  Facebook: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  Substack: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/></svg>`
};

const socialLinks = [
  { label: 'YouTube', href: site.socials.youtube },
  { label: 'Instagram', href: site.socials.instagram },
  { label: 'TikTok', href: site.socials.tiktok },
  { label: 'Substack', href: site.socials.substack },
  { label: 'Threads', href: site.socials.threads },
  { label: 'Facebook', href: site.socials.facebook },
];
---

<Layout title={title} description={description}>
  <main class="links-hub">
    <div class="links-container">
      <!-- Profile Section -->
      <section class="profile-header animate-on-scroll">
        <div class="profile-image-wrapper">
          <img src="/profile.jpg" alt="Be Unconventional HQ" class="profile-img" />
          <div class="profile-glow"></div>
        </div>
        <h1 class="hero-title-stack">
          <span class="word-be">Be</span>
          <span class="word-unconventional">Unconventional</span>
          <span class="word-hq">HQ</span>
        </h1>
        <p class="profile-tagline">Where Nerd Culture Gets Cinematic</p>
      </section>

      <!-- Main Navigation -->
      <section class="links-section animate-on-scroll" data-delay="100">
        <div class="links-grid">
          {mainLinks.map((link) => (
            <a href={link.href} class="link-card main-link">
              <span class="link-label">{link.label}</span>
              <span class="link-arrow">→</span>
            </a>
          ))}
        </div>
      </section>

      <!-- Social Icons -->
      <section class="socials-section animate-on-scroll" data-delay="200">
        <div class="socials-row">
          {socialLinks.map((social) => (
            <a href={social.href} target="_blank" rel="noopener noreferrer" class="social-icon-btn" aria-label={social.label} set:html={socialIcons[social.label]}>
            </a>
          ))}
        </div>
      </section>

      <!-- Featured Content Bento -->
      <section class="featured-section animate-on-scroll" data-delay="300">
        <h2 class="section-title-subtle">Featured Content</h2>
        <div class="bento-grid">
          <!-- Featured Videos -->
          {featuredVideos.map((video) => (
            <a href={video.link} target="_blank" class="bento-item video-bento">
              <div class="bento-image-wrapper">
                <img src={video.thumbnail} alt={video.title} />
                <div class="bento-overlay">
                  <span class="bento-badge">VIDEO</span>
                </div>
              </div>
              <div class="bento-content">
                <h3 class="bento-title">{video.title}</h3>
              </div>
            </a>
          ))}

          <!-- Featured Articles -->
          {featuredArticles.map((article) => (
            <a href={article.link} target="_blank" class="bento-item article-bento">
              <div class="bento-image-wrapper">
                <img src={article.image} alt={article.title} />
                <div class="bento-overlay">
                  <span class="bento-badge">ARTICLE</span>
                </div>
              </div>
              <div class="bento-content">
                <h3 class="bento-title">{article.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- Substack Embed / CTA -->
      <section class="newsletter-section animate-on-scroll" data-delay="400">
        <div class="newsletter-card">
          <h3>The Editorial Feed</h3>
          <p>Deep dives into cinema, gaming, and culture delivered to your inbox.</p>
          <a href="https://beunconventionalhq.substack.com/" target="_blank" class="cta-button-primary">Subscribe on Substack</a>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  /* Override layout defaults for links page */
  :global(#navbar), :global(.site-footer) {
    display: none !important;
  }

  .links-hub {
    min-height: 100vh;
    background-color: var(--color-black);
    background-image: 
      radial-gradient(circle at 50% -20%, rgba(204, 0, 0, 0.15) 0%, transparent 50%),
      radial-gradient(circle at 0% 100%, rgba(204, 0, 0, 0.05) 0%, transparent 40%);
    padding: 4rem 1.5rem;
    display: flex;
    justify-content: center;
    overflow-x: hidden;
  }

  .links-container {
    width: 100%;
    max-width: 580px;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* Profile */
  .profile-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-title-stack {
    margin-bottom: 0.5rem;
    transform: scale(0.85); /* Slightly smaller for mobile-first hub */
  }

  .profile-image-wrapper {
    position: relative;
    width: 96px;
    height: 96px;
    margin-bottom: 1.5rem;
  }

  .profile-img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-accent);
    position: relative;
    z-index: 2;
  }

  .profile-glow {
    position: absolute;
    inset: -10px;
    background: var(--color-accent);
    filter: blur(20px);
    opacity: 0.3;
    border-radius: 50%;
    z-index: 1;
  }

  .profile-tagline {
    color: var(--color-white-muted);
    font-size: 0.9rem;
    letter-spacing: 0.05em;
  }

  /* Links Grid */
  .links-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .link-card {
    background: var(--color-surface);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    text-decoration: none;
    color: var(--color-white);
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.2, 1);
  }

  .link-card:hover {
    background: rgba(204, 0, 0, 0.1);
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(204, 0, 0, 0.15);
  }

  .link-label {
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    font-size: 0.85rem;
  }

  .link-arrow {
    opacity: 0.5;
    transition: transform 0.3s ease;
  }

  .link-card:hover .link-arrow {
    transform: translateX(4px);
    opacity: 1;
  }

  /* Socials */
  .socials-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.25rem;
  }

  .social-icon-btn {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: var(--color-white-muted);
    transition: all 0.3s ease;
  }

  .social-icon-btn:hover {
    color: var(--color-accent);
    transform: scale(1.2);
    filter: drop-shadow(0 0 8px rgba(204, 0, 0, 0.5));
  }
  
  :global(.social-icon-btn svg) {
    width: 100%;
    height: 100%;
  }

  /* Bento Grid */
  .section-title-subtle {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-white-muted);
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .bento-item {
    background: var(--color-surface);
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.3s ease;
  }

  .bento-item:hover {
    border-color: var(--color-accent);
    transform: scale(1.02);
    box-shadow: 0 10px 30px rgba(204, 0, 0, 0.1);
  }

  .bento-image-wrapper {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .bento-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .bento-item:hover img {
    transform: scale(1.1);
  }

  .bento-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
    display: flex;
    align-items: flex-start;
    padding: 0.75rem;
  }

  .bento-badge {
    font-size: 0.5rem;
    font-weight: 800;
    background: var(--color-accent);
    color: white;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .bento-content {
    padding: 1.25rem;
  }

  .bento-title {
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-white);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Newsletter */
  .newsletter-card {
    background: var(--color-surface);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 2.5rem 2rem;
    border-radius: 20px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    position: relative;
    overflow: hidden;
  }
  
  .newsletter-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, rgba(204, 0, 0, 0.1), transparent 70%);
    pointer-events: none;
  }

  .newsletter-card h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    position: relative;
  }

  .newsletter-card p {
    font-size: 0.9rem;
    color: var(--color-white-muted);
    line-height: 1.6;
    position: relative;
    max-width: 320px;
  }

  @media (max-width: 480px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }
    
    .hero-title-stack {
      transform: scale(0.75);
    }
  }
</style>
