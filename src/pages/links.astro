---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site.js';

const links = [
  {
    label: 'Watch on YouTube',
    sub: 'Reviews, reactions & deep dives',
    href: site.socials.youtube,
    primary: true,
  },
  {
    label: 'Read on Substack',
    sub: 'The editorial feed',
    href: site.socials.substack,
    primary: true,
  },
  { label: 'Instagram', href: site.socials.instagram },
  { label: 'TikTok', href: site.socials.tiktok },
  { label: 'Letterboxd', href: site.socials.letterboxd },
  { label: 'X / Twitter', href: site.socials.twitter },
  { label: 'Threads', href: site.socials.threads },
  { label: 'Facebook', href: site.socials.facebook },
  { label: 'Shop on Amazon', href: site.socials.amazon },
];
---

<Layout
  title="Links"
  description="Every Be Unconventional HQ channel in one place."
>
  <section class="links-page container">
    <div class="links-card reveal">
      <img class="links-avatar" src="/profile.jpg" alt={site.name} />
      <h1 class="links-name">
        Be Unconventional<span>HQ</span>
      </h1>
      <p class="links-tagline">{site.tagline}.</p>

      <div class="links-list">
        {
          links.map((l, i) => (
            <a
              class:list={['link-btn', { primary: l.primary }]}
              href={l.href}
              target="_blank"
              rel="noopener noreferrer"
              data-delay={i * 50}
            >
              <span class="link-label">{l.label}</span>
              {l.sub && <span class="link-sub">{l.sub}</span>}
              <span class="link-arrow" aria-hidden="true">
                →
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .links-page {
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: calc(72px + 2rem) 4rem;
  }
  .links-card {
    width: 100%;
    max-width: 520px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
  }
  .links-avatar {
    width: 104px;
    height: 104px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--accent);
    box-shadow: var(--shadow-accent);
  }
  .links-name {
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    font-size: clamp(1.4rem, 6vw, 1.9rem);
    margin-top: 0.75rem;
    letter-spacing: -0.01em;
  }
  .links-name span {
    color: var(--accent);
    margin-left: 0.3em;
  }
  .links-tagline {
    color: var(--text-2);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }
  .links-list {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .link-btn {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 1.05rem 3rem 1.05rem 1.5rem;
    border-radius: 14px;
    border: 1px solid var(--line);
    background: var(--bg-1);
    text-align: left;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease;
  }
  .link-btn:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    background: var(--bg-2);
  }
  .link-btn.primary {
    border-color: rgba(229, 9, 20, 0.5);
    background:
      radial-gradient(
        140% 140% at 0% 0%,
        rgba(229, 9, 20, 0.16) 0%,
        transparent 60%
      ),
      var(--bg-1);
  }
  .link-label {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.02em;
  }
  .link-sub {
    color: var(--text-2);
    font-size: 0.8rem;
  }
  .link-arrow {
    position: absolute;
    right: 1.4rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-3);
    transition:
      color 0.2s ease,
      transform 0.2s ease;
  }
  .link-btn:hover .link-arrow {
    color: var(--accent-ink);
    transform: translate(4px, -50%);
  }
</style>
