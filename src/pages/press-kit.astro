---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site.js';

const title = `Press Kit | ${site.name}`;
const description =
  'Media assets and contact information for Be Unconventional HQ.';
---

<Layout title={title} description={description}>
  <main class="press-kit-page">
    <div class="container">
      <header class="section-header animate-on-scroll">
        <p class="section-kicker">Collaborations</p>
        <h1 class="section-title">Press Kit</h1>
      </header>

      <section class="press-kit-grid">
        <!-- Section 1: Media Assets -->
        <div class="press-kit-card animate-on-scroll" data-delay="100">
          <h2 class="press-kit-sub">Media Assets</h2>
          <div class="press-kit-content">
            <p>
              Our official logos, brand colors, and creator photography are
              currently being finalized for high-resolution distribution.
            </p>
            <p class="press-kit-note">
              Standard resolution assets are available upon direct request via
              email.
            </p>
          </div>
        </div>

        <!-- Section 2: Contact Information -->
        <div class="press-kit-card animate-on-scroll" data-delay="200">
          <h2 class="press-kit-sub">Contact Information</h2>
          <div class="press-kit-content">
            <p>
              For interview requests, sponsorship inquiries, or editorial
              collaborations, please reach out directly:
            </p>
            <a
              href="mailto:beunconventionalmedia@gmail.com"
              class="press-kit-email">Contact Be Unconventional HQ</a
            >
          </div>
        </div>

        <!-- Section 3: Download Placeholder -->
        <div
          class="press-kit-card animate-on-scroll download-card"
          data-delay="300"
        >
          <h2 class="press-kit-sub">Press Assets (PDF)</h2>
          <div class="press-kit-content">
            <p>
              Download the latest one-sheet containing our channel stats,
              audience demographics, and production gear list.
            </p>
            <button class="press-kit-btn-disabled" disabled>
              Download PDF (Coming Soon)
            </button>
          </div>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  .press-kit-page {
    padding-top: 120px;
    min-height: 100vh;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .press-kit-grid {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    margin-bottom: 8rem;
  }

  .press-kit-card {
    background: var(--color-surface);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 3rem;
  }

  .press-kit-sub {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .press-kit-content p {
    color: var(--color-white-muted);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .press-kit-note {
    font-size: 0.85rem;
    font-style: italic;
  }

  .press-kit-email {
    display: inline-block;
    color: var(--color-white);
    font-weight: 600;
    font-size: 1.1rem;
    text-decoration: none;
    position: relative;
    padding-bottom: 4px;
    transition:
      color 0.3s ease,
      text-shadow 0.3s ease;
  }

  .press-kit-email::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-accent);
    transition: width 0.35s cubic-bezier(0.25, 0.8, 0.2, 1);
  }

  .press-kit-email:hover {
    color: var(--color-accent);
    text-shadow: 0 0 16px rgba(204, 0, 0, 0.5);
  }

  .press-kit-email:hover::after {
    width: 100%;
  }

  .press-kit-btn-disabled {
    margin-top: 1rem;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.3);
    padding: 1rem 2rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    cursor: not-allowed;
  }

  @media (max-width: 768px) {
    .press-kit-card {
      padding: 2rem 1.5rem;
    }
  }
</style>
