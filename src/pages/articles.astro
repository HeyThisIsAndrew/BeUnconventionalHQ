---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site.js';
import { CATEGORIES, CATEGORY_NORMALIZATION } from '../data/constants.js';
import fs from 'fs/promises';
import path from 'path';

const title = `Articles | ${site.name}`;
const description =
  'Latest editorial content, reviews, and deep dives from Be Unconventional HQ on Substack.';

// Provide getter for components like LatestArticles.astro and feed.astro
export async function getArticles() {
  try {
    const cachePath = path.join(
      process.cwd(),
      'src',
      'data',
      'cache',
      'articles.json'
    );

    const data = await fs.readFile(cachePath, 'utf-8');
    return JSON.parse(data);
  } catch (e) {
    console.warn('[Astro] No articles cache found, returning empty array.');
    return [];
  }
}

const allArticles = await getArticles();
const displayArticles = allArticles.slice(0, 20);
const categories = [
  'All',
  CATEGORIES.FILM,
  CATEGORIES.TV,
  CATEGORIES.GAMING,
  'General',
];
---

<Layout title={title} description={description}>
  <main class="articles-page">
    <div class="container">
      <header class="section-header animate-on-scroll">
        <p class="section-kicker">Explore The HQ</p>
        <h1 class="section-title">Latest Articles</h1>
      </header>

      <nav class="filter-nav animate-on-scroll" data-delay="100">
        <div class="filter-group">
          <span class="filter-label">CATEGORY:</span>
          <div class="filter-scroll">
            {
              categories.map((cat) => (
                <button
                  class:list={['filter-btn', { active: cat === 'All' }]}
                  data-filter={cat.toLowerCase()}
                >
                  {cat.toUpperCase()}
                </button>
              ))
            }
          </div>
        </div>
      </nav>

      <div class="articles-grid">
        {
          displayArticles.map((article, index) => (
            <article
              class="article-card animate-on-scroll"
              data-category={(article.category || 'General').toLowerCase()}
              style={`--index: ${index}`}
            >
              <div class="article-image-wrapper">
                <span class="content-badge">{article.category}</span>
                <img
                  src={article.image}
                  alt={article.title}
                  class="article-image"
                />
              </div>
              <div class="article-content">
                <span class="article-date">{article.date}</span>
                <h2 class="article-title">{article.title}</h2>
                <p class="article-excerpt">{article.excerpt}</p>
                <a
                  href={article.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="article-link"
                >
                  Read Full Article
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </main>
</Layout>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.article-card');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');

      const filter = btn.getAttribute('data-filter');

      cards.forEach((card) => {
        const cat = card.getAttribute('data-category');
        if (filter === 'all' || cat === filter) {
          (card as HTMLElement).style.display = 'flex';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
</style>
