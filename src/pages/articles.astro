---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site.js';

const title = `Articles | ${site.name}`;
const description = 'Latest editorial content, reviews, and deep dives from Be Unconventional HQ on Substack.';

let articles = [];
const RSS_URL = 'https://beunconventionalhq.substack.com/feed';

try {
  const response = await fetch(RSS_URL);
  const xml = await response.text();

  // Simple regex-based RSS parsing since we can't install new packages
  const itemRegex = /<item>([\s\S]*?)<\/item>/g;
  let match;
  
  while ((match = itemRegex.exec(xml)) !== null) {
    const itemContent = match[1];
    
    const titleMatch = itemContent.match(/<title><!\[CDATA\[([\s\S]*?)\]\]><\/title>/) || itemContent.match(/<title>([\s\S]*?)<\/title>/);
    const linkMatch = itemContent.match(/<link>([\s\S]*?)<\/link>/);
    const pubDateMatch = itemContent.match(/<pubDate>([\s\S]*?)<\/pubDate>/);
    const descriptionMatch = itemContent.match(/<description><!\[CDATA\[([\s\S]*?)\]\]><\/description>/) || itemContent.match(/<description>([\s\S]*?)<\/description>/);
    const enclosureMatch = itemContent.match(/<enclosure[^>]+url="([^"]+)"/);

    if (titleMatch && linkMatch) {
      articles.push({
        title: titleMatch[1].trim(),
        link: linkMatch[1].trim(),
        date: pubDateMatch ? new Date(pubDateMatch[1]).toLocaleDateString('en-US', {
          month: 'long',
          day: 'numeric',
          year: 'numeric'
        }) : '',
        excerpt: descriptionMatch ? descriptionMatch[1].replace(/<[^>]*>/g, '').substring(0, 160).trim() + '...' : '',
        image: enclosureMatch ? enclosureMatch[1] : 'https://images.unsplash.com/photo-1495020689067-958852a7765e?auto=format&fit=crop&w=800&q=80'
      });
    }
    
    // Limit to 9 articles
    if (articles.length >= 9) break;
  }
} catch (error) {
  console.error('Error fetching Substack feed:', error);
  // Fallback placeholder data if fetch fails
  articles = [
    {
      title: 'The Boys Season 5 Episode 5: The Chaos Finally Clicks',
      link: site.socials.substack,
      date: 'May 5, 2026',
      excerpt: 'So yeah... Seth Rogen "died" in The Boys Season 5, Episode 5. Naturally, I thought it\'d be hilarious to make a dramatic "in memoriam" post about it...',
      image: 'https://images.unsplash.com/photo-1594909122845-11baa439b7bf?auto=format&fit=crop&w=800&q=80'
    },
    {
      title: 'Mortal Kombat 2 Review',
      link: site.socials.substack,
      date: 'May 2, 2026',
      excerpt: 'One job... be everything the first Mortal Kombat was not. I saw Mortal Kombat 2 early at the premiere, and hype factor aside, I ended up having a really good time with it...',
      image: 'https://images.unsplash.com/photo-1542751371-adc38448a05e?auto=format&fit=crop&w=800&q=80'
    }
  ];
}
---

<Layout title={title} description={description}>
  <main class="articles-page">
    <div class="container">
      <header class="section-header animate-on-scroll">
        <p class="section-kicker">Substack Feed</p>
        <h1 class="section-title">Latest Articles</h1>
      </header>

      <div class="articles-grid">
        {articles.map((article, index) => (
          <article class="article-card animate-on-scroll" data-delay={index * 100}>
            <div class="article-image-wrapper">
              <img src={article.image} alt={article.title} class="article-image" />
            </div>
            <div class="article-content">
              <span class="article-date">{article.date}</span>
              <h2 class="article-title">{article.title}</h2>
              <p class="article-excerpt">{article.excerpt}</p>
              <a href={article.link} target="_blank" rel="noopener noreferrer" class="article-link">
                Read Full Article
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  
  .section-header {
    text-align: center;
    margin-bottom: 5rem;
  }
</style>
