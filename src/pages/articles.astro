---
import Layout from '../layouts/Layout.astro';
import PageTitle from '../components/PageTitle.astro';
import { site } from '../data/site.js';
import QuadrantFilter from '../components/QuadrantFilter.astro';
import { getArticles } from '../data/feeds.js';

const title = `Articles | ${site.name}`;
const description =
  'Latest editorial content, reviews, and deep dives from Be Unconventional HQ on Substack.';

const allArticles = await getArticles();
const displayArticles = allArticles.slice(0, 20);
---

<Layout title={title} description={description}>
  <main class="articles-page">
    <div class="container">
      <header class="section-header animate-on-scroll">
        <PageTitle
          kicker="Explore The HQ"
          primary="Latest"
          secondary="Articles"
        />
      </header>

      <QuadrantFilter showTypes={false} />

      <div class="articles-grid">
        {
          displayArticles.map((article, index) => (
            <a
              href={article.link}
              target="_blank"
              rel="noopener noreferrer"
              class="article-card animate-on-scroll"
              data-category={(article.category || 'General').toLowerCase()}
              style={`--index: ${index}; text-decoration: none;`}
            >
              <div class="article-image-wrapper">
                <span class="content-badge">{article.category}</span>
                <img
                  src={article.image}
                  alt={article.title}
                  class="article-image"
                />
              </div>
              <div class="article-content">
                <span class="article-date">{article.date}</span>
                <h2 class="article-title">{article.title}</h2>
                <p class="article-excerpt">{article.excerpt}</p>
                <span class="article-link">Read Full Article</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
</style>
