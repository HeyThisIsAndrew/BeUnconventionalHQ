---
import Layout from '../../layouts/Layout.astro';
import { categories } from '../../data/categories.js';
import { getArticles } from '../../data/feeds.js';
import { getVideosUnified } from '../../lib/videos-source';
import { parseVideoId } from '../../lib/platforms/youtube';
import PageTitle from '../../components/PageTitle.astro';
import QuadrantFilter from '../../components/QuadrantFilter.astro';
import ContentCard from '../../components/ContentCard.astro';

export async function getStaticPaths() {
  return categories.map((cat) => ({
    params: { id: cat.slug },
    props: { category: cat },
  }));
}
const { category } = Astro.props;
const allVideos = await getVideosUnified();
const allArticles = await getArticles();

const catLabel = category.label.toLowerCase();
function matchesCategory(item: any) {
  const tags = Array.isArray(item.tags) ? item.tags : [];
  const cat = item.category || 'general';
  const allTags = [...tags, cat].map(t => typeof t === 'string' ? t.toLowerCase().trim() : '');
  
  return allTags.some((t: string) => {
    if (t === catLabel) return true;
    if (catLabel === 'events' && t === 'event') return true;
    if (catLabel === 'event' && t === 'events') return true;
    return false;
  });
}

const categoryVideos = allVideos.filter(matchesCategory).slice(0, 4);
const categoryArticles = allArticles.filter(matchesCategory).slice(0, 4);
---

<Layout title={`${category.label} | Be Unconventional HQ`}>
  <main
    class="category-hub-page flex-1 flex flex-col w-full pb-16 md:pb-24"
    style="padding-top: 120px;"
  >
    <div class="container flex-1 flex flex-col">
      <header class="section-header reveal" data-nav-anchor>
        <PageTitle
          as="h1"
          kicker={category.blurb}
          primary={category.label}
          secondary="HUB"
        />
      </header>

      <section class="hub-section" style="margin-bottom: 6rem;">
        <QuadrantFilter showTypes={false} />

        <h2
          class="filter-label"
          style="margin-bottom: 1.5rem; display: block; margin-right: 0;"
        >
          LATEST VIDEOS
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 w-full">
          {
            categoryVideos.length > 0 ? (
              categoryVideos.map((video: any, index: number) => (
                <ContentCard item={video} index={index} />
              ))
            ) : (
              <p
                class="filter-label empty-note"
                style="text-transform: uppercase;"
              >
                NO VIDEOS FOUND FOR THIS CATEGORY.
              </p>
            )
          }
        </div>
      </section>

      <section class="hub-section" style="margin-bottom: 6rem;">
        <h2
          class="filter-label"
          style="margin-bottom: 1.5rem; display: block; margin-right: 0;"
        >
          LATEST ARTICLES
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 w-full">
          {
            categoryArticles.length > 0 ? (
              categoryArticles.map((article: any, index: number) => (
                <ContentCard item={article} index={index} />
              ))
            ) : (
              <p
                class="filter-label empty-note"
                style="text-transform: uppercase;"
              >
                NO ARTICLES FOUND FOR THIS CATEGORY.
              </p>
            )
          }
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1536px;
    margin: 0 auto;
    padding: 0 2rem;
  }
</style>
