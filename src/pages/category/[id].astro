---
import Layout from '../../layouts/Layout.astro';
import { categories } from '../../data/categories.js';
import { getVideos, getArticles } from '../../data/feeds.js';
import { parseVideoId } from '../../lib/platforms/youtube';
import PageTitle from '../../components/PageTitle.astro';
import QuadrantFilter from '../../components/QuadrantFilter.astro';

export async function getStaticPaths() {
  return categories.map((cat) => ({
    params: { id: cat.slug },
    props: { category: cat },
  }));
}
const { category } = Astro.props;
const allVideos = await getVideos();
const allArticles = await getArticles();
const categoryVideos = allVideos
  .filter((v) => v.category.toLowerCase() === category.label.toLowerCase())
  .slice(0, 4);
const categoryArticles = allArticles
  .filter((a) => a.category.toLowerCase() === category.label.toLowerCase())
  .slice(0, 4);
---

<Layout title={`${category.label} | Be Unconventional HQ`}>
  <main
    class="category-hub-page"
    style="padding-top: 120px; min-height: 100vh;"
  >
    <div class="container">
      <header class="section-header reveal" data-nav-anchor>
        <PageTitle
          as="h1"
          kicker={category.blurb}
          primary={category.label}
          secondary="HUB"
        />
      </header>

      <section class="hub-section" style="margin-bottom: 6rem;">
        <QuadrantFilter isNavMode={true} />

        <h2
          class="filter-label"
          style="margin-bottom: 1.5rem; display: block; margin-right: 0;"
        >
          LATEST VIDEOS
        </h2>
        <div class="video-grid">
          {
            categoryVideos.length > 0 ? (
              categoryVideos.map((video, index) => (
                <div
                  class="video-card reveal video-modal-trigger"
                  data-delay={index * 100}
                  data-video-id={parseVideoId(video.link)}
                  style="cursor: pointer;"
                >
                  <div class="video-thumbnail-wrapper">
                    <span class="content-badge">{video.category}</span>
                    <img
                      src={video.thumbnail}
                      alt={video.title}
                      loading="lazy"
                      decoding="async"
                      class="video-thumbnail"
                      onerror="this.onerror=null;this.src=this.src.replace('maxresdefault','hqdefault')"
                    />
                  </div>
                  <div class="video-info">
                    <h3 class="video-title">{video.title}</h3>
                    <span class="video-watch-btn">Watch Now →</span>
                  </div>
                </div>
              ))
            ) : (
              <p
                class="filter-label empty-note"
                style="text-transform: uppercase;"
              >
                NO VIDEOS FOUND FOR THIS CATEGORY.
              </p>
            )
          }
        </div>
      </section>

      <section class="hub-section" style="margin-bottom: 6rem;">
        <h2
          class="filter-label"
          style="margin-bottom: 1.5rem; display: block; margin-right: 0;"
        >
          LATEST ARTICLES
        </h2>
        <div class="articles-grid">
          {
            categoryArticles.length > 0 ? (
              categoryArticles.map((article, index) => (
                <a
                  href={article.link}
                  target="_blank"
                  class="article-card reveal"
                  data-delay={index * 100}
                >
                  <div class="article-image-wrapper">
                    <img
                      src={article.image}
                      alt={article.title}
                      loading="lazy"
                      decoding="async"
                      class="article-image"
                    />
                  </div>
                  <div class="article-content">
                    <span class="article-date">{article.date}</span>
                    <h3 class="article-title">{article.title}</h3>
                    <span class="article-link">Read More →</span>
                  </div>
                </a>
              ))
            ) : (
              <p
                class="filter-label empty-note"
                style="text-transform: uppercase;"
              >
                NO ARTICLES FOUND FOR THIS CATEGORY.
              </p>
            )
          }
        </div>
      </section>
    </div>
  </main>
</Layout>
