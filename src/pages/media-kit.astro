---
// Self-hosted, same-origin - see Layout.astro. media-kit.astro renders its
// own standalone <html> (bypasses Layout), so it needs its own font import;
// the Google Fonts <link> this replaced was a live external request that
// window.print() doesn't reliably wait on, so a slow/blocked fetch printed
// the whole page (both --font-display and --font-body resolve to this one
// family) in the browser's fallback sans-serif.
import '@fontsource-variable/syne';
import { site } from '../data/site.js';

import channelStats from '../data/cache/channel-stats.json';

let followers = channelStats.followers || 0;
let totalViews = channelStats.totalViews || 0;
let views30Days = channelStats.analytics?.views30Days || 0;
let impressions = channelStats.analytics?.impressions || 0;
let ageString = channelStats.analytics?.age18to34Percent > 0 ? Math.round(channelStats.analytics.age18to34Percent) + '%' : 'XX%';
let maleStr = channelStats.analytics?.malePercent > 0 ? Math.round(channelStats.analytics.malePercent) + '%' : 'XX%';
let femaleStr = channelStats.analytics?.femalePercent > 0 ? Math.round(channelStats.analytics.femalePercent) + '%' : 'XX%';
let genderString = `${maleStr} / ${femaleStr}`;
let geosString = channelStats.analytics?.topGeos?.length > 0 ? channelStats.analytics.topGeos.join(', ') : 'US, GB, IN';
let tvString = channelStats.analytics?.tvViewershipPercent > 0 ? Math.round(channelStats.analytics.tvViewershipPercent) + '%' : 'XX%';
let searchString = channelStats.analytics?.searchTrafficPercent > 0 ? Math.round(channelStats.analytics.searchTrafficPercent) + '%' : 'XX%';
let unsubString = channelStats.analytics?.unsubscribedPercent > 0 ? Math.round(channelStats.analytics.unsubscribedPercent) + '%' : 'XX%';

// Formatter for numbers like 25.5K
const compactFormatter = new Intl.NumberFormat('en-US', {
  notation: 'compact',
  compactDisplay: 'short',
  maximumFractionDigits: 1,
});

const igFollowers = 337;
const tiktokFollowers = 534;

const youtubeReachString = followers > 0 ? compactFormatter.format(followers) : 'XX.Xk';
const viewsString = views30Days > 0 ? compactFormatter.format(views30Days) : (totalViews > 0 ? compactFormatter.format(totalViews) : 'XX.Xk');
const topGeoString = channelStats.analytics?.topGeos?.[0] || 'US';

// Impressions isn't populated for every channel (YouTube only reports it once
// a channel has Suggested/Home-feed thumbnail-impression data). Rather than
// show a literal "XX.Xk" as the single most prominent number on the page,
// fall back to lifetime total views - always populated once the channel has
// any view history at all - and relabel the card to match.
const hasImpressions = impressions > 0;
const headlineMetricValue = hasImpressions
  ? compactFormatter.format(impressions)
  : (totalViews > 0 ? compactFormatter.format(totalViews) : 'XX.Xk');
const headlineMetricLabel = hasImpressions ? 'Total Impressions' : 'Total Views';
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Be Unconventional HQ - Digital Media Kit</title>
    <meta name="robots" content="noindex">
    <style is:global>
        /* CSS reset and print setup */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        /* Set the exact page size so it prints flawlessly to PDF */
        @page {
            size: 8.5in 11in;
            margin: 0;
        }

        :root {
            /* Brand Colors based on the site's dark mode and red accents */
            --bg-color: #0a0a0a;
            --surface-color: #111112;
            --text-main: #f0f0f0;
            --text-muted: #888888;
            --accent-red: #cc0000;
            --font-display: 'Syne Variable', 'Syne', sans-serif;
            --font-body: 'Syne Variable', 'Syne', sans-serif;
        }

        html, body {
            background-color: #111;
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        /* The .page wrapper acts as the physical piece of paper */
        .page {
            width: 8.5in;
            height: 11in;
            margin: 3rem auto; /* Safely centers horizontally and adds 3rem margin top/bottom */
            background-color: var(--bg-color);
            color: var(--text-main);
            font-family: var(--font-body);
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            display: flex;
            flex-direction: column;
            padding: 0.6in; /* Increased padding to ensure nothing touches the edges */
            position: relative;
            box-shadow: 0 20px 40px rgba(0,0,0,0.8); /* Drop shadow so it looks like a paper */
        }

        @media print {
            html, body {
                background-color: transparent;
            }
            .page {
                margin: 0;
                /* Measured directly from a real print-to-PDF on iOS: that
                   pipeline reserves ~0.56in top/side and ~1.35in at the
                   bottom (its own URL/date/page-number footer band) no
                   matter what @page margin says - leaving only ~9.1in of
                   actually usable height out of the nominal 11in. This
                   page's content was sized for the full 11in, so it spilled
                   a sliver onto a second page. Capping .page itself at 9in
                   (with the spacing trims below sized to fit inside that)
                   keeps the whole design on the one usable page instead of
                   trusting @page's declared size, which this pipeline
                   doesn't fully honor.
                   NOTE: not independently confirmed against a second device
                   - this is calibrated from the one real PDF measured, not
                   a documented iOS constant. */
                height: 9in !important;
                padding: 0.3in !important;
                box-shadow: none;
                overflow: hidden;
            }
            /* !important on every property below: this print block sits
               near the top of the stylesheet, before the unconditional
               (screen+print) base rules for these same selectors further
               down the file - without !important the later, unrelated-to-
               print base declaration wins the cascade regardless of the
               media query, exactly like .page's height above would too if
               its base rule weren't the one exception that happens to sit
               earlier in the file. Confirmed empirically: before adding
               !important here, these overrides silently did nothing. */
            .container {
                gap: 0.08in !important;
            }
            .pitch,
            .headshot-placeholder {
                height: 1in !important;
            }
            .headshot-placeholder {
                width: 1in !important;
            }
            .section-title {
                margin-bottom: 0.08in !important;
            }
            .metric-card {
                padding: 0.1in !important;
            }
            .metric-value {
                font-size: 0.28in !important;
                margin-bottom: 0.05in !important;
            }
            .capabilities-list li {
                margin-bottom: 0.06in !important;
            }
            .footer {
                padding-top: 0.06in !important;
            }
            .footer-logo-container {
                margin-top: 0.05in !important;
                padding-bottom: 0.05in !important;
            }
            .action-fab, .fab-container {
                display: none !important;
            }
            /* Confirmed on a real device: this radial-gradient ambient glow
               - subtle by design when spread across the full 8.5x11in
               canvas on screen - rasterizes as a solid opaque red disc in
               at least one real-world print pipeline instead of a soft
               fade. Same underlying failure class as the two fixes below,
               just on a background gradient instead of a shadow; hide it
               for print rather than risk it. */
            .page::before {
                display: none !important;
            }
            /* .word-hq combines `transform` with `text-shadow`, and
               `.word-unconventional` / `.hero-subtitle` carry blurred
               text-shadow on their own - all three are the same risk
               category as the gradient above (a soft rgba effect that a
               real print pipeline can rasterize as a hard block instead of
               a fade). Neutralizing all of them for print rather than
               waiting for each to get individually reported broken. */
            .word-hq,
            .word-unconventional,
            .hero-subtitle {
                text-shadow: none !important;
            }
            /* Same failure class again, box-shadow this time: the blurred
               rgba drop shadow on each metric card, and the large-blur
               inset shadow that feathers the headshot's edges. */
            .metric-card {
                box-shadow: none !important;
            }
            .headshot-placeholder::after {
                box-shadow: none !important;
            }
        }

        /* -------------------------------------
           Mobile screen layout. Everything above this point was sized for
           an 8.5x11in printed sheet - fixed page width, in-unit type scale,
           and a viewport-fixed FAB stack that overlapped content the moment
           the canvas shrank to fit a phone. `screen` scopes all of this to
           on-screen viewing only; @media print above is a separate media
           type and is completely unaffected by anything in this block.
           ------------------------------------- */
        /* Ambient cinematic background glow in the top right */
        .page::before {
            content: '';
            position: absolute;
            top: -10%;
            right: -10%;
            width: 50%;
            height: 50%;
            background: radial-gradient(circle, rgba(204, 0, 0, 0.15) 0%, rgba(10, 10, 10, 0) 70%);
            z-index: 0;
            pointer-events: none;
        }

        /* Floating Actions Container */
        .fab-container {
            position: fixed;
            top: 50%;
            right: 2rem;
            transform: translateY(-50%);
            display: flex;
            flex-direction: column;
            gap: 1rem;
            z-index: 1000;
            width: 260px; /* Fixed width so all buttons are exactly the same size */
        }

        /* Unified Action Button */
        .action-fab {
            background-color: rgba(10, 10, 10, 0.85); /* Slight cinematic backing */
            color: #fff;
            padding: 1rem 1.5rem;
            border-radius: 50px;
            font-family: var(--font-display);
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            border: 1px solid var(--accent-red);
            cursor: pointer;
            box-shadow: 0 0 15px rgba(204, 0, 0, 0.2);
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.2, 1);
            text-decoration: none;
            text-align: center;
            display: block;
            width: 100%;
        }

        .action-fab:hover {
            transform: translateY(-2px);
            background-color: var(--accent-red);
            color: #fff;
            box-shadow: 0 0 30px rgba(204, 0, 0, 0.6);
        }

        .container {
            position: relative;
            z-index: 1;
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 0.2in; /* Slightly tighter spacing to fit logo at bottom */
        }

        /* -------------------------------------
           1. Header Section
           ------------------------------------- */
        .header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 2px solid rgba(255, 255, 255, 0.1);
            padding-bottom: 0.25in;
        }

        .header-text {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        /* Cinematic Title Stack (matching website hero) */
        .hero-title-stack {
            display: flex;
            flex-direction: column;
            align-items: center;
            line-height: 0.85;
            text-transform: uppercase;
            font-family: var(--font-display);
        }

        .hero-title-stack span {
            display: block;
        }

        .word-be {
            font-size: 1.3rem;
            font-weight: 600;
            align-self: center;
            color: var(--text-muted);
            transform: translateX(-3.2rem);
        }

        .word-unconventional {
            font-size: 2.3rem;
            font-weight: 800;
            letter-spacing: -0.04em;
            color: var(--text-main);
            z-index: 2;
            text-shadow: 0 4px 15px rgba(0, 0, 0, 0.6);
        }

        .word-hq {
            font-size: 1.8rem;
            font-weight: 800;
            align-self: center;
            margin-top: -0.7rem;
            transform: translateX(3.6rem);
            color: var(--accent-red);
            text-shadow: 0 0 10px rgba(204, 0, 0, 0.5);
        }

        .hero-kicker {
            color: var(--accent-red);
            font-size: 0.65rem;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            margin-bottom: 0.5rem;
            font-weight: 700;
        }

        .hero-subtitle {
            color: rgba(255, 255, 255, 0.9);
            font-size: 0.75rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            margin-top: 0.8rem;
            font-weight: 600;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
        }

        /* Image blocks */
        .header-images {
            display: flex;
            gap: 0.2in;
        }

        .image-placeholder {
            width: 1.6in;
            height: 1.6in;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Headshot block */
        .pitch-container {
            display: flex;
            align-items: center;
            gap: 0; /* Using margin/padding for precise line placement */
            margin: 0.1in 0;
        }

        .headshot-placeholder {
            width: 1.4in; 
            height: 1.4in; /* Fixed height to match text box */
            background-size: cover;
            background-position: center top;
            background-image: url('/profile.jpg');
            flex-shrink: 0;
            position: relative;
        }

        /* Guarantee absolutely NO hard edges with aggressive feathering */
        .headshot-placeholder::after {
            content: '';
            position: absolute;
            inset: -1px; /* Cover any potential edge artifacts */
            box-shadow: inset 0 0 0.4in 0.1in var(--bg-color); 
            pointer-events: none;
        }

        /* -------------------------------------
           2. Elevator Pitch
           ------------------------------------- */
        .pitch {
            height: 1.4in; /* Match the photo's exact height */
            display: flex;
            flex-direction: column;
            justify-content: center; /* Vertically center the text */
            
            margin-left: 0.25in; /* Space between photo and the line */
            padding-left: 0.25in; /* Space between the line and the text */
            border-left: 1px solid rgba(255, 255, 255, 0.15); /* Subtle thin line */

            font-family: var(--font-display);
            font-size: 0.12in; 
            line-height: 1.6;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.9);
            text-align: justify; /* Force text to be left and right justified evenly */
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        /* -------------------------------------
           3. The Footprint (Metrics)
           ------------------------------------- */
        .section-title {
            font-family: var(--font-display);
            font-size: 0.15in; /* Further reduced to strictly fit inside the column bounds */
            font-weight: 800;
            text-transform: uppercase;
            color: var(--text-muted);
            letter-spacing: 0.05em; /* Reduced tracking to prevent overflow */
            margin-bottom: 0.15in;
            white-space: nowrap;
        }

        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 0.2in;
        }

        .metric-card {
            background-color: var(--surface-color);
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 0.15in 0.1in;
            text-align: center;
            position: relative;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
        }

        /* Subtle glowing top border for cards */
        .metric-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 3px;
            background: var(--accent-red);
            opacity: 0.7;
        }

        .metric-value {
            font-family: var(--font-display);
            font-size: 0.35in; /* Reduced from 0.45in so that large numbers like 319.8K fit perfectly in their box */
            font-weight: 800;
            line-height: 1;
            margin-bottom: 0.08in;
            color: var(--text-main);
        }

        .metric-label {
            font-size: 0.13in;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
        }

        /* -------------------------------------
           4 & 5. Audience and Capabilities Split
           ------------------------------------- */
        .split-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.2in; /* Reduced gap to give columns more width space */
            flex: 1;
        }

        /* Audience Data List */
        .data-list {
            list-style: none;
        }

        .data-list li {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.05in 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            font-size: 0.16in;
        }

        .data-list li:last-child {
            border-bottom: none;
        }

        .data-label {
            font-size: 0.10in;
            line-height: 1.5;
            font-weight: 600;
            color: var(--text-main);
            flex: 1;
            padding-right: 0.1in;
            white-space: nowrap; /* Prevent wrapping */
        }

        .data-value {
            font-family: var(--font-display);
            font-weight: 800;
            font-size: 0.11in;
            color: var(--accent-red);
            white-space: nowrap;
            text-align: right;
        }

        /* Capabilities List */
        .capabilities-list {
            list-style: none;
            padding-top: 0.05in;
        }

        .capabilities-list li {
            position: relative;
            padding-left: 0.25in;
            margin-bottom: 0.1in;
            font-size: 0.12in; /* Reduced to fit all text on one line */
            white-space: nowrap; /* Strictly force single line */
            font-weight: 600;
            line-height: 1.5;
            color: var(--text-main);
        }

        /* Custom cinematic red bullet */
        .capabilities-list li::before {
            content: '►';
            position: absolute;
            left: 0;
            top: 50%;
            transform: translateY(-50%);
            color: var(--accent-red);
            font-size: 0.14in;
        }

        /* -------------------------------------
           6. Footer
           ------------------------------------- */
        .footer {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding-top: 0.1in;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            font-size: 0.095in; /* Safely reduced to guarantee no wrapping or touching edges */
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .footer-item {
            display: flex;
            flex-direction: column;
            align-items: center; /* Center align label above the text */
            text-align: center;
            gap: 0.08in;
        }
        
        .footer a {
            color: var(--text-main);
            text-decoration: none;
        }

        .footer-logo-container {
            display: flex;
            justify-content: center;
            margin-top: 0.1in;
            padding-bottom: 0.1in;
        }

        .footer-logo {
            width: 2.5in;
            height: 0.8in;
            background-image: url('/logo.webp');
            background-size: contain;
            background-repeat: no-repeat;
            background-position: center;
        }
        .social-icon-link {
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
        }
        .social-icon-link:hover svg {
            fill: #ffffff !important;
        }

        @media screen and (max-width: 720px) {
            .page {
                width: 100%;
                height: auto;
                min-height: 100vh;
                margin: 0;
                padding: 2rem 1.25rem 8rem; /* bottom clears the fixed action bar below */
                box-shadow: none;
                overflow-x: hidden; /* .page::before's ambient glow is positioned with a
                   negative right offset by design (bleeds past the edge on the
                   fixed-width desktop canvas); clip it here so it can't add
                   horizontal scroll room on a fluid-width mobile page. */
            }

            .container {
                gap: 1.5rem;
            }

            .hero-kicker {
                font-size: 0.55rem;
                letter-spacing: 0.15em;
            }

            .word-be {
                font-size: clamp(0.75rem, 4vw, 1rem);
                transform: translateX(-0.9rem);
            }

            .word-unconventional {
                font-size: clamp(0.95rem, 6.2vw, 1.3rem);
            }

            .word-hq {
                font-size: clamp(0.85rem, 5.5vw, 1.25rem);
                margin-top: -0.4rem;
                transform: translateX(0.9rem);
            }

            .hero-subtitle {
                font-size: 0.6rem;
                letter-spacing: 0.08em;
            }

            .pitch-container {
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
            }

            .headshot-placeholder {
                width: 5rem;
                height: 5rem;
            }

            .pitch {
                height: auto;
                margin-left: 0;
                padding-left: 0;
                border-left: none;
                font-size: 0.7rem;
                text-align: left;
            }

            .metrics-grid,
            .split-section {
                grid-template-columns: 1fr;
                gap: 1rem;
            }

            .metric-value {
                font-size: 2.1rem;
            }

            .metric-label {
                font-size: 0.7rem;
            }

            .mini-platform-grid {
                grid-template-columns: repeat(3, 1fr) !important;
                gap: 0.4rem !important;
            }

            .data-label {
                white-space: normal;
                font-size: 0.65rem;
            }

            .data-value {
                font-size: 0.75rem;
            }

            .data-list li {
                font-size: 0.75rem;
            }

            .capabilities-list li {
                white-space: normal;
                font-size: 0.75rem;
            }

            .gear-grid {
                grid-template-columns: repeat(2, 1fr) !important;
                gap: 1rem !important;
            }

            .footer {
                grid-template-columns: 1fr !important;
                gap: 0.75rem;
            }

            .footer-logo {
                width: 2in;
                height: 0.65in;
            }

            /* A viewport-fixed vertical stack over an 816px canvas overlaps
               content the instant that canvas shrinks to fit a phone.
               Collapse to a bottom action bar instead - anchored to the
               screen edge, never floating over content. Download PDF (the
               primary action) gets its own full-width row; Press Kit /
               Return to Site split the row below it. */
            .fab-container {
                top: auto;
                bottom: 0;
                left: 0;
                right: 0;
                transform: none;
                display: grid;
                grid-template-columns: 1fr 1fr;
                width: 100%;
                gap: 0.5rem;
                padding: 0.75rem;
                padding-bottom: calc(0.75rem + env(safe-area-inset-bottom, 0px));
                background: rgba(10, 10, 10, 0.95);
                border-top: 1px solid var(--accent-red);
            }

            .fab-container .action-fab {
                width: auto;
                padding: 0.85rem 0.5rem;
                font-size: 0.6rem;
                border-radius: 8px;
            }

            .fab-container .action-fab:first-child {
                grid-column: 1 / -1;
            }
        }

    </style>
</head>
<body>
    <div class="page">
        <div class="container">
        
        <!-- 1. Header Section -->
        <div class="header" style="justify-content: center; border-bottom: none; padding-bottom: 0;">
            <div class="header-text">
                <p class="hero-kicker">Where nerd culture gets cinematic</p>
                <h1 class="hero-title-stack">
                    <span class="word-be">Be</span>
                    <span class="word-unconventional">Unconventional</span>
                    <span class="word-hq">HQ</span>
                </h1>
                <p class="hero-subtitle">Stories craft and culture through a different lens</p>
            </div>
        </div>

        <!-- 2. Elevator Pitch with Headshot -->
        <div class="pitch-container">
            <div class="headshot-placeholder"></div>
            <div class="pitch">
                Be Unconventional HQ was created to share a passion for movies, games, technology, and storytelling with honesty, curiosity, and a cinematic perspective. Whether breaking down cinematography, exploring game mechanics, or geeking out over creative technology, our goal is to slow down, appreciate the craft, and foster a community built on genuine conversations.
            </div>
        </div>

        <!-- 3. Network Reach -->
        <div>
            <h2 class="section-title">NETWORK REACH</h2>
            <div class="metrics-grid">
                
                <div class="metric-card">
                    <div class="metric-value">{headlineMetricValue}</div>
                    <div class="metric-label">{headlineMetricLabel}</div>
                </div>

                <div class="metric-card">
                    <div class="metric-value">{viewsString}</div>
                    <div class="metric-label">30-Day Views</div>
                </div>

                <div class="metric-card">
                    <div class="metric-value">{topGeoString}</div>
                    <div class="metric-label">Top Geo</div>
                </div>
                
            </div>

            <!-- Mini Platform Breakdown Mockup -->
            <div class="mini-platform-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.1in; margin-top: 0.15in; text-align: center;">
                <div style="border: 1px solid rgba(255,255,255,0.05); padding: 0.1in; background: rgba(255,255,255,0.02);">
