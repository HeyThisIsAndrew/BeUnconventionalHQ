---
import { createYouTubeClient } from '../lib/platforms/youtube';

// Fetch API Key and Channel ID from environment variables
const apiKey = import.meta.env.YOUTUBE_API_KEY || process.env.YOUTUBE_API_KEY;
const channelId = import.meta.env.YOUTUBE_CHANNEL_ID || process.env.YOUTUBE_CHANNEL_ID;

let followers = 0;
let totalViews = 0;

if (apiKey && channelId) {
  try {
    const yt = createYouTubeClient({ apiKey });
    const stats = await yt.getChannelStats(channelId);
    followers = stats.followers;
    totalViews = stats.totalViews || 0;
  } catch (error) {
    console.error('Failed to fetch YouTube stats for Media Kit:', error);
  }
}

// Formatter for numbers like 25.5K
const compactFormatter = new Intl.NumberFormat('en-US', {
  notation: 'compact',
  compactDisplay: 'short',
  maximumFractionDigits: 1,
});

const reachString = followers > 0 ? compactFormatter.format(followers) : 'XX.Xk';
const viewsString = totalViews > 0 ? compactFormatter.format(totalViews) : 'XX.Xk';
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Be Unconventional HQ - Digital Media Kit</title>
    <meta name="robots" content="noindex">
    <!-- Importing Brand Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Syne:wght@600;800&display=swap" rel="stylesheet">
    <style>
        /* CSS reset and print setup */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        /* Set the exact page size so it prints flawlessly to PDF */
        @page {
            size: 8.5in 11in;
            margin: 0;
        }

        :root {
            /* Brand Colors based on the site's dark mode and red accents */
            --bg-color: #0a0a0a;
            --surface-color: #111112;
            --text-main: #f0f0f0;
            --text-muted: #888888;
            --accent-red: #cc0000;
            --font-display: 'Syne', sans-serif;
            --font-body: 'Syne', sans-serif;
        }

        html, body {
            background-color: #111;
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        /* The .page wrapper acts as the physical piece of paper */
        .page {
            width: 8.5in;
            height: 11in;
            margin: 3rem auto; /* Safely centers horizontally and adds 3rem margin top/bottom */
            background-color: var(--bg-color);
            color: var(--text-main);
            font-family: var(--font-body);
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
            display: flex;
            flex-direction: column;
            padding: 0.6in; /* Increased padding to ensure nothing touches the edges */
            position: relative;
            box-shadow: 0 20px 40px rgba(0,0,0,0.8); /* Drop shadow so it looks like a paper */
        }

        @media print {
            html, body {
                background-color: transparent;
            }
            .page {
                margin: 0;
                box-shadow: none;
                overflow: hidden;
            }
        }

        /* Ambient cinematic background glow in the top right */
        .page::before {
            content: '';
            position: absolute;
            top: -10%;
            right: -10%;
            width: 50%;
            height: 50%;
            background: radial-gradient(circle, rgba(204, 0, 0, 0.15) 0%, rgba(10, 10, 10, 0) 70%);
            z-index: 0;
            pointer-events: none;
        }

        .container {
            position: relative;
            z-index: 1;
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 0.2in; /* Slightly tighter spacing to fit logo at bottom */
        }

        /* -------------------------------------
           1. Header Section
           ------------------------------------- */
        .header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 2px solid rgba(255, 255, 255, 0.1);
            padding-bottom: 0.25in;
        }

        .header-text {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        /* Cinematic Title Stack (matching website hero) */
        .hero-title-stack {
            display: flex;
            flex-direction: column;
            align-items: center;
            line-height: 0.85;
            text-transform: uppercase;
            font-family: var(--font-display);
        }

        .hero-title-stack span {
            display: block;
        }

        .word-be {
            font-size: 1.3rem;
            font-weight: 600;
            align-self: center;
            color: var(--text-muted);
            transform: translateX(-3.2rem);
        }

        .word-unconventional {
            font-size: 2.3rem;
            font-weight: 800;
            letter-spacing: -0.04em;
            color: var(--text-main);
            z-index: 2;
            text-shadow: 0 4px 15px rgba(0, 0, 0, 0.6);
        }

        .word-hq {
            font-size: 1.8rem;
            font-weight: 800;
            align-self: center;
            margin-top: -0.7rem;
            transform: translateX(3.6rem);
            color: var(--accent-red);
            text-shadow: 0 0 10px rgba(204, 0, 0, 0.5);
        }

        .hero-kicker {
            color: var(--accent-red);
            font-size: 0.65rem;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            margin-bottom: 0.5rem;
            font-weight: 700;
        }

        .hero-subtitle {
            color: rgba(255, 255, 255, 0.9);
            font-size: 0.75rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            margin-top: 0.8rem;
            font-weight: 600;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
        }

        /* Image blocks */
        .header-images {
            display: flex;
            gap: 0.2in;
        }

        .image-placeholder {
            width: 1.6in;
            height: 1.6in;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Headshot block */
        .pitch-container {
            display: flex;
            align-items: center;
            gap: 0; /* Using margin/padding for precise line placement */
            margin: 0.15in 0;
        }

        .headshot-placeholder {
            width: 2.4in; 
            height: 2.4in; /* Fixed height to match text box */
            background-size: cover;
            background-position: center top;
            background-image: url('/profile.jpg');
            flex-shrink: 0;
            position: relative;
        }

        /* Guarantee absolutely NO hard edges with aggressive feathering */
        .headshot-placeholder::after {
            content: '';
            position: absolute;
            inset: -1px; /* Cover any potential edge artifacts */
            box-shadow: inset 0 0 0.9in 0.25in var(--bg-color); 
            pointer-events: none;
        }

        /* -------------------------------------
           2. Elevator Pitch
           ------------------------------------- */
        .pitch {
            height: 2.4in; /* Match the photo's exact height */
            display: flex;
            flex-direction: column;
            justify-content: center; /* Vertically center the text */
            
            margin-left: 0.25in; /* Space between photo and the line */
            padding-left: 0.25in; /* Space between the line and the text */
            border-left: 1px solid rgba(255, 255, 255, 0.15); /* Subtle thin line */

            font-family: var(--font-display);
            font-size: 0.12in; 
            line-height: 1.6;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.9);
            text-align: justify; /* Force text to be left and right justified evenly */
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        /* -------------------------------------
           3. The Footprint (Metrics)
           ------------------------------------- */
        .section-title {
            font-family: var(--font-display);
            font-size: 0.15in; /* Further reduced to strictly fit inside the column bounds */
            font-weight: 800;
            text-transform: uppercase;
            color: var(--text-muted);
            letter-spacing: 0.05em; /* Reduced tracking to prevent overflow */
            margin-bottom: 0.15in;
            white-space: nowrap;
        }

        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 0.2in;
        }

        .metric-card {
            background-color: var(--surface-color);
            border: 1px solid rgba(255, 255, 255, 0.05);
            padding: 0.25in 0.15in;
            text-align: center;
            position: relative;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
        }

        /* Subtle glowing top border for cards */
        .metric-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 3px;
            background: var(--accent-red);
            opacity: 0.7;
        }

        .metric-value {
            font-family: var(--font-display);
            font-size: 0.35in; /* Reduced from 0.45in so that large numbers like 319.8K fit perfectly in their box */
            font-weight: 800;
            line-height: 1;
            margin-bottom: 0.08in;
            color: var(--text-main);
        }

        .metric-label {
            font-size: 0.13in;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
        }

        /* -------------------------------------
           4 & 5. Audience and Capabilities Split
           ------------------------------------- */
        .split-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.2in; /* Reduced gap to give columns more width space */
            flex: 1;
        }

        /* Audience Data List */
        .data-list {
            list-style: none;
        }

        .data-list li {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.15in 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            font-size: 0.16in;
        }

        .data-list li:last-child {
            border-bottom: none;
        }

        .data-label {
            font-weight: 600;
            color: var(--text-muted);
            flex: 1;
            padding-right: 0.1in;
            white-space: nowrap; /* Prevent wrapping */
        }

        .data-value {
            font-family: var(--font-display);
            font-weight: 800;
            font-size: 0.22in;
            color: var(--accent-red);
            white-space: nowrap;
            text-align: right;
        }

        /* Capabilities List */
        .capabilities-list {
            list-style: none;
            padding-top: 0.05in;
        }

        .capabilities-list li {
            position: relative;
            padding-left: 0.25in;
            margin-bottom: 0.15in;
            font-size: 0.12in; /* Reduced to fit all text on one line */
            white-space: nowrap; /* Strictly force single line */
            font-weight: 600;
            line-height: 1.5;
            color: var(--text-main);
        }

        /* Custom cinematic red bullet */
        .capabilities-list li::before {
            content: '►';
            position: absolute;
            left: 0;
            top: 0.02in;
            color: var(--accent-red);
            font-size: 0.14in;
        }

        /* -------------------------------------
           6. Footer
           ------------------------------------- */
        .footer {
            margin-top: auto; /* Pushes footer to the exact bottom of the 11in page */
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding-top: 0.2in;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            font-size: 0.095in; /* Safely reduced to guarantee no wrapping or touching edges */
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .footer-item {
            display: flex;
            flex-direction: column;
            align-items: center; /* Center align label above the text */
            text-align: center;
            gap: 0.08in;
        }
        
        .footer a {
            color: var(--text-main);
            text-decoration: none;
        }

        .footer-logo-container {
            display: flex;
            justify-content: center;
            margin-top: 0.1in;
            padding-bottom: 0.1in;
        }

        .footer-logo {
            width: 2.5in;
            height: 0.8in;
            background-image: url('/logo.webp');
            background-size: contain;
            background-repeat: no-repeat;
            background-position: center;
        }
    </style>
</head>
<body>
    <div class="page">
        <div class="container">
        
        <!-- 1. Header Section -->
        <div class="header" style="justify-content: center; border-bottom: none; padding-bottom: 0;">
            <div class="header-text">
                <p class="hero-kicker">Where nerd culture gets cinematic</p>
                <h1 class="hero-title-stack">
                    <span class="word-be">Be</span>
                    <span class="word-unconventional">Unconventional</span>
                    <span class="word-hq">HQ</span>
                </h1>
                <p class="hero-subtitle">Stories craft and culture through a different lens</p>
            </div>
        </div>

        <!-- 2. Elevator Pitch with Headshot -->
        <div class="pitch-container">
            <div class="headshot-placeholder"></div>
            <div class="pitch">
                Be Unconventional HQ was created to share a passion for movies, games, technology, and storytelling with honesty, curiosity, and a cinematic perspective. Whether breaking down cinematography, exploring game mechanics, or geeking out over creative technology, our goal is to slow down, appreciate the craft, and champion genuine conversations over clickbait.
            </div>
        </div>

        <!-- 3. The Footprint -->
        <div>
            <h2 class="section-title">The Footprint</h2>
            <div class="metrics-grid">
                
                <div class="metric-card">
