---
import Layout from '../layouts/Layout.astro';
import PageTitle from '../components/PageTitle.astro';
import { site } from '../data/site.js';
import QuadrantFilter from '../components/QuadrantFilter.astro';
import { parseVideoId } from '../lib/platforms/youtube';
import { getVideos } from '../data/feeds.js';

const title = `Videos | ${site.name}`;
const description =
  'Explore the latest cinematic video content from Be Unconventional HQ.';

const displayVideos = await getVideos();
---

<Layout title={title} description={description}>
  <main class="videos-page">
    <div class="container">
      <header class="section-header animate-on-scroll" data-nav-anchor>
        <PageTitle
          as="h1"
          kicker="Explore The HQ"
          primary="Latest"
          secondary="Videos"
        />
      </header>

      <QuadrantFilter showTypes={false} />

      <div class="video-grid">
        {
          displayVideos.map((video, index) => (
            <div
              class="video-card animate-on-scroll is-visible video-modal-trigger"
              data-type="video"
              data-category={(video.category || 'General').toLowerCase()}
              data-video-id={parseVideoId(video.link)}
              style={`--index: ${index}; cursor: pointer;`}
            >
              <div class="video-thumbnail-wrapper">
                <span class="content-badge">{video.category}</span>
                <img
                  src={video.thumbnail}
                  alt={video.title}
                  loading="lazy"
                  decoding="async"
                  class="video-thumbnail"
                  onerror="this.onerror=null;this.src=this.src.replace('maxresdefault','hqdefault')"
                />
                <div class="video-play-overlay">
                  <div class="play-icon">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                    >
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </div>
                </div>
              </div>
              <div class="video-info">
                <h3 class="video-title">{video.title}</h3>
                <div class="video-watch-btn">
                  Watch Now
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
</style>
