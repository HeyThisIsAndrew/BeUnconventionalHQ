---
import Layout from '../layouts/Layout.astro';
import VideoCard from '../components/VideoCard.astro';
import { getVideos } from '../data/feeds.js';
import { CATEGORIES } from '../data/constants.js';
import { site } from '../data/site.js';

const videos = await getVideos();
const present = new Set(videos.map((v) => v.category || 'General'));
const filters = ['All', ...CATEGORIES.filter((c) => present.has(c))];
---

<Layout
  title="Videos"
  description="Watch the latest film, TV, and gaming videos from Be Unconventional HQ."
>
  <header class="page-head container">
    <p class="eyebrow">The Cinematic Vault</p>
    <h1 class="heading">Videos</h1>
    <p class="lead">
      Reviews, reactions, and breakdowns — straight from the channel.
    </p>
  </header>

  <div class="container section" style="padding-top:0">
    {
      filters.length > 1 && (
        <div
          class="filters"
          role="tablist"
          aria-label="Filter videos by category"
        >
          {filters.map((f) => (
            <button
              class:list={['chip', { active: f === 'All' }]}
              data-filter={f.toLowerCase()}
            >
              {f}
            </button>
          ))}
        </div>
      )
    }

    {
      videos.length > 0 ? (
        <div class="card-grid" id="grid">
          {videos.map((video) => (
            <VideoCard video={video} />
          ))}
        </div>
      ) : (
        <p class="empty-note">
          No videos to show right now — head to
          <a href={site.socials.youtube} target="_blank" rel="noopener">
            {' '}
            YouTube
          </a>{' '}
          for the latest.
        </p>
      )
    }
  </div>
</Layout>

<script>
  const chips = [...document.querySelectorAll<HTMLButtonElement>('.chip')];
  const cards = [
    ...document.querySelectorAll<HTMLElement>('#grid > [data-category]'),
  ];

  function apply(filter: string) {
    chips.forEach((c) =>
      c.classList.toggle('active', c.dataset.filter === filter)
    );
    cards.forEach((card) => {
      const match = filter === 'all' || card.dataset.category === filter;
      card.style.display = match ? '' : 'none';
    });
  }

  chips.forEach((chip) =>
    chip.addEventListener('click', () => apply(chip.dataset.filter || 'all'))
  );

  const hash = decodeURIComponent(location.hash.replace('#', '')).toLowerCase();
  if (hash && chips.some((c) => c.dataset.filter === hash)) apply(hash);
</script>
