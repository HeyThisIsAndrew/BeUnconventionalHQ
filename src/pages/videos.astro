---
import Layout from '../layouts/Layout.astro';
import PageTitle from '../components/PageTitle.astro';
import { site } from '../data/site.js';
import { CATEGORIES } from '../data/constants.js';
import { getVideos } from '../data/feeds.js';

const title = `Videos | ${site.name}`;
const description =
  'Explore the latest cinematic video content from Be Unconventional HQ.';

const displayVideos = await getVideos();
const categories = ['All', ...CATEGORIES];
---

<Layout title={title} description={description}>
  <main class="videos-page">
    <div class="container">
      <header class="section-header animate-on-scroll">
        <PageTitle
          kicker="Explore The HQ"
          primary="Latest"
          secondary="Videos"
        />
      </header>

      <nav class="filter-nav animate-on-scroll" data-delay="100">
        <div class="filter-group">
          <span class="filter-label">CATEGORY:</span>
          <div class="filter-scroll">
            {
              categories.map((category) => (
                <button
                  class:list={['filter-btn', { active: category === 'All' }]}
                  data-filter={category.toLowerCase()}
                >
                  {category.toUpperCase()}
                </button>
              ))
            }
          </div>
        </div>
      </nav>

      <div class="video-grid">
        {
          displayVideos.map((video, index) => (
            <div
              class="video-card animate-on-scroll is-visible video-modal-trigger"
              data-category={(video.category || 'General').toLowerCase()}
              data-video-id={
                video.link.includes('shorts')
                  ? video.link.split('/').pop()
                  : new URL(video.link).searchParams.get('v')
              }
              style={`--index: ${index}; cursor: pointer;`}
            >
              <div class="video-thumbnail-wrapper">
                <span class="content-badge">{video.category}</span>
                <img
                  src={video.thumbnail}
                  alt={video.title}
                  class="video-thumbnail"
                  onerror="this.onerror=null;this.src=this.src.replace('maxresdefault','hqdefault')"
                />
                <div class="video-play-overlay">
                  <div class="play-icon">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                    >
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </div>
                </div>
              </div>
              <div class="video-info">
                <h3 class="video-title">{video.title}</h3>
                <div class="video-watch-btn">
                  Watch Now
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </main>
</Layout>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const videoCards = document.querySelectorAll('.video-card');

  // Filter Logic
  filterBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      if (btn.classList.contains('active')) return;

      filterBtns.forEach(function (b) {
        b.classList.remove('active');
      });
      btn.classList.add('active');

      const filter = btn.getAttribute('data-filter');

      videoCards.forEach(function (card) {
        card.classList.remove('is-visible');
        (card as HTMLElement).style.pointerEvents = 'none';
      });

      setTimeout(function () {
        let visibleIndex = 0;
        videoCards.forEach(function (card) {
          const category = card.getAttribute('data-category');
          const isMatch = filter === 'all' || category === filter;

          if (isMatch) {
            (card as HTMLElement).style.display = 'flex';
            (card as HTMLElement).style.transitionDelay =
              visibleIndex * 80 + 'ms';
            visibleIndex++;
            void (card as HTMLElement).offsetWidth;
            card.classList.add('is-visible');
            (card as HTMLElement).style.pointerEvents = 'auto';
          } else {
            (card as HTMLElement).style.display = 'none';
          }
        });
      }, 400);
    });
  });
</script>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
</style>
