---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Categories from '../components/Categories.astro';
import LatestArticles from '../components/LatestArticles.astro';
import { getVideos } from '../data/feeds.js';
---

<Layout title="Be Unconventional HQ">
  <Hero />

  <section class="container" style="padding-top: 6rem; padding-bottom: 2rem; max-width: 1200px; margin: 0 auto;">
    <div class="section-header reveal" style="text-align: center; margin-bottom: 3rem;">
      <p class="section-kicker" style="color: var(--color-accent); font-size: 0.7rem; letter-spacing: 0.4em; text-transform: uppercase;">Latest From The Channel</p>
      <h2 class="section-title" style="font-family: var(--font-display); font-size: clamp(2.2rem, 5vw, 4rem); font-weight: 800; color: white; text-transform: uppercase;">Recent Videos</h2>
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2.5rem;">
      {(await getVideos()).slice(0, 3).map((video, index) => (
        <a href={video.link} target="_blank" class="reveal" data-delay={index * 100} style="background: #111; border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; overflow: hidden; text-decoration: none; display: flex; flex-direction: column; transition: transform 0.3s, border-color 0.3s;">
          <img src={video.thumbnail} alt={video.title} style="width: 100%; aspect-ratio: 16/9; object-fit: cover;" onerror="this.onerror=null;this.src=this.src.replace('maxresdefault','hqdefault')" />
          <div style="padding: 1.5rem;">
            <h3 style="color: white; font-family: var(--font-display); font-size: 1.1rem; font-weight: 700; margin-bottom: 1rem;">{video.title}</h3>
            <span style="color: var(--color-accent); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em;">Watch Now →</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <Categories />
  <LatestArticles />

  <section class="container" style="margin-bottom: 6rem; position: relative; z-index: 10;">
    <div class="cta-band reveal">
      <div>
        <p class="section-kicker" style="text-align: left;">Don't miss a drop</p>
        <h2 class="cta-title" style="font-family: var(--font-display); font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 800; margin-bottom: 0.5rem; text-align: left; line-height: 1.1;">Get the next review in your inbox.</h2>
        <p style="color: var(--color-white-muted); text-align: left;">New videos and articles, straight from Be Unconventional HQ.</p>
      </div>
      <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1rem; align-items: center;">
        <a class="cta-button-primary" href="https://beunconventionalhq.substack.com" target="_blank" rel="noopener">Subscribe on Substack</a>
        <a class="cta-button-primary" style="background: transparent; border-color: rgba(255,255,255,0.2);" href="https://youtube.com/@BeUnconventionalHQ" target="_blank" rel="noopener">Subscribe on YouTube</a>
      </div>
    </div>
  </section>
</Layout>
