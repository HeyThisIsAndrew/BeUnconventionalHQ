---
import Layout from '../layouts/Layout.astro';
import Categories from '../components/Categories.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="Be Unconventional HQ">

  <!-- NAVBAR -->
  <nav id="navbar" style="
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    padding: 1.25rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: background 0.4s ease, backdrop-filter 0.4s ease;
  ">
    <a href="/">
      <img src={`${base}logo.png`} alt="Be Unconventional HQ" style="height: 48px; width: auto;" />
    </a>
    <ul style="
      list-style: none;
      display: flex;
      gap: 2rem;
      margin: 0;
      padding: 0;
    ">
      <li><a href="/videos" style="color: var(--color-white); font-family: var(--font-body); font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; transition: color 0.2s;">Videos</a></li>
      <li><a href="/articles" style="color: var(--color-white); font-family: var(--font-body); font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; transition: color 0.2s;">Articles</a></li>
      <li><a href="/about" style="color: var(--color-white); font-family: var(--font-body); font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; transition: color 0.2s;">About</a></li>
      <li><a href="/contact" style="color: var(--color-accent); font-family: var(--font-body); font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; font-weight: 600;">Contact</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section style="
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  ">
    <!-- BANNER IMAGE WITH KEN BURNS -->
    <div style={`position: absolute; inset: 0; background-image: url('${base}banner.png'); background-size: cover; background-position: center; animation: kenburns 20s ease-in-out infinite alternate; z-index: 0;`}></div>

    <!-- DARK OVERLAY -->
    <div style="
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(10,10,10,0.3) 0%,
        rgba(10,10,10,0.5) 50%,
        rgba(10,10,10,0.95) 100%
      );
      z-index: 1;
    "></div>

    <!-- HERO CONTENT -->
    <div style="
      position: relative;
      z-index: 2;
      text-align: center;
      padding: 0 1.5rem;
    ">
      <p style="
        color: var(--color-accent);
        font-family: var(--font-body);
        font-size: 0.75rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
      ">Where Nerd Culture Gets Cinematic</p>

      <h1 style="
        font-family: var(--font-display);
        font-size: clamp(3rem, 8vw, 7rem);
        font-weight: 800;
        color: var(--color-white);
        line-height: 1;
        margin-bottom: 2rem;
      ">Be Unconventional HQ</h1>

      <p style="
        color: var(--color-white-muted);
        font-family: var(--font-body);
        font-size: 0.9rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        margin-bottom: 2.5rem;
      ">Sometimes Unconventional is the Only Way Forward</p>

      <a href="/videos" style="
        display: inline-block;
        background-color: var(--color-accent);
        color: var(--color-white);
        font-family: var(--font-body);
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        text-decoration: none;
        padding: 0.9rem 2.5rem;
        transition: background 0.2s ease;
      ">Explore Content</a>
    </div>
  </section>
  <Categories />
  <Categories />
  <Categories />
  <Categories />

</Layout>

<!-- NAVBAR SCROLL EFFECT -->
<script>
  const navbar = document.getElementById('navbar');
  if (navbar) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        navbar.style.background = 'rgba(10,10,10,0.92)';
        navbar.style.backdropFilter = 'blur(12px)';
        navbar.style.borderBottom = '1px solid rgba(255,255,255,0.1)';
      } else {
        navbar.style.background = 'rgba(10,10,10,0.4)';
        navbar.style.backdropFilter = 'none';
        navbar.style.borderBottom = '1px solid rgba(255,255,255,0.06)';
      }
    });
  }
</script>

<!-- KEN BURNS ANIMATION -->
<style>
  @keyframes kenburns {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.08);
    }
  }

  nav a:hover {
    color: var(--color-accent) !important;
  }
</style>