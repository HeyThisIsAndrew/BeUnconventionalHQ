---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site.js';
import { parseVideoId } from '../lib/platforms/youtube';
import Hero from '../components/Hero.astro';
import Categories from '../components/Categories.astro';
import LatestArticles from '../components/LatestArticles.astro';
import PromoBanner from '../components/PromoBanner.astro';
import TakeoverBillboard from '../components/TakeoverBillboard.astro';
import { getVideosUnified } from '../lib/videos-source';
import PageTitle from '../components/PageTitle.astro';
import ContentCard from '../components/ContentCard.astro';

// Get the current path, stripping trailing slashes for safety
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHomePage = currentPath === '/';
---

<Layout title="Be Unconventional HQ">
  <main>
  <Hero />

  {/* Route-based conditional rendering guardrail */}
  {isHomePage && <TakeoverBillboard />}

  {
    false && (
      <PromoBanner
        title="Final Space: The Ending"
        subtitle="Olan Rogers finally gets to finish the story that captured our hearts. See why this is the most important release of the year."
        videoId="CBUmFGi_NNI"
        image="https://i.ytimg.com/vi/CBUmFGi_NNI/maxresdefault.jpg"
      />
    )
  }

  <section
    class="container"
    style="padding-top: 4rem; padding-bottom: 6rem; max-width: 1536px; margin: 0 auto;"
  >
    <div class="section-header reveal animate-on-scroll">
      <PageTitle
        kicker="Latest From The Channel"
        primary="Recent"
        secondary="Videos"
      />
    </div>
    <div
      style="display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 400px), 1fr)); gap: 2.5rem;"
    >
      {
        (await getVideosUnified())
          .slice(0, 3)
          .map((video, index) => (
            <ContentCard item={video} index={index} />
          ))
      }
    </div>
  </section>

  <section
    class="container"
    style="padding-bottom: 8rem; max-width: 1536px; margin: 0 auto;"
  >
    <div class="section-header reveal animate-on-scroll">
      <PageTitle kicker="Explore The HQ" primary="What We" secondary="Cover" />
    </div>
    <Categories />
  </section>

  <LatestArticles />

  <section
    class="container"
    style="margin-bottom: 2rem; position: relative; z-index: 10;"
  >
    <div
      class="cta-band reveal"
      style="flex-direction: column; justify-content: center; align-items: center; text-align: center;"
    >
      <div style="width: 100%;">
        <div class="section-header" style="margin-bottom: 1rem;">
          <PageTitle
            kicker="Don't miss a drop"
            primary="Subscribe"
            secondary="For Updates"
            scale="secondary"
          />
        </div>
        <p style="color: var(--color-white-muted);">
          New videos and articles, straight from Be Unconventional HQ.
        </p>
      </div>
      <div class="cta-buttons-wrapper">
        <a
          class="cta-button-primary"
          href={site.socials.substack}
          target="_blank"
          rel="noopener">Subscribe on Substack</a
        >
        <a
          class="cta-button-primary"
          href={site.socials.youtube}
          target="_blank"
          rel="noopener">Subscribe on YouTube</a
        >
      </div>
    </div>
  </section>
  </main>
</Layout>

<style>
  .cta-buttons-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2rem;
    width: 100%;
  }

  .cta-buttons-wrapper .cta-button-primary {
    width: 100%;
    text-align: center;
  }

  @media (min-width: 768px) {
    .cta-buttons-wrapper {
      flex-direction: row;
    }

    .cta-buttons-wrapper .cta-button-primary {
      flex: 1;
    }
  }
</style>
