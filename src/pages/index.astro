---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site.js';
import Hero from '../components/Hero.astro';
import Categories from '../components/Categories.astro';
import LatestArticles from '../components/LatestArticles.astro';
import PromoBanner from '../components/PromoBanner.astro';
import { getVideos } from '../data/feeds.js';
---

<Layout title="Be Unconventional HQ">
  <Hero />

  <PromoBanner 
    title="Final Space: The Ending"
    subtitle="Olan Rogers finally gets to finish the story that captured our hearts. See why this is the most important release of the year."
    videoId="CBUmFGi_NNI"
    image="https://i.ytimg.com/vi/CBUmFGi_NNI/maxresdefault.jpg"
  />

  <section
    class="container"
    style="padding-top: 4rem; padding-bottom: 6rem; max-width: 1200px; margin: 0 auto;"
  >
    <div class="section-header reveal animate-on-scroll">
      <h2 class="hero-title-stack">
        <span class="word-be">Latest From The Channel</span>
        <span class="word-unconventional">Recent</span>
        <span class="word-hq">Videos</span>
      </h2>
    </div>
    <div
      style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2.5rem;"
    >
      {
        (await getVideos())
          .filter((v) => v.isUpload)
          .slice(0, 3)
          .map((video, index) => (
            <a
              href={video.link}
              class="reveal video-card-home play-modal-btn"
              data-delay={index * 100}
              data-video-id={video.link.includes('shorts') ? video.link.split('/').pop() : new URL(video.link).searchParams.get('v')}
              style="background: var(--color-surface); border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; overflow: hidden; text-decoration: none; display: flex; flex-direction: column; transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease; min-height: 100%;"
            >
              <div style="position: relative; width: 100%; aspect-ratio: 16/9; overflow: hidden;">
                <img
                  src={video.thumbnail}
                  alt={video.title}
                  style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;"
                  onerror="this.onerror=null;this.src=this.src.replace('maxresdefault','hqdefault')"
                />
              </div>
              <div style="padding: 1.5rem; display: flex; flex-direction: column; flex-grow: 1;">
                <h3 style="color: white; font-family: var(--font-display); font-size: 1.1rem; font-weight: 700; margin-bottom: 1rem; line-height: 1.4;">
                  {video.title}
                </h3>
                <span
                  class="watch-now-btn"
                  style="margin-top: auto; color: var(--color-white); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; display: inline-block; position: relative; width: fit-content; transition: color 0.3s ease;"
                >
                  Watch Now{' '}
                  <span style="color: var(--color-accent);">&rarr;</span>
                  <span
                    class="btn-underline"
                    style="position: absolute; bottom: -4px; left: 0; width: 0; height: 1px; background: var(--color-accent); transition: width 0.3s ease;"
                  />
                </span>
              </div>
            </a>
          ))
      }
    </div>
  </section>

  <section
    class="container"
    style="padding-bottom: 8rem; max-width: 1200px; margin: 0 auto;"
  >
    <div class="section-header reveal animate-on-scroll">
      <h2 class="hero-title-stack">
        <span class="word-be">Explore The HQ</span>
        <span class="word-unconventional">What We</span>
        <span class="word-hq">Cover</span>
      </h2>
    </div>
    <Categories />
  </section>

  <LatestArticles />

  <section
    class="container"
    style="margin-bottom: 6rem; position: relative; z-index: 10;"
  >
    <div class="cta-band reveal">
      <div>
        <p class="section-kicker" style="text-align: left;">
          Don't miss a drop
        </p>
        <h2
          class="cta-title"
          style="font-family: var(--font-display); font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 800; margin-bottom: 0.5rem; text-align: left; line-height: 1.1;"
        >
          Get the next review in your inbox.
        </h2>
        <p style="color: var(--color-white-muted); text-align: left;">
          New videos and articles, straight from Be Unconventional HQ.
        </p>
      </div>
      <div
        style="display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1rem; align-items: center;"
      >
        <a
          class="cta-button-primary"
          href={site.socials.substack}
          target="_blank"
          rel="noopener">Subscribe on Substack</a>
        <a
          class="cta-button-primary"
          href={site.socials.youtube}
          target="_blank"
          rel="noopener">Subscribe on YouTube</a>
      </div>
    </div>
  </section>

  <!-- Experimental Modal Overlay -->
  <div id="video-modal" class="modal-overlay">
    <div class="modal-content">
      <button class="modal-close">&times;</button>
      <div class="video-container">
        <iframe
          id="modal-iframe"
          width="560"
          height="315"
          src=""
          title="YouTube video player"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </div>
</Layout>

<script>
  const modal = document.getElementById('video-modal');
  const modalIframe = document.getElementById('modal-iframe') as HTMLIFrameElement;
  const modalClose = document.querySelector('.modal-close');
  const playBtns = document.querySelectorAll('.play-modal-btn');

  // Modal Logic
  playBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const videoId = btn.getAttribute('data-video-id');
      if (videoId && modal && modalIframe) {
        modalIframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
      }
    });
  });

  const closeModal = () => {
    if (modal && modalIframe) {
      modal.classList.remove('active');
      modalIframe.src = '';
      document.body.style.overflow = '';
    }
  };

  modalClose?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>

<style>
  /* Modal Styles */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000;
    opacity: 0;
    visibility: hidden;
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .modal-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .modal-content {
    width: 90%;
    max-width: 1000px;
    position: relative;
    transform: scale(0.9);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .modal-overlay.active .modal-content {
    transform: scale(1);
  }

  .video-container {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 */
    height: 0;
    overflow: hidden;
    background: #000;
    box-shadow: 0 0 50px rgba(204, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .modal-close {
    position: absolute;
    top: -40px;
    right: 0;
    background: none;
    border: none;
    color: white;
    font-size: 2rem;
    cursor: pointer;
    transition: color 0.3s ease;
  }

  .modal-close:hover {
    color: var(--color-accent);
  }
</style>
