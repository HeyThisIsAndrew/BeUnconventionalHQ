---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CategoryStrip from '../components/CategoryStrip.astro';
import VideoCard from '../components/VideoCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getVideos, getArticles } from '../data/feeds.js';
import { site } from '../data/site.js';

const videos = (await getVideos()).slice(0, 3);
const articles = (await getArticles()).slice(0, 3);
---

<Layout>
  <Hero />

  {
    videos.length > 0 && (
      <section class="section container">
        <SectionHeader
          eyebrow="Latest from the channel"
          title="Recent videos"
          href="/videos"
        />
        <div class="card-grid">
          {videos.map((video) => (
            <VideoCard video={video} />
          ))}
        </div>
      </section>
    )
  }

  <section class="section container">
    <SectionHeader eyebrow="What we cover" title="Explore the HQ" />
    <CategoryStrip />
  </section>

  {
    articles.length > 0 && (
      <section class="section container">
        <SectionHeader
          eyebrow="From the editorial feed"
          title="Recent articles"
          href="/articles"
        />
        <div class="card-grid">
          {articles.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
      </section>
    )
  }

  <section class="section container">
    <div class="cta-band reveal">
      <div>
        <p class="eyebrow">Don't miss a drop</p>
        <h2 class="cta-title">Get the next review in your inbox.</h2>
        <p class="lead">
          New videos and articles, straight from Be Unconventional HQ.
        </p>
      </div>
      <div class="cta-actions">
        <a
          class="btn btn-primary"
          href={site.socials.substack}
          target="_blank"
          rel="noopener">Subscribe on Substack</a
        >
        <a
          class="btn btn-ghost"
          href={site.socials.youtube}
          target="_blank"
          rel="noopener">Subscribe on YouTube</a
        >
      </div>
    </div>
  </section>
</Layout>

<style>
  .cta-band {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: clamp(2.25rem, 5vw, 3.5rem);
    border-radius: var(--radius);
    border: 1px solid var(--line);
    background:
      radial-gradient(
        120% 140% at 0% 0%,
        rgba(229, 9, 20, 0.16) 0%,
        transparent 55%
      ),
      var(--bg-1);
  }
  .cta-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    line-height: 1.1;
    margin-block: 0.6rem 0.6rem;
    max-width: 18ch;
  }
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }
</style>
