---
import Layout from '../layouts/Layout.astro';
import PageTitle from '../components/PageTitle.astro';
import { site } from '../data/site.js';

const title = `Contact | ${site.name}`;
const description =
  'Get in touch for press inquiries, collaborations, or general questions.';

---

<Layout title={title} description={description}>
  <main class="contact-page">
    <!-- Turnstile script -->
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    <div class="contact-container">
      <header class="section-header animate-on-scroll" data-nav-anchor>
        <PageTitle as="h1" kicker="Get In Touch" primary="Contact" secondary="Us" />
      </header>

      <form
        id="contact-form"
        class="contact-form animate-on-scroll"
        data-delay="100"
      >
        <div class="form-group">
          <label for="name" class="form-label">Full Name</label>
          <input
            type="text"
            id="name"
            name="name"
            class="form-input"
            placeholder="Enter your name"
            required
          />
        </div>

        <div class="form-group">
          <label for="email" class="form-label">Email Address</label>
          <input
            type="email"
            id="email"
            name="email"
            class="form-input"
            placeholder="Enter your email"
            required
          />
        </div>

        <div class="form-group">
          <label for="subject" class="form-label">Subject</label>
          <select id="subject" name="subject" class="form-select" required>
            <option value="" disabled selected>Select a subject</option>
            <option value="press">Press Inquiry</option>
            <option value="collaboration">Collaboration</option>
            <option value="general">General Question</option>
          </select>
        </div>

        <div class="form-group">
          <label for="message" class="form-label">Message</label>
          <textarea
            id="message"
            name="message"
            class="form-textarea"
            placeholder="How can we help?"
            required></textarea>
        </div>

        <div class="form-group">
          <!-- Turnstile widget -->
          <div class="cf-turnstile" data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY}></div>
        </div>

        <div
          id="form-status"
          class="form-status-message"
          role="status"
          aria-live="polite"
        ></div>

        <button type="submit" class="form-submit cta-button-primary">
          Send Message
        </button>
      </form>

      <script is:inline>
        const form = document.getElementById('contact-form');
        const status = document.getElementById('form-status');
        const submitBtn = form.querySelector('.form-submit');

        if (form && status) {
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());

            submitBtn.disabled = true;
            submitBtn.textContent = 'Sending...';
            status.classList.remove('is-visible');
            status.innerHTML = '';
            status.style.background = '';
            status.style.borderColor = '';

            try {
              const res = await fetch('/api/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data),
              });

              const result = await res.json();

              if (res.ok) {
                status.innerHTML = '✅ Your message has been sent. We will get back to you soon!';
                status.style.background = 'rgba(0, 204, 0, 0.1)';
                status.style.borderColor = 'green';
                status.classList.add('is-visible');
                form.reset();
              } else {
                status.innerHTML = `❌ ${result.error || 'Something went wrong. Please try again.'}`;
                status.style.background = 'rgba(204, 0, 0, 0.1)';
                status.style.borderColor = 'red';
                status.classList.add('is-visible');
              }
            } catch (err) {
              status.innerHTML = '❌ Network error. Please try again.';
              status.style.background = 'rgba(204, 0, 0, 0.1)';
              status.style.borderColor = 'red';
              status.classList.add('is-visible');
            } finally {
              submitBtn.disabled = false;
              submitBtn.textContent = 'Send Message';
            }
          });
        }
      </script>
    </div>

  </main>
</Layout>

<style>
  .form-status-message {
    display: none;
    padding: 1rem;
    margin-bottom: 1.5rem;
    background: rgba(204, 0, 0, 0.1);
    border: 1px solid var(--color-accent);
    color: var(--color-white);
    font-size: 0.85rem;
    text-align: center;
    animation: fadeIn 0.3s ease;
  }

  .form-status-message.is-visible {
    display: block;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-5px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
