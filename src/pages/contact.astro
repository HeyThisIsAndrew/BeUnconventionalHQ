---
import Layout from '../layouts/Layout.astro';
import PageTitle from '../components/PageTitle.astro';
import { site } from '../data/site.js';

const title = `Contact | ${site.name}`;
const description =
  'Get in touch for press inquiries, collaborations, or general questions.';

---

<Layout title={title} description={description}>
  <main class="contact-page">
    <div class="contact-container">
      <header class="section-header animate-on-scroll" data-nav-anchor>
        <PageTitle as="h1" kicker="Get In Touch" primary="Contact" secondary="Us" />
      </header>

      <form
        id="contact-form"
        class="contact-form animate-on-scroll"
        data-delay="100"
      >
        <div class="form-group">
          <label for="name" class="form-label">Full Name</label>
          <input
            type="text"
            id="name"
            name="name"
            class="form-input"
            placeholder="Enter your name"
            required
          />
        </div>

        <div class="form-group">
          <label for="email" class="form-label">Email Address</label>
          <input
            type="email"
            id="email"
            name="email"
            class="form-input"
            placeholder="Enter your email"
            required
          />
        </div>

        <div class="form-group">
          <label for="subject" class="form-label">Subject</label>
          <select id="subject" name="subject" class="form-select" required>
            <option value="" disabled selected>Select a subject</option>
            <option value="press">Press Inquiry</option>
            <option value="collaboration">Collaboration</option>
            <option value="general">General Question</option>
          </select>
        </div>

        <div class="form-group">
          <label for="message" class="form-label">Message</label>
          <textarea
            id="message"
            name="message"
            class="form-textarea"
            placeholder="How can we help?"
            required></textarea>
        </div>

        <div
          id="form-status"
          class="form-status-message"
          role="status"
          aria-live="polite"
        >
          Contact form is currently unavailable. Please use social links to get
          in touch.
        </div>

        <button type="submit" class="form-submit cta-button-primary">
          Send Message
        </button>
      </form>

      <script is:inline>
        const form = document.getElementById('contact-form');
        const status = document.getElementById('form-status');

        if (form && status) {
          form.addEventListener('submit', (e) => {
            e.preventDefault();
            status.classList.add('is-visible');
            // Optional: reset form fields to feel more interactive
            form.reset();
          });
        }
      </script>
    </div>

  </main>
</Layout>

<style>
  .form-status-message {
    display: none;
    padding: 1rem;
    margin-bottom: 1.5rem;
    background: rgba(204, 0, 0, 0.1);
    border: 1px solid var(--color-accent);
    color: var(--color-white);
    font-size: 0.85rem;
    text-align: center;
    animation: fadeIn 0.3s ease;
  }

  .form-status-message.is-visible {
    display: block;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-5px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
