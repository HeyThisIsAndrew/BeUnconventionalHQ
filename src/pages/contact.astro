---
import Layout from '../layouts/Layout.astro';
import Socials from '../components/Socials.astro';
import { site } from '../data/site.js';

const channels = [
  {
    title: 'Business & collabs',
    body: 'Partnerships, press access, and sponsorship inquiries.',
    cta: 'Message on Instagram',
    href: site.socials.instagram,
  },
  {
    title: 'Join the community',
    body: 'Get every new review and reaction the moment it drops.',
    cta: 'Subscribe on Substack',
    href: site.socials.substack,
  },
  {
    title: 'Watch & subscribe',
    body: 'The full video archive lives on the channel.',
    cta: 'Open YouTube',
    href: site.socials.youtube,
  },
];
---

<Layout
  title="Contact"
  description="Get in touch with Be Unconventional HQ for collaborations, press, and community."
>
  <header class="page-head container">
    <p class="eyebrow">Say hello</p>
    <h1 class="heading">Get in touch</h1>
    <p class="lead">
      Working on something unconventional? We'd love to hear about it.
    </p>
  </header>

  <section class="container section" style="padding-top:0">
    <div class="channels">
      {
        channels.map((c, i) => (
          <a
            class="channel reveal"
            href={c.href}
            target="_blank"
            rel="noopener"
            data-delay={i * 80}
          >
            <h2 class="channel-title">{c.title}</h2>
            <p class="channel-body">{c.body}</p>
            <span class="channel-cta">{c.cta} →</span>
          </a>
        ))
      }
    </div>

    <div class="contact-socials reveal">
      <p class="eyebrow">Or find us everywhere</p>
      <Socials />
    </div>
  </section>
</Layout>

<style>
  .channels {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 270px), 1fr));
    gap: clamp(1rem, 2vw, 1.5rem);
  }
  .channel {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.75rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg-1);
    transition:
      transform 0.3s ease,
      border-color 0.3s ease;
  }
  .channel:hover {
    transform: translateY(-6px);
    border-color: var(--accent);
  }
  .channel-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.2rem;
  }
  .channel-body {
    color: var(--text-2);
    font-size: 0.92rem;
    flex: 1;
  }
  .channel-cta {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--accent-ink);
  }
  .contact-socials {
    margin-top: clamp(2.5rem, 5vw, 4rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.1rem;
    text-align: center;
  }
</style>
