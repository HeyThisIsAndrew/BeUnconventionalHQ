---
import Layout from '../../layouts/Layout.astro';
import { sanityClient } from "sanity:client";
import { getVideos, getArticles } from '../../data/feeds.js';
import EventBookingCTA from '../../components/EventBookingCTA.astro';

export async function getStaticPaths() {
  // Project image asset dimensions so we can reserve the logo's box and avoid CLS.
  const query = `*[_type == "event"]{
    ...,
    logo{ ..., "dimensions": asset->metadata.dimensions },
    heroImage{ ..., "dimensions": asset->metadata.dimensions }
  }`;
  const events = await sanityClient.fetch(query);
  
  return events.map((event: any) => ({
    params: { slug: event.slug.current },
    props: { event },
  }));
}

const { event } = Astro.props;

import { createImageUrlBuilder } from "@sanity/image-url";
const builder = createImageUrlBuilder(sanityClient);
function urlFor(source: any) {
  return builder.image(source);
}

// 1. Fetch Global Data
const allVideos = await getVideos();
const allArticles = await getArticles();

// 2. Filter Global Data against Sanity Event Tags
const eventTags = event.tags || [];

const filteredVideos = allVideos.filter((v: any) => {
  // TEMPORARY TEST: Display all videos categorized as "Events" for SDCC 2026 
  // so the user can see the layout while the tagging system is configured
  if (event.slug?.current === 'sdcc-2026' || event.slug?.current === 'san-diego-comic-con-2026') {
    return v.category === 'Events';
  }

  // If the video title or description contains ANY of the exact tags
  return eventTags.some((tag: string) => 
    v.title?.toLowerCase().includes(tag.toLowerCase()) || 
    v.description?.toLowerCase().includes(tag.toLowerCase())
  );
});

const filteredArticles = allArticles.filter((a: any) => {
  return eventTags.some((tag: string) => 
    a.title?.toLowerCase().includes(tag.toLowerCase()) || 
    a.excerpt?.toLowerCase().includes(tag.toLowerCase())
  );
});

// Merge and sort all content
const unifiedContent = [
  ...filteredVideos.map((v: any) => ({ ...v, contentType: 'video' })),
  ...filteredArticles.map((a: any) => ({ ...a, contentType: 'article' }))
].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

// Format date range. All getters/formatters are pinned to UTC so a datetime
// stored as midnight UTC ("2026-07-23") never shifts back a day for viewers
// west of UTC (i.e. all of the Americas).
function formatDateRange(start: string, end?: string) {
  const fmtMonth = (d: Date) => d.toLocaleString('en-US', { timeZone: 'UTC', month: 'short' });
  const startDate = new Date(start);
  const sMonth = fmtMonth(startDate);
  const sDay = startDate.getUTCDate();
  const sYear = startDate.getUTCFullYear();

  if (!end) return `${sMonth} ${sDay}, ${sYear}`;

  const endDate = new Date(end);
  const eMonth = fmtMonth(endDate);
  const eDay = endDate.getUTCDate();
  const eYear = endDate.getUTCFullYear();

  if (sMonth === eMonth && sYear === eYear) {
    return `${sMonth} ${sDay} - ${eDay}, ${sYear}`;
  }
  return `${sMonth} ${sDay}, ${sYear} - ${eMonth} ${eDay}, ${eYear}`;
}

// Safe YouTube ID extraction for feed items — a null/broken link returns null
// instead of throwing (a bad URL used to crash the whole static build).
function getVideoId(link: string | undefined | null): string | null {
  if (!link || typeof link !== 'string') return null;
  try {
    if (link.includes('shorts')) {
      const id = link.split('/').filter(Boolean).pop();
      return id || null;
    }
    return new URL(link).searchParams.get('v');
  } catch {
    return null;
  }
}

const brandColor = event.brandColor || 'var(--color-accent, #cc0000)';
// Cap the hero at 2400px wide (retina-safe for a full-bleed banner) instead of
// serving the raw upload, and let Sanity pick the best format.
const heroUrl = event.heroImage
  ? urlFor(event.heroImage).width(2400).auto('format').url()
  : '';
const fallbackGradient = `linear-gradient(135deg, ${brandColor} 0%, #111 100%)`;

// Poster shown over the paused trailer on load, so the hero never renders a
// black iframe on iOS Safari. Prefer a 16:9 crop of the hero image; fall back
// to the logo centred on a dark panel.
const trailerPoster = event.heroImage
  ? { url: urlFor(event.heroImage).width(1200).height(675).fit('crop').auto('format').url(), kind: 'hero' }
  : event.logo
    ? { url: urlFor(event.logo).width(800).auto('format').url(), kind: 'logo' }
    : null;

const trailerUrl = event.trailerUrl;
function getYoutubeId(url) {
  if (!url) return null;
  const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:embed\/|v\/|watch\?v=|watch\?.+&v=))([^&?]+)/);
  return match ? match[1] : null;
}
const trailerId = getYoutubeId(trailerUrl);
---

<Layout title={`${event.title}`} description={`Complete coverage of ${event.title}`}>
  <main class="event-dashboard" style={`--brand-color: ${brandColor};`}>
    
    {/* Cinematic Hero */}
    <section class="event-hero">
      <div class="event-hero-bg" style={heroUrl ? `background-image: url('${heroUrl}');` : `background-image: ${fallbackGradient};`}></div>
      <div class="event-hero-overlay">
        <div
          class:list={[
            'container',
            'hero-grid-container',
            { 'has-trailer': !!trailerId, 'has-cta': !!event.signUpLink },
          ]}
        >
          <div class="event-hero-content hero-copy animate-on-scroll">
            {event.logo && (
              <img
                src={urlFor(event.logo).height(240).url()}
                alt={`${event.title} logo`}
                class="hero-logo"
                height="240"
                width={event.logo?.dimensions?.aspectRatio
                  ? Math.round(240 * event.logo.dimensions.aspectRatio)
                  : undefined}
              />
            )}
            <h1 class="hero-title">{event.title}</h1>
            <p class="hero-meta">
              <span class="event-dates">{formatDateRange(event.startDate, event.endDate)}</span>
              {event.location && <span class="event-location"> • {event.location}</span>}
            </p>
            {event.description && (
              <div class="hero-description-wrapper">
                <p class="hero-description-text" id="event-about-text">{event.description}</p>
                <button class="hero-read-more" id="event-about-toggle" aria-expanded="false" hidden>
                  Read more
                </button>
              </div>
            )}
          </div>
          
          {trailerId && (
            <div class="hero-trailer animate-on-scroll" style="animation-delay: 0.2s;">
              {/* Iframe is rendered up front (muted autoplay — allowed inline on
                  iOS) so the player is already initialised. The poster covers it
                  until playback actually starts, then fades; tapping the poster
                  starts/unmutes the ALREADY-LOADED player within the gesture,
                  which is what iOS honours. No overflow:hidden ancestor, so the
                  iframe renders instead of going black. */}
              <div class="trailer-wrapper" id="trailer-wrapper">
                <iframe
                  id="hero-trailer-iframe"
                  src={`https://www.youtube.com/embed/${trailerId}?autoplay=1&mute=1&loop=1&playlist=${trailerId}&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1&enablejsapi=1`}
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  title={`${event.title} trailer`}
                ></iframe>

                <button
                  type="button"
                  class="trailer-poster-overlay"
                  id="trailer-poster"
                  aria-label={`Play ${event.title} trailer`}
                >
                  {trailerPoster && (
                    <span
                      class="trailer-poster-img"
                      data-kind={trailerPoster.kind}
                      style={`background-image: url('${trailerPoster.url}');`}
                    ></span>
                  )}
                  <span class="trailer-play-btn" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </span>
                </button>

                <button
                  type="button"
                  class="trailer-sound-toggle is-muted"
                  id="trailer-sound-toggle"
                  aria-label="Unmute trailer"
                  aria-pressed="false"
                >
                  <svg class="icon-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M11 5 6 9H2v6h4l5 4z" />
                    <line x1="22" y1="9" x2="16" y2="15" />
                    <line x1="16" y1="9" x2="22" y2="15" />
                  </svg>
                  <svg class="icon-unmuted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M11 5 6 9H2v6h4l5 4z" />
                    <path d="M15.54 8.46a5 5 0 0 1 0 7.07" />
                    <path d="M19.07 4.93a10 10 0 0 1 0 14.14" />
                  </svg>
                </button>
              </div>
            </div>
          )}

          {/* Placed after the trailer in the DOM so mobile stacks copy →
              trailer → button; grid-areas restore the desktop layout. */}
          {event.signUpLink && (
            <div class="hero-cta">
              <a href={event.signUpLink} target="_blank" rel="noopener noreferrer" class="hero-rsvp-btn">
                Event Details
              </a>
            </div>
          )}
        </div>
      </div>
    </section>

    <div class="container content-container">
      {unifiedContent.length > 0 ? (
        <section class="content-section">
          <h2 class="sr-only">Event coverage</h2>

          <div class="filter-controls animate-on-scroll">
            <button class="filter-btn type-btn" data-filter="video" aria-pressed="false">VIDEOS</button>
            <button class="filter-btn type-btn" data-filter="article" aria-pressed="false">ARTICLES</button>
          </div>

          <div class="mixed-grid" aria-live="polite">
            {unifiedContent.map((item, index) => {
              if (item.contentType === 'video') {
                const videoId = getVideoId(item.link);
                return (
                  <div
                    class:list={['content-card', 'video-card', 'animate-on-scroll', { 'video-modal-trigger': !!videoId }]}
                    data-type="video"
                    data-video-id={videoId || undefined}
                    role={videoId ? 'button' : undefined}
                    tabindex={videoId ? '0' : undefined}
                    aria-label={videoId ? `Play video: ${item.title}` : undefined}
                    style={`--index: ${index}; cursor: ${videoId ? 'pointer' : 'default'};`}
                  >
                    <div class="thumbnail-wrapper">
                      <img src={item.thumbnail} alt={item.title} loading="lazy" class="thumbnail" onerror="this.onerror=null;this.src=this.src.replace('maxresdefault','hqdefault')" />
                      <div class="video-play-overlay">
                        <div class="play-icon">
                          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
                        </div>
                      </div>
                    </div>
                    <div class="card-info">
                      <span class="content-type-subtle">VIDEO • {item.date}</span>
                      <h3 class="card-title">{item.title}</h3>
                    </div>
                  </div>
                );
              } else {
                return (
                  <a href={item.link} target="_blank" rel="noopener noreferrer" class="content-card article-card animate-on-scroll" data-type="article" style={`--index: ${index};`}>
                    {item.image && (
                      <div class="thumbnail-wrapper">
                        <img src={item.image} alt={item.title} loading="lazy" class="thumbnail" />
                      </div>
                    )}
                    <div class="card-info">
                      <span class="content-type-subtle">ARTICLE • {item.date}</span>
                      <h3 class="card-title">{item.title}</h3>
                      {item.excerpt && <p class="card-excerpt">{item.excerpt}</p>}
                    </div>
                  </a>
                );
              }
            })}
          </div>
        </section>
      ) : (
        <div class="empty-state animate-on-scroll">
          <p>Coverage for this event is coming soon.</p>
        </div>
      )}
    </div>
    
    <EventBookingCTA />

  </main>
</Layout>

<style>
  .event-dashboard {
    background: #000;
    min-height: 100vh;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  
  /* Hero */
  .event-hero {
    position: relative;
    background-color: #111;
    /* NO overflow:hidden here. On iOS Safari an overflow:hidden ancestor makes
       a descendant cross-origin (YouTube) iframe render as a black box. The bg
       below is inset:0 and its image clips to its own box, so it can't spill —
       the clip was never needed. */
  }
  .event-hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    /* Cover the whole hero (behind the copy AND the trailer). It re-crops when
       the description expands — an accepted trade for full coverage. */
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    z-index: 0;
  }
  /* In normal flow (not absolute) so the banner GROWS with its content instead
     of overflowing upward under the fixed navbar. padding-top clears the navbar
     so the logo is never clipped. */
  .event-hero-overlay {
    position: relative;
    z-index: 1;
    min-height: 70vh;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.97) 0%,
      rgba(0, 0, 0, 0.55) 55%,
      rgba(0, 0, 0, 0.35) 100%
    );
    /* Subtle blur of the background image behind the overlay (content is a child,
       so it stays sharp) — softens the busy hero art for title legibility. */
    -webkit-backdrop-filter: blur(3px);
    backdrop-filter: blur(3px);
    display: flex;
    align-items: center;
    padding-top: clamp(6rem, 4.5rem + 6vw, 8.5rem);
    padding-bottom: clamp(2.5rem, 2rem + 2.5vw, 4rem);
  }

  /* Mobile: single column. Source order is copy → trailer → button, so the
     trailer sits above the Event Details button. */
  .hero-grid-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
    width: 100%;
  }
  .hero-cta {
    text-align: center;
  }

  /* Desktop: two columns. grid-areas keep copy + button stacked on the left
     with the trailer spanning both rows on the right. */
  @media (min-width: 900px) {
    /* .has-trailer / .has-cta are applied at build time — no reliance on :has()
       (which older Firefox lacks). Single-row areas when there's no CTA so the
       copy isn't squeezed by an empty grid row. */
    .hero-grid-container.has-trailer {
      grid-template-columns: 1fr 1fr;
      grid-template-areas: 'copy trailer';
      align-items: center;
    }
    .hero-grid-container.has-trailer.has-cta {
      grid-template-areas:
        'copy trailer'
        'cta trailer';
    }
    .hero-grid-container.has-trailer .hero-copy {
      grid-area: copy;
    }
    .hero-grid-container.has-trailer .hero-trailer {
      grid-area: trailer;
    }
    .hero-grid-container.has-trailer .hero-cta {
      grid-area: cta;
      align-self: start;
    }
    .hero-cta {
      text-align: left;
    }
  }

  .event-hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 900px;
  }
  
  .hero-trailer {
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    aspect-ratio: 16/9;
    /* Removed border-radius, overflow:hidden, and box-shadow to prevent the known 
       iOS Safari WebKit bug that causes cross-origin iframes to render as a black box */
  }
  .trailer-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    /* Solid base so there's no flash before the injected iframe paints. No
       border-radius/overflow here — that reintroduces the iOS Safari clipping
       bug that renders cross-origin video iframes black. */
    background: #000;
  }
  .trailer-wrapper iframe {
    width: 100%;
    height: 100%;
    /* Removed object-fit: cover; as it causes iOS Safari to render the iframe as a black tile */
  }

  /* Unmute / mute toggle overlaid on the trailer. */
  .trailer-sound-toggle {
    position: absolute;
    bottom: 0.85rem;
    right: 0.85rem;
    z-index: 3;
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.25);
    background: rgba(0, 0, 0, 0.55);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    color: #fff;
    cursor: pointer;
    transition: background 0.25s ease, border-color 0.25s ease, transform 0.2s ease;
  }
  /* An explicit display above beats the [hidden] UA rule, so restore it. */
  .trailer-sound-toggle[hidden] {
    display: none;
  }
  .trailer-sound-toggle:hover,
  .trailer-sound-toggle:focus-visible {
    background: var(--color-accent, #cc0000);
    border-color: var(--color-accent, #cc0000);
    transform: scale(1.06);
    outline: none;
  }
  .trailer-sound-toggle svg {
    width: 20px;
    height: 20px;
    display: block;
  }
  /* Muted state (default) shows the muted icon; unmuted swaps to sound waves. */
  .trailer-sound-toggle .icon-unmuted {
    display: none;
  }
  .trailer-sound-toggle.is-unmuted .icon-muted {
    display: none;
  }
  .trailer-sound-toggle.is-unmuted .icon-unmuted {
    display: block;
  }

  /* Poster overlay covering the iframe until the user taps play. */
  .trailer-poster-overlay {
    position: absolute;
    inset: 0;
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: none;
    background: #000;
    cursor: pointer;
    transition: opacity 0.4s ease;
  }
  .trailer-poster-overlay.is-hidden {
    opacity: 0;
    pointer-events: none;
  }
  @media (min-width: 900px) {
    .trailer-poster-overlay {
      display: none !important;
    }
  }
  .trailer-poster-img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  /* Logo fallback: contain + inset on a dark panel instead of a cover crop. */
  .trailer-poster-img[data-kind='logo'] {
    background-size: contain;
    background-origin: content-box;
    background-color: #0a0a0a;
    padding: 14%;
  }
  /* Scrim so the play button reads over bright artwork. */
  .trailer-poster-overlay::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    transition: background 0.3s ease;
  }
  .trailer-poster-overlay:hover::after,
  .trailer-poster-overlay:focus-visible::after {
    background: rgba(0, 0, 0, 0.2);
  }
  .trailer-play-btn {
    position: relative;
    z-index: 1;
    width: 72px;
    height: 72px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-accent, #cc0000);
    color: #fff;
    box-shadow: 0 8px 30px rgba(204, 0, 0, 0.5);
    transition: transform 0.2s ease;
  }
  .trailer-poster-overlay:hover .trailer-play-btn,
  .trailer-poster-overlay:focus-visible .trailer-play-btn {
    transform: scale(1.08);
  }
  .trailer-poster-overlay:focus-visible {
    outline: 2px solid var(--color-accent, #cc0000);
    outline-offset: 3px;
  }
  .trailer-play-btn svg {
    width: 30px;
    height: 30px;
    margin-left: 3px; /* optical centring of the triangle */
  }
  
  .hero-logo {
    /* Responsive + width-capped so wide logos (e.g. Comic-Con) never overflow
       the column or force the banner taller than the viewport on mobile. */
    max-height: clamp(84px, 46px + 12vw, 180px);
    max-width: min(100%, 420px);
    width: auto;
    height: auto;
    object-fit: contain;
    margin-bottom: 1.5rem;
    /* Removed filter: drop-shadow due to known iOS Safari rendering bugs 
       causing the image to completely fail to load/display as broken on mobile */
  }
  .hero-title {
    font-family: var(--font-display, 'Inter', sans-serif);
    font-size: clamp(1.9rem, calc(1.1rem + 3vw), 3.75rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 0.95;
    text-transform: uppercase;
    color: var(--color-white, #f0f0f0);
    text-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
    margin: 0 0 1rem 0;
  }
  .hero-meta {
    font-size: clamp(0.9rem, 0.8rem + 0.6vw, 1.25rem);
    color: #ccc;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .event-dates, .event-location {
    display: inline-block;
  }

  .hero-description-text {
    /* Font size is identical in every state so toggling never resizes the text.
       Collapsed height is 3em (2 lines at line-height 1.5); JS animates the
       inline max-height between this and the measured full height, so there's no
       arbitrary 800px value and no invisible portion of the transition. */
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.5;
    max-width: 600px;
    margin-top: 1.5rem;
    font-weight: 400;
    overflow: hidden;
    max-height: 3em;
    transition: max-height 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .hero-read-more {
    background: none;
    border: none;
    color: var(--color-accent, #cc0000);
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 0;
    margin-top: 0.5rem;
    cursor: pointer;
    text-decoration: underline;
  }
  .hero-read-more:hover {
    color: white;
  }

  .hero-rsvp-btn {
    display: inline-block;
    background: transparent;
    color: white;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0.75rem 2rem;
    border: 1px solid var(--color-accent, #cc0000);
    text-transform: uppercase;
    letter-spacing: 2px;
    transition: background 0.3s ease, color 0.3s ease;
  }
  .hero-rsvp-btn:hover {
    background: var(--color-accent, #cc0000);
    color: white;
  }

  /* Mobile: single column with no trailer — centre the lockup for balance.
     align-items centres the logo (a flex item); text-align centres the copy. */
  @media (max-width: 899px) {
    .event-hero-content {
      align-items: flex-start;
      text-align: left;
    }
    /* Font size stays 1rem (matching the base) so expand/collapse never resizes
       the text; only the top margin tightens on mobile. */
    .hero-description-text {
      margin-top: 1rem;
    }
  }

  /* Content */
  .content-container {
    padding: 4rem 2rem;
  }
  .content-section {
    margin-bottom: 5rem;
  }
  
  /* Filter Controls */
  .filter-controls {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    max-width: 600px;
    margin: 0 auto 3rem auto;
  }
  .filter-btn {
    padding: 1.25rem 1rem;
    background: rgba(10, 10, 10, 0.6);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    color: var(--color-white, #fff);
    font-size: 1.1rem;
    font-weight: 700;
    font-family: var(--font-display, 'Inter', sans-serif);
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    outline: none;
    -webkit-tap-highlight-color: transparent;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  @media (hover: hover) {
    .filter-btn:hover,
    .filter-btn:focus-visible {
      background: rgba(239, 68, 68, 0.1);
      border: 2px solid var(--color-accent, #ef4444);
      box-shadow: 0 0 15px rgba(239, 68, 68, 0.5);
      transform: translateY(-2px);
    }
  }

  .filter-btn.active {
    background: rgba(239, 68, 68, 0.1);
    border: 2px solid var(--color-accent, #ef4444);
    color: white;
    box-shadow: 0 0 20px rgba(239, 68, 68, 0.6);
  }
  
  /* Mixed Grid */
  .mixed-grid {
    display: grid;
    /* min(100%, 320px) lets a single card shrink below 320px on narrow phones
       instead of overflowing the padded container. */
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    gap: 2rem;
  }
  
  .content-card {
    background: #111;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: white;
    transition: transform 0.2s ease, border-color 0.2s ease;
    border: 1px solid rgba(255,255,255,0.1);
    display: flex;
    flex-direction: column;
  }
  .content-card:hover {
    transform: translateY(-5px);
    border-color: var(--brand-color);
  }
  
  .thumbnail-wrapper {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
  }
  .thumbnail {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .content-card:hover .thumbnail {
    transform: scale(1.05);
  }
  
  .content-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: rgba(0,0,0,0.8);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    z-index: 10;
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255,255,255,0.1);
  }
  
  /* Video Specific */
  .video-play-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 5;
  }
  .content-card:hover .video-play-overlay,
  .content-card:focus-visible .video-play-overlay {
    opacity: 1;
  }
  .content-card:focus-visible {
    outline: 2px solid var(--brand-color, #cc0000);
    outline-offset: 3px;
  }
  .play-icon {
    width: 60px;
    height: 60px;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(4px);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    border: 2px solid rgba(255,255,255,0.5);
    transition: transform 0.3s ease, background 0.3s ease;
  }
  .content-card:hover .play-icon {
    transform: scale(1.1);
    background: var(--brand-color);
    border-color: var(--brand-color);
  }
  
  .card-info {
    padding: 1.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }
  .card-date {
    font-size: 0.8rem;
    color: var(--brand-color);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
    font-weight: 700;
  }
  .card-title {
    font-size: 1.25rem;
    margin: 0;
    line-height: 1.4;
  }
  .card-excerpt {
    color: #a0a0a0;
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0.75rem 0 0 0;
    flex-grow: 1;
  }
  
  .empty-state {
    text-align: center;
    padding: 4rem;
    color: #a0a0a0;
    font-size: 1.2rem;
  }

  /* Visually hidden but exposed to assistive tech (used for the section <h2>
     that restores the heading hierarchy between the hero <h1> and card <h3>s). */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  // astro:page-load fires on the initial load AND after every View Transition
  // navigation, so the filters keep working after client-side nav.
  function initEventInteractions() {
    const filterBtns = Array.from(document.querySelectorAll('.filter-btn'));
    const contentCards = Array.from(document.querySelectorAll('.content-card'));

    filterBtns.forEach((btn) => {
      if (btn.dataset.bound === 'true') return;
      btn.dataset.bound = 'true';
      btn.addEventListener('click', () => {
        const wasActive = btn.classList.contains('active');
        filterBtns.forEach((b) => {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
        });

        let activeFilter = 'all';
        if (!wasActive) {
          btn.classList.add('active');
          btn.setAttribute('aria-pressed', 'true');
          activeFilter = btn.getAttribute('data-filter');
        }

        contentCards.forEach((card) => {
          const show = activeFilter === 'all' || card.getAttribute('data-type') === activeFilter;
          card.style.display = show ? 'flex' : 'none';
        });
      });
    });

    // Keyboard activation for video cards exposed as role="button".
    document.querySelectorAll('.video-modal-trigger').forEach((card) => {
      if (card.dataset.keybound === 'true') return;
      card.dataset.keybound = 'true';
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          card.click();
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initEventInteractions);
</script>

<script>
  // Hero trailer. The iframe is rendered up front with muted autoplay (allowed
  // inline on iOS), so the player is already initialised. The poster covers it
  // until the player reports it is actually PLAYING, then fades. Tapping the
  // poster starts/unmutes the already-loaded player from within the gesture —
  // the reliable path on iOS, since there is no async iframe load to expire the
  // user activation. Commands use the postMessage API (enablejsapi=1), CSP-safe.
  function initTrailer() {
    const iframe = document.getElementById('hero-trailer-iframe');
    if (!iframe) return;
    const poster = document.getElementById('trailer-poster');
    const soundBtn = document.getElementById('trailer-sound-toggle');

    let ready = false;
    let posterHidden = false;
    const queue = [];
    let muted = true;

    const post = (payload) =>
      iframe.contentWindow &&
      iframe.contentWindow.postMessage(JSON.stringify(payload), 'https://www.youtube.com');
    const command = (func, args = []) => {
      const payload = { event: 'command', func, args };
      if (ready) post(payload);
      else queue.push(payload);
    };
    const setMuted = (m) => {
      muted = m;
      if (!soundBtn) return;
      soundBtn.classList.toggle('is-muted', m);
      soundBtn.classList.toggle('is-unmuted', !m);
      soundBtn.setAttribute('aria-pressed', String(!m));
      soundBtn.setAttribute('aria-label', m ? 'Unmute trailer' : 'Mute trailer');
    };
    const hidePoster = () => {
      if (posterHidden || !poster) return;
      posterHidden = true;
      poster.classList.add('is-hidden');
    };

    const startListening = () =>
      post({ event: 'listening', id: iframe.id, channel: 'widget' });

    const onMessage = (e) => {
      if (!iframe.contentWindow || e.source !== iframe.contentWindow) return;
      let data;
      try {
        data = typeof e.data === 'string' ? JSON.parse(e.data) : e.data;
      } catch {
        return;
      }
      if (!data) return;
      if ((data.event === 'onReady' || data.event === 'initialDelivery') && !ready) {
        ready = true;
        queue.splice(0).forEach(post);
      }
      // playerState 1 = playing. Reveal the video (hide poster) only once it is
      // truly playing, so a stalled autoplay leaves the poster/play button up.
      const state =
        data.info && typeof data.info.playerState === 'number'
          ? data.info.playerState
          : data.event === 'onStateChange' && typeof data.info === 'number'
            ? data.info
            : undefined;
      if (state === 1) hidePoster();
      // Keep the toggle honest with the player's actual mute state.
      if (data.event === 'infoDelivery' && data.info && typeof data.info.muted === 'boolean') {
        if (data.info.muted !== muted) setMuted(data.info.muted);
      }
    };

    if (window.__ytTrailerMsg) window.removeEventListener('message', window.__ytTrailerMsg);
    window.__ytTrailerMsg = onMessage;
    window.addEventListener('message', onMessage);

    iframe.addEventListener('load', startListening);
    startListening(); // iframe is server-rendered and may already be loaded

    // Poster tap → play + unmute the already-initialised player, inside the tap.
    if (poster && poster.dataset.bound !== 'true') {
      poster.dataset.bound = 'true';
      poster.addEventListener('click', () => {
        command('playVideo');
        command('unMute');
        command('setVolume', [100]);
        setMuted(false);
        hidePoster();
      });
    }

    // Sound toggle after playback has started.
    if (soundBtn && soundBtn.dataset.bound !== 'true') {
      soundBtn.dataset.bound = 'true';
      soundBtn.addEventListener('click', () => {
        if (muted) {
          command('unMute');
          command('setVolume', [100]);
          command('playVideo');
          setMuted(false);
        } else {
          command('mute');
          setMuted(true);
        }
      });
    }
  }

  document.addEventListener('astro:page-load', initTrailer);
</script>

<script>
  // Expandable event blurb. max-height animates between the CSS collapsed value
  // (3em) and the measured full height, so the motion is smooth in both
  // directions with no arbitrary max-height and no snap at the end. Rapid
  // toggling is safe: each click retargets the same animated property and the
  // completion cleanup uses a single transitionend handler (no stray timeout).
  const COLLAPSED_MAX = '3em';

  function initEventAbout() {
    const text = document.getElementById('event-about-text');
    const toggle = document.getElementById('event-about-toggle');
    if (!text || !toggle) return;

    let expanded = false;
    let endHandler = null;
    const clearEnd = () => {
      if (endHandler) {
        text.removeEventListener('transitionend', endHandler);
        endHandler = null;
      }
    };

    // Toggle visibility depends on whether the (collapsed) text overflows. Skip
    // while expanded or mid-animation so a transient height can't hide it.
    const evaluate = () => {
      if (expanded) return;
      if (text.style.maxHeight && text.style.maxHeight.endsWith('px')) return;
      toggle.hidden = text.scrollHeight <= text.clientHeight + 2;
    };

    if (toggle.dataset.bound !== 'true') {
      toggle.dataset.bound = 'true';
      toggle.addEventListener('click', () => {
        clearEnd();
        if (!expanded) {
          expanded = true;
          text.style.maxHeight = text.scrollHeight + 'px';
          toggle.textContent = 'Read less';
          toggle.setAttribute('aria-expanded', 'true');
          endHandler = (e) => {
            if (e.propertyName !== 'max-height') return;
            text.style.maxHeight = 'none'; // let it reflow freely once open
            clearEnd();
          };
          text.addEventListener('transitionend', endHandler);
        } else {
          expanded = false;
          // Disable transition to pin the current full height instantly
          // without triggering a jump from 'none', then re-enable for the collapse.
          text.style.transition = 'none';
          text.style.maxHeight = text.getBoundingClientRect().height + 'px';
          void text.offsetHeight; // force reflow
          text.style.transition = '';
          requestAnimationFrame(() => {
            text.style.maxHeight = COLLAPSED_MAX;
          });
          toggle.textContent = 'Read more';
          toggle.setAttribute('aria-expanded', 'false');
        }
      });
    }

    // Evaluate after web fonts settle (wrong scrollHeight otherwise) and on any
    // resize/reflow of the text box.
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(evaluate);
    }
    evaluate();
    if (text.__ro) text.__ro.disconnect();
    const ro = new ResizeObserver(() => evaluate());
    ro.observe(text);
    text.__ro = ro;
  }

  document.addEventListener('astro:page-load', initEventAbout);
</script>
