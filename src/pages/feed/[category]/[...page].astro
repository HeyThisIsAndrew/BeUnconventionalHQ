---
import Layout from '../../../layouts/Layout.astro';
import PageTitle from '../../../components/PageTitle.astro';
import { site } from '../../../data/site.js';
import { getArticles } from '../../../data/feeds.js';
import { getVideosUnified } from '../../../lib/videos-source';
import QuadrantFilter from '../../../components/QuadrantFilter.astro';
import Pagination from '../../../components/Pagination.astro';
import { parseVideoId } from '../../../lib/platforms/youtube';
import { categories } from '../../../data/categories.js';
import type { GetStaticPathsOptions } from 'astro';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const articles = await getArticles();
  const videos = await getVideosUnified();

  return categories.flatMap((cat) => {
    const catLabel = cat.label.toLowerCase();
    
    function matchesCategory(item: any) {
      const itemTags = Array.isArray(item.tags) ? item.tags : [item.category || 'general'];
      return itemTags.some((t: any) => {
        const trimmed = typeof t === 'string' ? t.toLowerCase().trim() : '';
        if (trimmed === catLabel) return true;
        if (catLabel === 'events' && trimmed === 'event') return true;
        if (catLabel === 'event' && trimmed === 'events') return true;
        return false;
      });
    }

    const filteredItems = [
      ...articles.filter(matchesCategory).map((a: any) => ({ ...a, type: 'article' })),
      ...videos.filter(matchesCategory).map((v: any) => ({ ...v, type: 'video', image: v.thumbnail })),
    ].sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());

    return paginate(filteredItems, {
      params: { category: cat.slug },
      props: { categoryObj: cat },
      pageSize: 16,
    });
  });
}

const { page, categoryObj } = Astro.props;
const allItems = page.data;

const pageNum = page.currentPage > 1 ? ` - Page ${page.currentPage}` : '';
const title = `${categoryObj.label} Feed${pageNum} | ${site.name}`;
const description = `Explore all ${categoryObj.label} articles, videos, and events.`;
---

<Layout title={title} description={description} prevUrl={page.url.prev} nextUrl={page.url.next}>
  <main class="feed-page" style="min-height: 100vh;">
    <div class="container">
      <header class="section-header animate-on-scroll" data-nav-anchor>
        <PageTitle as="h1" kicker="Explore The HQ" primary="The" secondary="Feed" />
      </header>

      <QuadrantFilter showTypes={true} />

      <h2 class="sr-only">All {categoryObj.label} content</h2>
      <div class="articles-grid">
        {
          allItems.length > 0 ? (
            allItems.map((item: any, index: number) => {
              const isVideo = item.type === 'video';
              const videoId = isVideo ? parseVideoId(item.link) : null;

              const itemTags = Array.isArray(item.tags) ? item.tags : [item.category || 'General'];
              const lowerTags = itemTags.map((t: string) => typeof t === 'string' ? t.toLowerCase() : '');
              
              let primaryLabel = 'General';
              if (lowerTags.includes('tv')) primaryLabel = 'TV';
              else if (lowerTags.includes('film')) primaryLabel = 'Film';
              else if (lowerTags.includes('gaming')) primaryLabel = 'Gaming';
              else if (lowerTags.includes('event') || lowerTags.includes('events')) primaryLabel = 'Event';
              else primaryLabel = item.category || 'General';

              const CardWrapper = isVideo ? 'div' : 'a';
              const wrapperProps = isVideo
                ? {
                    class: 'article-card animate-on-scroll video-modal-trigger',
                    'data-video-id': videoId,
                    style: `--index: ${index}; text-decoration: none; cursor: pointer;`,
                  }
                : {
                    href: item.link || '#',
                    target: '_blank',
                    rel: 'noopener noreferrer',
                    class: 'article-card animate-on-scroll',
                    style: `--index: ${index}; text-decoration: none;`,
                  };

              const loadingStrategy = index < 6 ? 'eager' : 'lazy';

              return (
                <CardWrapper
                  {...wrapperProps}
                  data-type={(item.type || 'article').toLowerCase()}
                  data-category={lowerTags.join(',')}
                >
                  <div class="article-image-wrapper">
                    <img
                      src={item.image}
                      alt={item.title}
                      loading={loadingStrategy}
                      decoding="async"
                      class="article-image"
                    />
                    <span class="content-badge">
                      {primaryLabel.toUpperCase()}
                    </span>
                  </div>
                  <div class="article-content">
                    <span class="content-type-subtle">
                      {(item.type || 'ARTICLE').toUpperCase()} • {item.date}
                    </span>
                    <h3 class="article-title">{item.title}</h3>
                    <p class="article-excerpt">{item.excerpt}</p>
                    <span class="article-link">
                      {isVideo ? 'Watch Now →' : 'Explore →'}
                    </span>
                  </div>
                </CardWrapper>
              );
            })
          ) : (
             <div class="empty-state animate-on-scroll" style="grid-column: 1 / -1; text-align: center; padding: 4rem 0; opacity: 0.6;">
              <p>No items found for this category.</p>
            </div>
          )
        }
      </div>

      <Pagination page={page} />
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .feed-page {
    padding: 120px 0 2rem;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 260px), 1fr));
    gap: 3rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .feed-page {
      padding: 80px 0 2rem;
    }
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
