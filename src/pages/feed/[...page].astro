---
import Layout from '../../layouts/Layout.astro';
import PageTitle from '../../components/PageTitle.astro';
import { site } from '../../data/site.js';
import { getArticles } from '../../data/feeds.js';
import { getVideosUnified } from '../../lib/videos-source';
import QuadrantFilter from '../../components/QuadrantFilter.astro';
import Pagination from '../../components/Pagination.astro';
import ContentCard from '../../components/ContentCard.astro';
import type { GetStaticPathsOptions } from 'astro';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const articles = await getArticles();
  const videos = await getVideosUnified();

  const allItems = [
    ...articles.map((a: any) => ({ ...a, type: 'article' })),
    ...videos.map((v: any) => ({ ...v, type: 'video', image: v.thumbnail })),
  ].sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime());

  return paginate(allItems, { pageSize: 12 });
}

const { page } = Astro.props;
const allItems = page.data;

const pageNum = page.currentPage > 1 ? ` - Page ${page.currentPage}` : '';
const title = `All Content${pageNum} | ${site.name}`;
const description = 'Discover all articles, videos, and events from Be Unconventional HQ.';
---

<Layout title={title} description={description} prevUrl={page.url.prev} nextUrl={page.url.next}>
  <main class="feed-page flex-1 flex flex-col w-full pb-16 md:pb-24">
    <div class="container flex-1 flex flex-col">
      <header class="section-header animate-on-scroll" data-nav-anchor>
        <PageTitle as="h1" kicker="Explore The HQ" primary="The" secondary="Feed" />
      </header>

      <QuadrantFilter showTypes={true} isNavMode={true} />

      {/* Structural h2 so card h3s don't skip a heading level (axe: heading-order). */}
      <h2 class="sr-only">All content</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 w-full max-w-screen-2xl mx-auto px-4 md:px-8">
        {
          allItems.map((item: any, index: number) => (
            <ContentCard item={item} index={index} />
          ))
        }
      </div>

      <div class="mt-auto w-full max-w-screen-2xl mx-auto px-4 md:px-8">
        <Pagination page={page} />
      </div>
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1536px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .feed-page {
    padding: 120px 0 2rem;
  }

  @media (max-width: 768px) {
    .feed-page {
      padding: 80px 0 2rem;
    }
  }
</style>
