---
import Layout from '../layouts/Layout.astro';
import PageTitle from '../components/PageTitle.astro';
import { site } from '../data/site.js';
import { getArticles, getVideos } from '../data/feeds.js';
import QuadrantFilter from '../components/QuadrantFilter.astro';
import { parseVideoId } from '../lib/platforms/youtube';

const title = `All Content | ${site.name}`;
const description =
  'Discover all articles, videos, and events from Be Unconventional HQ.';

const articles = await getArticles();
const videos = await getVideos();

const allItems = [
  ...articles.map((a) => ({ ...a, type: 'article' })),
  ...videos.map((v) => ({ ...v, type: 'video', image: v.thumbnail })),
].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout title={title} description={description}>
  <main class="feed-page" style="min-height: 100vh;">
    <div class="container">
      <header class="section-header animate-on-scroll" data-nav-anchor>
        <PageTitle as="h1" kicker="Explore The HQ" primary="The" secondary="Feed" />
      </header>

      <QuadrantFilter showTypes={true} />

      <div class="articles-grid">
        {
          allItems.map((item, index) => {
            const isVideo = item.type === 'video';
            const videoId = parseVideoId(item.link);

            const CardWrapper = isVideo ? 'div' : 'a';
            const wrapperProps = isVideo
              ? {
                  class: 'article-card animate-on-scroll video-modal-trigger',
                  'data-video-id': videoId,
                  style: `--index: ${index}; text-decoration: none; cursor: pointer;`,
                }
              : {
                  href: item.link || '#',
                  target: '_blank',
                  rel: 'noopener noreferrer',
                  class: 'article-card animate-on-scroll',
                  style: `--index: ${index}; text-decoration: none;`,
                };

            return (
              <CardWrapper
                {...wrapperProps}
                data-type={(item.type || 'article').toLowerCase()}
                data-category={(item.category || 'General').toLowerCase()}
              >
                <div class="article-image-wrapper">
                  <img
                    src={item.image}
                    alt={item.title}
                    loading="lazy"
                    decoding="async"
                    class="article-image"
                  />
                  <span class="content-badge">
                    {(item.category || 'General').toUpperCase()}
                  </span>
                </div>
                <div class="article-content">
                  <span class="content-type-subtle">
                    {(item.type || 'ARTICLE').toUpperCase()} • {item.date}
                  </span>
                  <h3 class="article-title">{item.title}</h3>
                  <p class="article-excerpt">{item.excerpt}</p>
                  <span class="article-link">
                    {isVideo ? 'Watch Now →' : 'Explore →'}
                  </span>
                </div>
              </CardWrapper>
            );
          })
        }
      </div>
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .feed-page {
    padding: 120px 0;
    min-height: 80vh;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 3rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
    .filter-nav {
      align-items: center;
    }
  }
</style>
