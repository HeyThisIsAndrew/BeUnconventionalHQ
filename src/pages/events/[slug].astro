---
import Layout from '../../layouts/Layout.astro';
import { sanityClient } from "sanity:client";
import { getVideos, getArticles } from '../../data/feeds.js';
import EventBookingCTA from '../../components/EventBookingCTA.astro';

export async function getStaticPaths() {
  const query = `*[_type == "event"]`;
  const events = await sanityClient.fetch(query);
  
  return events.map((event: any) => ({
    params: { slug: event.slug.current },
    props: { event },
  }));
}

const { event } = Astro.props;

import { createImageUrlBuilder } from "@sanity/image-url";
const builder = createImageUrlBuilder(sanityClient);
function urlFor(source: any) {
  return builder.image(source);
}

// 1. Fetch Global Data
const allVideos = await getVideos();
const allArticles = await getArticles();

// 2. Filter Global Data against Sanity Event Tags
const eventTags = event.tags || [];

const filteredVideos = allVideos.filter((v: any) => {
  // TEMPORARY TEST: Display all videos categorized as "Events" for SDCC 2026 
  // so the user can see the layout while the tagging system is configured
  if (event.slug?.current === 'sdcc-2026' || event.slug?.current === 'san-diego-comic-con-2026') {
    return v.category === 'Events';
  }

  // If the video title or description contains ANY of the exact tags
  return eventTags.some((tag: string) => 
    v.title?.toLowerCase().includes(tag.toLowerCase()) || 
    v.description?.toLowerCase().includes(tag.toLowerCase())
  );
});

const filteredArticles = allArticles.filter((a: any) => {
  return eventTags.some((tag: string) => 
    a.title?.toLowerCase().includes(tag.toLowerCase()) || 
    a.excerpt?.toLowerCase().includes(tag.toLowerCase())
  );
});

// Merge and sort all content
const unifiedContent = [
  ...filteredVideos.map((v: any) => ({ ...v, contentType: 'video' })),
  ...filteredArticles.map((a: any) => ({ ...a, contentType: 'article' }))
].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

// Format date range
function formatDateRange(start, end) {
  const startDate = new Date(start);
  const startStr = startDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  if (!end) return startStr;
  
  const endDate = new Date(end);
  const endStr = endDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  
  if (startDate.getMonth() === endDate.getMonth() && startDate.getFullYear() === endDate.getFullYear()) {
    return `${startDate.toLocaleString('en-US', { month: 'short' })} ${startDate.getDate()} - ${endDate.getDate()}, ${startDate.getFullYear()}`;
  }
  return `${startStr} - ${endStr}`;
}

const brandColor = event.brandColor || 'var(--color-accent, #cc0000)';
// Cap the hero at 2400px wide (retina-safe for a full-bleed banner) instead of
// serving the raw upload, and let Sanity pick the best format.
const heroUrl = event.heroImage
  ? urlFor(event.heroImage).width(2400).auto('format').url()
  : '';
const fallbackGradient = `linear-gradient(135deg, ${brandColor} 0%, #111 100%)`;

// Poster shown over the paused trailer on load, so the hero never renders a
// black iframe on iOS Safari. Prefer a 16:9 crop of the hero image; fall back
// to the logo centred on a dark panel.
const trailerPoster = event.heroImage
  ? { url: urlFor(event.heroImage).width(1200).height(675).fit('crop').auto('format').url(), kind: 'hero' }
  : event.logo
    ? { url: urlFor(event.logo).width(800).auto('format').url(), kind: 'logo' }
    : null;

const trailerUrl = event.trailerUrl;
function getYoutubeId(url) {
  if (!url) return null;
  const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:embed\/|v\/|watch\?v=|watch\?.+&v=))([^&?]+)/);
  return match ? match[1] : null;
}
const trailerId = getYoutubeId(trailerUrl);
---

<Layout title={`${event.title}`} description={`Complete coverage of ${event.title}`}>
  <main class="event-dashboard" style={`--brand-color: ${brandColor};`}>
    
    {/* Cinematic Hero */}
    <section class="event-hero" style={heroUrl ? `background-image: url('${heroUrl}');` : `background: ${fallbackGradient};`}>
      <div class="event-hero-overlay">
        <div class="container hero-grid-container">
          <div class="event-hero-content hero-copy animate-on-scroll">
            {event.logo && (
              <img src={urlFor(event.logo).height(240).url()} alt={`${event.title} logo`} class="hero-logo" />
            )}
            <h1 class="hero-title">{event.title}</h1>
            <p class="hero-meta">
              <span class="event-dates">{formatDateRange(event.startDate, event.endDate)}</span>
              {event.location && <span class="event-location"> • {event.location}</span>}
            </p>
            {event.description && (
              <div class="hero-description-wrapper">
                <p class="hero-description-text" id="event-about-text">{event.description}</p>
                <button class="hero-read-more" id="event-about-toggle" aria-expanded="false" hidden>
                  Read more
                </button>
              </div>
            )}
          </div>
          
          {trailerId && (
            <div class="hero-trailer animate-on-scroll" style="animation-delay: 0.2s;">
              <div class="trailer-wrapper">
                <iframe
                  id="hero-trailer-iframe"
                  src={`https://www.youtube.com/embed/${trailerId}?autoplay=1&mute=1&loop=1&playlist=${trailerId}&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1&enablejsapi=1`}
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  title={`${event.title} trailer`}
                ></iframe>

                {/* Poster overlay: guarantees a branded image on load (never a
                    black iframe) and ties playback to an explicit user tap, which
                    iOS Safari always honours. */}
                {trailerPoster && (
                  <button
                    type="button"
                    class="trailer-poster-overlay"
                    id="trailer-poster"
                    aria-label={`Play ${event.title} trailer`}
                  >
                    <span
                      class="trailer-poster-img"
                      data-kind={trailerPoster.kind}
                      style={`background-image: url('${trailerPoster.url}');`}
                    ></span>
                    <span class="trailer-play-btn" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M8 5v14l11-7z" />
                      </svg>
                    </span>
                  </button>
                )}

                {/* Sound toggle for after playback starts (postMessage API,
                    enablejsapi=1 → no external script, CSP-safe). */}
                <button
                  type="button"
                  class="trailer-sound-toggle is-muted"
                  id="trailer-sound-toggle"
                  aria-label="Unmute trailer"
                  aria-pressed="false"
                >
                  <svg class="icon-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M11 5 6 9H2v6h4l5 4z" />
                    <line x1="22" y1="9" x2="16" y2="15" />
                    <line x1="16" y1="9" x2="22" y2="15" />
                  </svg>
                  <svg class="icon-unmuted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M11 5 6 9H2v6h4l5 4z" />
                    <path d="M15.54 8.46a5 5 0 0 1 0 7.07" />
                    <path d="M19.07 4.93a10 10 0 0 1 0 14.14" />
                  </svg>
                </button>
              </div>
            </div>
          )}

          {/* Placed after the trailer in the DOM so mobile stacks copy →
              trailer → button; grid-areas restore the desktop layout. */}
          {event.signUpLink && (
            <div class="hero-cta">
              <a href={event.signUpLink} target="_blank" rel="noopener noreferrer" class="hero-rsvp-btn">
                Event Details
              </a>
            </div>
          )}
        </div>
      </div>
    </section>

    <div class="container content-container">
      {unifiedContent.length > 0 ? (
        <section class="content-section">
          
          <div class="filter-controls animate-on-scroll">
            <button class="filter-btn type-btn" data-filter="video">VIDEOS</button>
            <button class="filter-btn type-btn" data-filter="article">ARTICLES</button>
          </div>

          <div class="mixed-grid">
            {unifiedContent.map((item, index) => {
              if (item.contentType === 'video') {
                const videoId = item.link.includes('shorts')
                  ? item.link.split('/').pop()
                  : new URL(item.link).searchParams.get('v');
                return (
                  <div class="content-card video-card animate-on-scroll video-modal-trigger" data-type="video" data-video-id={videoId} style={`--index: ${index}; cursor: pointer;`}>
                    <div class="thumbnail-wrapper">
                      <img src={item.thumbnail} alt={item.title} loading="lazy" class="thumbnail" onerror="this.onerror=null;this.src=this.src.replace('maxresdefault','hqdefault')" />
                      <div class="video-play-overlay">
                        <div class="play-icon">
                          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
                        </div>
                      </div>
                    </div>
                    <div class="card-info">
                      <span class="content-type-subtle">VIDEO • {item.date}</span>
                      <h3 class="card-title">{item.title}</h3>
                    </div>
                  </div>
                );
              } else {
                return (
                  <a href={item.link} target="_blank" rel="noopener noreferrer" class="content-card article-card animate-on-scroll" data-type="article" style={`--index: ${index};`}>
                    {item.image && (
                      <div class="thumbnail-wrapper">
                        <img src={item.image} alt={item.title} loading="lazy" class="thumbnail" />
                      </div>
                    )}
                    <div class="card-info">
                      <span class="content-type-subtle">ARTICLE • {item.date}</span>
                      <h3 class="card-title">{item.title}</h3>
                      {item.excerpt && <p class="card-excerpt">{item.excerpt}</p>}
                    </div>
                  </a>
                );
              }
            })}
          </div>
        </section>
      ) : (
        <div class="empty-state animate-on-scroll">
          <p>Coverage for this event is coming soon.</p>
        </div>
      )}
    </div>
    
    <EventBookingCTA />

  </main>
</Layout>

<style>
  .event-dashboard {
    background: #000;
    min-height: 100vh;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  
  /* Hero */
  .event-hero {
    position: relative;
    background-size: cover;
    background-position: center 30%;
    background-color: #111;
  }
  /* In normal flow (not absolute) so the banner GROWS with its content instead
     of overflowing upward under the fixed navbar. padding-top clears the navbar
     so the logo is never clipped. */
  .event-hero-overlay {
    min-height: 70vh;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.97) 0%,
      rgba(0, 0, 0, 0.55) 55%,
      rgba(0, 0, 0, 0.35) 100%
    );
    /* Subtle blur of the background image behind the overlay (content is a child,
       so it stays sharp) — softens the busy hero art for title legibility. */
    -webkit-backdrop-filter: blur(3px);
    backdrop-filter: blur(3px);
    display: flex;
    align-items: center;
    padding-top: clamp(6rem, 4.5rem + 6vw, 8.5rem);
    padding-bottom: clamp(2.5rem, 2rem + 2.5vw, 4rem);
  }

  /* Mobile: single column. Source order is copy → trailer → button, so the
     trailer sits above the Event Details button. */
  .hero-grid-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
    width: 100%;
  }
  .hero-cta {
    text-align: center;
  }

  /* Desktop: two columns. grid-areas keep copy + button stacked on the left
     with the trailer spanning both rows on the right. */
  @media (min-width: 900px) {
    .hero-grid-container:has(.hero-trailer) {
      grid-template-columns: 1fr 1fr;
      grid-template-areas:
        'copy trailer'
        'cta trailer';
    }
    .hero-grid-container:has(.hero-trailer) .hero-copy {
      grid-area: copy;
    }
    .hero-grid-container:has(.hero-trailer) .hero-trailer {
      grid-area: trailer;
    }
    .hero-grid-container:has(.hero-trailer) .hero-cta {
      grid-area: cta;
      align-self: start;
    }
    .hero-cta {
      text-align: left;
    }
  }

  .event-hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 900px;
  }
  
  .hero-trailer {
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    aspect-ratio: 16/9;
    /* Removed border-radius, overflow:hidden, and box-shadow to prevent the known 
       iOS Safari WebKit bug that causes cross-origin iframes to render as a black box */
  }
  .trailer-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .trailer-wrapper iframe {
    width: 100%;
    height: 100%;
    /* Removed object-fit: cover; as it causes iOS Safari to render the iframe as a black tile */
  }

  /* Unmute / mute toggle overlaid on the trailer. */
  .trailer-sound-toggle {
    position: absolute;
    bottom: 0.85rem;
    right: 0.85rem;
    z-index: 3;
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.25);
    background: rgba(0, 0, 0, 0.55);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    color: #fff;
    cursor: pointer;
    transition: background 0.25s ease, border-color 0.25s ease, transform 0.2s ease;
  }
  .trailer-sound-toggle:hover,
  .trailer-sound-toggle:focus-visible {
    background: var(--color-accent, #cc0000);
    border-color: var(--color-accent, #cc0000);
    transform: scale(1.06);
    outline: none;
  }
  .trailer-sound-toggle svg {
    width: 20px;
    height: 20px;
    display: block;
  }
  /* Muted state (default) shows the muted icon; unmuted swaps to sound waves. */
  .trailer-sound-toggle .icon-unmuted {
    display: none;
  }
  .trailer-sound-toggle.is-unmuted .icon-muted {
    display: none;
  }
  .trailer-sound-toggle.is-unmuted .icon-unmuted {
    display: block;
  }

  /* Poster overlay covering the iframe until the user taps play. */
  .trailer-poster-overlay {
    position: absolute;
    inset: 0;
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: none;
    background: #000;
    cursor: pointer;
    transition: opacity 0.4s ease;
  }
  .trailer-poster-overlay.is-hidden {
    opacity: 0;
    pointer-events: none;
  }
  @media (min-width: 900px) {
    .trailer-poster-overlay {
      display: none !important;
    }
  }
  .trailer-poster-img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  /* Logo fallback: contain + inset on a dark panel instead of a cover crop. */
  .trailer-poster-img[data-kind='logo'] {
    background-size: contain;
    background-origin: content-box;
    background-color: #0a0a0a;
    padding: 14%;
  }
  /* Scrim so the play button reads over bright artwork. */
  .trailer-poster-overlay::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    transition: background 0.3s ease;
  }
  .trailer-poster-overlay:hover::after,
  .trailer-poster-overlay:focus-visible::after {
    background: rgba(0, 0, 0, 0.2);
  }
  .trailer-play-btn {
    position: relative;
    z-index: 1;
    width: 72px;
    height: 72px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-accent, #cc0000);
    color: #fff;
    box-shadow: 0 8px 30px rgba(204, 0, 0, 0.5);
    transition: transform 0.2s ease;
  }
  .trailer-poster-overlay:hover .trailer-play-btn,
  .trailer-poster-overlay:focus-visible .trailer-play-btn {
    transform: scale(1.08);
  }
  .trailer-poster-overlay:focus-visible {
    outline: 2px solid var(--color-accent, #cc0000);
    outline-offset: 3px;
  }
  .trailer-play-btn svg {
    width: 30px;
    height: 30px;
    margin-left: 3px; /* optical centring of the triangle */
  }
  
  .hero-logo {
    /* Responsive + width-capped so wide logos (e.g. Comic-Con) never overflow
       the column or force the banner taller than the viewport on mobile. */
    max-height: clamp(84px, 46px + 12vw, 180px);
    max-width: min(100%, 420px);
    width: auto;
    height: auto;
    object-fit: contain;
    margin-bottom: 1.5rem;
    /* Removed filter: drop-shadow due to known iOS Safari rendering bugs 
       causing the image to completely fail to load/display as broken on mobile */
  }
  .hero-title {
    font-family: var(--font-display, 'Inter', sans-serif);
    font-size: clamp(1.9rem, calc(1.1rem + 3vw), 3.75rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 0.95;
    text-transform: uppercase;
    color: var(--color-white, #f0f0f0);
    text-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
    margin: 0 0 1rem 0;
  }
  .hero-meta {
    font-size: clamp(0.9rem, 0.8rem + 0.6vw, 1.25rem);
    color: #ccc;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .event-dates, .event-location {
    display: inline-block;
  }

  .hero-description-text {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.5;
    max-width: 600px;
    margin-top: 1.5rem;
    font-weight: 400;
  }
  .hero-description-text:not(.is-expanded) {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .hero-read-more {
    background: none;
    border: none;
    color: var(--color-accent, #cc0000);
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 0;
    margin-top: 0.5rem;
    cursor: pointer;
    text-decoration: underline;
  }
  .hero-read-more:hover {
    color: white;
  }

  .hero-rsvp-btn {
    display: inline-block;
    background: transparent;
    color: white;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0.75rem 2rem;
    border: 1px solid var(--color-accent, #cc0000);
    text-transform: uppercase;
    letter-spacing: 2px;
    transition: background 0.3s ease, color 0.3s ease;
  }
  .hero-rsvp-btn:hover {
    background: var(--color-accent, #cc0000);
    color: white;
  }

  /* Mobile: single column with no trailer — centre the lockup for balance.
     align-items centres the logo (a flex item); text-align centres the copy. */
  @media (max-width: 899px) {
    .event-hero-content {
      align-items: center;
      text-align: center;
    }
    
    .hero-description-text:not(.is-expanded) {
      -webkit-line-clamp: 1; /* 1 line on mobile */
      margin-top: 1rem;
      font-size: 1rem;
    }
  }

  /* Content */
  .content-container {
    padding: 4rem 2rem;
  }
  .content-section {
    margin-bottom: 5rem;
  }
  
  /* Filter Controls */
  .filter-controls {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    max-width: 600px;
    margin: 0 auto 3rem auto;
  }
  .filter-btn {
    padding: 1.25rem 1rem;
    background: rgba(10, 10, 10, 0.6);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    color: var(--color-white, #fff);
    font-size: 1.1rem;
    font-weight: 700;
    font-family: var(--font-display, 'Inter', sans-serif);
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    outline: none;
    -webkit-tap-highlight-color: transparent;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  @media (hover: hover) {
    .filter-btn:hover,
    .filter-btn:focus-visible {
      background: rgba(239, 68, 68, 0.1);
      border: 2px solid var(--color-accent, #ef4444);
      box-shadow: 0 0 15px rgba(239, 68, 68, 0.5);
      transform: translateY(-2px);
    }
  }

  .filter-btn.active {
    background: rgba(239, 68, 68, 0.1);
    border: 2px solid var(--color-accent, #ef4444);
    color: white;
    box-shadow: 0 0 20px rgba(239, 68, 68, 0.6);
  }
  
  /* Mixed Grid */
  .mixed-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }
  
  .content-card {
    background: #111;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: white;
    transition: transform 0.2s ease, border-color 0.2s ease;
    border: 1px solid rgba(255,255,255,0.1);
    display: flex;
    flex-direction: column;
  }
  .content-card:hover {
    transform: translateY(-5px);
    border-color: var(--brand-color);
  }
  
  .thumbnail-wrapper {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
  }
  .thumbnail {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .content-card:hover .thumbnail {
    transform: scale(1.05);
  }
  
  .content-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: rgba(0,0,0,0.8);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    z-index: 10;
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255,255,255,0.1);
  }
  
  /* Video Specific */
  .video-play-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 5;
  }
  .content-card:hover .video-play-overlay {
    opacity: 1;
  }
  .play-icon {
    width: 60px;
    height: 60px;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(4px);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    border: 2px solid rgba(255,255,255,0.5);
