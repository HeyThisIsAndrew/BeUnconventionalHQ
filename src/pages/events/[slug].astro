</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const contentCards = document.querySelectorAll('.content-card');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const wasActive = btn.classList.contains('active');
        
        // Remove active state from all buttons
        filterBtns.forEach(b => b.classList.remove('active'));

        let activeFilter = 'all';

        // Toggle logic: If it wasn't active, make it active. If it was active, it stays inactive (reverting to 'all')
        if (!wasActive) {
          btn.classList.add('active');
          activeFilter = btn.getAttribute('data-filter');
        }

        // Apply filter to cards
        contentCards.forEach(card => {
          if (activeFilter === 'all') {
            card.style.display = 'flex';
          } else {
            if (card.getAttribute('data-type') === activeFilter) {
              card.style.display = 'flex';
            } else {
              card.style.display = 'none';
            }
          }
        });
      });
    });
  });
</script>

<script>
  // Hero trailer. Playback is tied to an explicit tap on the poster overlay —
  // the only thing iOS Safari reliably honours — instead of forcing autoplay.
  // Commands go through YouTube's postMessage API (enablejsapi=1 on the embed),
  // so no external script loads and the site CSP is untouched.
  function initTrailer() {
    const iframe = document.getElementById('hero-trailer-iframe');
    if (!iframe) return;

    const command = (func, args = []) => {
      iframe.contentWindow?.postMessage(
        JSON.stringify({ event: 'command', func, args }),
        'https://www.youtube.com'
      );
    };

    let muted = true;
    const soundBtn = document.getElementById('trailer-sound-toggle');
    const setMuted = (m) => {
      muted = m;
      if (!soundBtn) return;
      soundBtn.classList.toggle('is-muted', m);
      soundBtn.classList.toggle('is-unmuted', !m);
      soundBtn.setAttribute('aria-pressed', String(!m));
      soundBtn.setAttribute('aria-label', m ? 'Unmute trailer' : 'Mute trailer');
    };

    // Poster tap → guaranteed playback with audio (fires inside the gesture).
    const poster = document.getElementById('trailer-poster');
    if (poster && poster.dataset.bound !== 'true') {
      poster.dataset.bound = 'true';
      poster.addEventListener('click', () => {
        command('playVideo');
        command('unMute');
        command('setVolume', [100]);
        setMuted(false);
        poster.classList.add('is-hidden');
      });
    }

    // Sound toggle for after playback has started.
    if (soundBtn && soundBtn.dataset.bound !== 'true') {
      soundBtn.dataset.bound = 'true';
      soundBtn.addEventListener('click', () => {
        if (muted) {
          command('unMute');
          command('setVolume', [100]);
          command('playVideo');
          setMuted(false);
        } else {
          command('mute');
          setMuted(true);
        }
      });
    }
  }

  document.addEventListener('astro:page-load', initTrailer);
</script>

<script>
  // Show the "Read more" toggle only when the blurb actually overflows its
  // 3-line clamp; otherwise the short description just displays in full.
  function initEventAbout() {
    const text = document.getElementById('event-about-text');
    const toggle = document.getElementById('event-about-toggle');
    if (!text || !toggle) return;

    const overflowing = text.scrollHeight > text.clientHeight + 2;
    if (!overflowing) {
      toggle.hidden = true;
      return;
    }
    toggle.hidden = false;
    if (toggle.dataset.bound === 'true') return;
    toggle.dataset.bound = 'true';

    toggle.addEventListener('click', () => {
      const expanded = text.classList.toggle('is-expanded');
      toggle.setAttribute('aria-expanded', String(expanded));
      toggle.textContent = expanded ? 'Read less' : 'Read more';
    });
  }

  document.addEventListener('astro:page-load', initEventAbout);
</script>
