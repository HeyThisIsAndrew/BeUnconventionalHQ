---
import Layout from '../../layouts/Layout.astro';
import { getArticles } from '../../data/feeds.js';
import { getVideosUnified, getShortsUnified, getLiveStreamsUnified } from '../../lib/videos-source';
import { getEventsLocal, urlFor } from '../../lib/local-content';
import SubscribeCTA from '../../components/SubscribeCTA.astro';
import HeroTrailer from '../../components/HeroTrailer.astro';
import { parseVideoId } from '../../lib/platforms/youtube';
import { formatEventDateRange, formatLocation } from '../../lib/events';
import EventStatusIndicator from '../../components/EventStatusIndicator.astro';
import ContentCard from '../../components/ContentCard.astro';

export async function getStaticPaths() {
  const events = getEventsLocal();
  return events.map((event: any) => ({
    params: { slug: event.slug?.current || 'unknown' },
    props: { event },
  }));
}

const { event } = Astro.props;

// 1. Fetch Global Data
const allVideos = await getVideosUnified();
const allArticles = getArticles();

// 1b. Phase C1 (epic #25): deterministic, editor-controlled coverage — videos
// whose hubs[] reference THIS event doc (by slug - see sync-youtube.mjs's
// taxonomy dictionary, which keys hub matches off event/featuredBrand slugs).
// Spans video/short/live (the original Sanity query's `_type in [...]`),
// unlike the `allVideos` fallback below which is video-only. Empty until
// editors/sync hub-tag published docs, in which case the tag-match fallback
// still runs, so behavior is unchanged until real data exists (same
// activation pattern as Phase B).
const [shortsForHubs, liveForHubs] = await Promise.all([getShortsUnified(), getLiveStreamsUnified()]);
const hubCoverage = [...allVideos, ...shortsForHubs, ...liveForHubs]
  .filter((v: any) => (v.hubs || []).includes(event.slug?.current))
  .sort((a: any, b: any) => new Date(b.publishedAt ?? 0).getTime() - new Date(a.publishedAt ?? 0).getTime());

// 2. Fallback: filter global data against hub tags (legacy heuristic; removed
const eventTags = (event.youtubeSyncKeywords || []).filter((t: any) => typeof t === 'string');

const filteredVideos = hubCoverage.length > 0 ? hubCoverage : allVideos.filter((v: any) => {


  // If the video title or description contains ANY of the exact tags
  return eventTags.some((tag: string) =>
    v.title?.toLowerCase().includes(tag.toLowerCase()) ||
    v.description?.toLowerCase().includes(tag.toLowerCase())
  );
});

const filteredArticles = allArticles.filter((a: any) => {
  return eventTags.some((tag: string) => 
    a.title?.toLowerCase().includes(tag.toLowerCase()) || 
    a.excerpt?.toLowerCase().includes(tag.toLowerCase())
  );
});

// Merge and sort all content
const unifiedContent = [
  ...filteredArticles.map((a: any) => ({ ...a, contentType: 'article' })),
  ...filteredVideos.map((v: any) => ({ ...v, contentType: 'video' }))
].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

// Date range + location formatting now live in src/lib/events (Date-free,
// unit-tested) — see formatEventDateRange / formatLocation usage below.

// YouTube IDs are extracted via the shared parseVideoId (src/lib/platforms/youtube).

const brandColor = event.brandColor || 'var(--color-accent, #cc0000)';
// Cap the hero at 2400px wide (retina-safe for a full-bleed banner) instead of
// serving the raw upload, and let Sanity pick the best format.
const heroUrl = event.heroImage
  ? urlFor(event.heroImage).width(2400).auto('format').url()
  : '';
const fallbackGradient = `linear-gradient(135deg, ${brandColor} 0%, #111 100%)`;

// The trailer (poster, players, sound) is fully encapsulated in <HeroTrailer/>.
const trailerUrl = event.trailerUrl;
const trailerId = parseVideoId(trailerUrl);
---

<Layout title={`${event.title}`} description={`Complete coverage of ${event.title}`}>
  <main class="event-dashboard" style={`--brand-color: ${brandColor};`}>
    
    {/* Cinematic Hero */}
    <section class="event-hero">
      {/* Two layers (issue #22): the wrapper owns clipping/coverage and stays
          static; the inner layer owns the background image and the slow Ken
          Burns transform. Animating a single element caused edge slivers. */}
      <div class="event-hero-bg-wrapper">
        <div class="event-hero-bg-animated" style={heroUrl ? `background-image: url('${heroUrl}');` : `background-image: ${fallbackGradient};`}></div>
      </div>
      <div class="event-hero-overlay max-h-[800px] flex flex-col justify-center">
        <div
          class:list={[
            'container',
            'hero-grid-container',
            '2xl:!max-w-[1920px]',
            '2xl:!grid-cols-[1fr_1.2fr]',
            '3xl:!max-w-[2400px]',
            '3xl:!grid-cols-[1fr_1.4fr]',
            { 'has-trailer': !!trailerId, 'has-cta': !!(event.officialWebsite || event.signUpLink) },
          ]}
        >
          <div class="event-hero-content hero-copy animate-on-scroll flex flex-col gap-3 md:gap-0 w-full">
            {/* Top Row: Logo/Meta side-by-side on mobile, stacked on desktop */}
            <div class="flex flex-row items-center gap-3 md:flex-col md:items-start md:gap-0 w-full">
              {/* Logo */}
              <div class="flex-shrink-0 w-36 sm:w-40 md:w-auto md:mb-6">
                {event.logo && (
                  <img
                    src={urlFor(event.logo).height(240).url()}
                    alt={`${event.title} logo`}
                    class="hero-logo w-full h-auto md:w-auto"
                    height="240"
                    width={event.logo?.dimensions?.aspectRatio
                      ? Math.round(240 * event.logo.dimensions.aspectRatio)
                      : undefined}
                  />
                )}
                {!event.logo && <h1 class="hero-title">{event.title}</h1>}
              </div>
              
              {/* Meta Box */}
              <div class="flex flex-col flex-1 min-w-0 md:w-auto">
                <div class="hero-status md:mb-3"><EventStatusIndicator event={event} /></div>
                <p class="hero-meta text-xs md:text-base leading-tight md:leading-normal mt-1 md:mt-0">
                  <span class="event-dates block md:inline">{formatEventDateRange(event.startDate, event.endDate)}</span>
                  {formatLocation(event.location) && (
                    <span class="event-location block md:inline mt-0.5 md:mt-0">
                      <span class="hidden md:inline mx-2 text-gray-400">•</span>
                      {formatLocation(event.location)}
                    </span>
                  )}
                </p>
              </div>
            </div>

            {/* Bottom Row: Description spanning full width */}
            {event.description && (
              <div class="hero-description-wrapper w-full mt-1 md:mt-6">
                <p class="hero-description-text md:mt-0" id="event-about-text">{event.description}</p>
                <button class="hero-read-more" id="event-about-toggle" aria-expanded="false" hidden>
                  Read more
                </button>
              </div>
            )}
          </div>
          
          {trailerId && (
            <div class="hero-trailer animate-on-scroll aspect-video w-full h-auto 2xl:!max-w-4xl 3xl:!max-w-6xl 2xl:scale-110 2xl:origin-right" style="animation-delay: 0.2s;">
              <HeroTrailer trailerId={trailerId} title={event.title} />
            </div>
          )}

          {/* Placed after the trailer in the DOM so mobile stacks copy →
              trailer → button; grid-areas restore the desktop layout. */}
          {(event.officialWebsite || event.signUpLink) && (
            <div class="hero-cta">
              <a href={event.officialWebsite || event.signUpLink} target="_blank" rel="noopener noreferrer" class="hero-rsvp-btn">
                Official event information
              </a>
            </div>
          )}
        </div>
      </div>
    </section>

    <div class="container content-container">
      {unifiedContent.length > 0 ? (
        <section class="content-section">
          <h2 class="sr-only">Event coverage</h2>

          <div class="filter-controls animate-on-scroll">
            <button class="filter-btn type-btn" data-filter="article" aria-pressed="false" aria-controls="event-content-grid">ARTICLES</button>
            <button class="filter-btn type-btn" data-filter="video" aria-pressed="false" aria-controls="event-content-grid">VIDEOS</button>
          </div>

          <div id="event-content-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 w-full" aria-live="polite">
            {unifiedContent.map((item, index) => (
              <ContentCard item={item} index={index} />
            ))}
          </div>
        </section>
      ) : (
        <div class="empty-state animate-on-scroll">
          <p>{event.title} coverage is coming soon.</p>
        </div>
      )}
    </div>
    
    <SubscribeCTA />

  </main>
</Layout>

<style>

  .event-dashboard {
    /* min-height removed to respect canonical footer spacing */
  }
  .container {
    max-width: 1536px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  
  /* Hero */
  .event-hero {
    position: relative;
    background-color: #111;
    /* NO overflow:hidden here. On iOS Safari an overflow:hidden ancestor makes
       a descendant cross-origin (YouTube) iframe render as a black box. The bg
       below is inset:0 and its image clips to its own box, so it can't spill —
       the clip was never needed. */
  }
  /* Clipping/coverage layer: static, fills the hero, hides the sliver the
     animated child exposes at its edges while scaled. overflow:hidden is safe
     HERE (and only here) — it contains no iframe, so the iOS black-box bug
     cannot trigger. */
  .event-hero-bg-wrapper {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }
  .event-hero-bg-animated {
    position: absolute;
    inset: 0;
    /* Cover the whole hero (behind the copy AND the trailer). It re-crops when
       the description expands — an accepted trade for full coverage. */
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    /* translateZ(0) promotes this layer to its own compositor layer. Without
       it, the overlay's backdrop-filter blur stops the animated transform from
       repainting (issue #22 root cause) — keep it in the base AND in every
       keyframe so the promotion never lapses mid-animation. */
    transform: translateZ(0);
    /* Tuned after visual QA: the original 1.05/50s (~0.1%/s) sat below the
       perception floor and read as static. 1.08/30s is ambient but alive —
       don't retune blind; verify any change with the 2s/1.5x debug values
       (see d1db593). */
    animation: cinematic-hero-zoom 30s ease-in-out infinite alternate;
  }
  /* Scale never drops below 1, so the image always covers the wrapper — no
     exposed edges at any point in the cycle. */
  @keyframes cinematic-hero-zoom {
    from {
      transform: scale(1.08) translateZ(0);
    }
    to {
      transform: scale(1) translateZ(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .event-hero-bg-animated {
      animation: none;
    }
  }
  /* In normal flow (not absolute) so the banner GROWS with its content instead
     of overflowing upward under the fixed navbar. padding-top clears the navbar
     so the logo is never clipped. */
  .event-hero-overlay {
    position: relative;
    z-index: 1;
    min-height: 70vh;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.97) 0%,
      rgba(0, 0, 0, 0.55) 55%,
      rgba(0, 0, 0, 0.35) 100%
    );
    /* Subtle blur of the background image behind the overlay (content is a child,
       so it stays sharp) — softens the busy hero art for title legibility. */
    -webkit-backdrop-filter: blur(3px);
    backdrop-filter: blur(3px);
    display: flex;
    align-items: center;
    padding-top: clamp(6rem, 4.5rem + 6vw, 8.5rem);
    padding-bottom: clamp(2.5rem, 2rem + 2.5vw, 4rem);
  }

  /* Mobile: single column. Source order is copy → trailer → button, so the
     trailer sits above the Event Details button. */
  .hero-grid-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
    width: 100%;
  }
  .hero-cta {
    text-align: center;
  }

  /* Desktop: two columns. grid-areas keep copy + button stacked on the left
     with the trailer spanning both rows on the right. */
  @media (min-width: 900px) {
    /* .has-trailer / .has-cta are applied at build time — no reliance on :has()
       (which older Firefox lacks). Single-row areas when there's no CTA so the
       copy isn't squeezed by an empty grid row. */
    .hero-grid-container.has-trailer {
      grid-template-columns: 1fr 1fr;
      grid-template-areas: 'copy trailer';
      align-items: center;
    }
    .hero-grid-container.has-trailer.has-cta {
      grid-template-areas:
        'copy trailer'
        'cta trailer';
    }
    .hero-grid-container.has-trailer .hero-copy {
      grid-area: copy;
    }
    .hero-grid-container.has-trailer .hero-trailer {
      grid-area: trailer;
    }
    .hero-grid-container.has-trailer .hero-cta {
      grid-area: cta;
      align-self: start;
    }
    .hero-cta {
      text-align: left;
    }
  }

  .event-hero-content {
    max-width: 900px;
  }
  
  /* Placement only — the trailer's internals live in <HeroTrailer/>. */
  .hero-trailer {
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
  }
  
  .hero-logo {
    /* Responsive + width-capped so wide logos (e.g. Comic-Con) never overflow
       the column or force the banner taller than the viewport on mobile. */
    max-height: clamp(84px, 46px + 12vw, 180px);
    max-width: min(100%, 420px);
    width: auto;
    height: auto;
    object-fit: contain;
    /* Removed filter: drop-shadow due to known iOS Safari rendering bugs 
       causing the image to completely fail to load/display as broken on mobile */
  }
  .hero-title {
    font-family: var(--font-display, 'Inter', sans-serif);
    font-size: clamp(1.9rem, calc(1.1rem + 3vw), 3.75rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 0.95;
    text-transform: uppercase;
    color: var(--color-white, #f0f0f0);
    text-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
    margin: 0 0 1rem 0;
  }
  .hero-status {
    /* Margins managed by Tailwind md:mb-3 on the wrapper */
  }
  .hero-meta {
    font-size: clamp(0.9rem, 0.8rem + 0.6vw, 1.25rem);
    color: #fff;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .event-dates, .event-location {
    display: inline-block;
  }

  .hero-description-text {
    /* Font size is identical in every state so toggling never resizes the text.
       Collapsed height is 3em (2 lines at line-height 1.5); JS animates the
       inline max-height between this and the measured full height, so there's no
       arbitrary 800px value and no invisible portion of the transition. */
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.5;
    max-width: 600px;
    margin-top: 1.5rem;
    font-weight: 400;
    overflow: hidden;
    max-height: 3em;
    transition: max-height 0.3s ease;
  }

  .hero-read-more {
    background: none;
    border: none;
    color: #f87171; /* red-400: WCAG-legible link color on the dark hero (was low-contrast muted white) */
    font-weight: 500;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 0;
    margin-top: 0.5rem;
    cursor: pointer;
    text-decoration: underline;
  }

  /* TODO: Revisit stateful color logic. Caused color to reset on scroll.
  .hero-read-more {
    transition: color 0.3s ease;
  }
  .hero-read-more:not(:hover) {
    color: var(--color-white-muted);
  }
  .hero-read-more:hover, .hero-read-more:focus-visible {
    color: var(--color-accent);
  } */

  .hero-rsvp-btn {
    display: inline-block;
    background: transparent;
    color: white;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0.75rem 2rem;
    border: 1px solid var(--color-accent, #cc0000);
    text-transform: uppercase;
    letter-spacing: 2px;
    transition: background 0.3s ease, color 0.3s ease;
  }
  .hero-rsvp-btn:hover {
    background: var(--color-accent, #cc0000);
    color: white;
  }

  /* Mobile: single column with no trailer — centre the lockup for balance.
     align-items centres the logo (a flex item); text-align centres the copy. */
  @media (max-width: 899px) {
    .event-hero-content {
      align-items: flex-start;
      text-align: left;
    }
    /* Font size stays 1rem (matching the base) so expand/collapse never resizes
       the text; only the top margin tightens on mobile. */
    .hero-description-text {
      margin-top: 1rem;
    }
  }

  /* Content */
  .content-container {
    padding: 4rem 2rem;
  }
  .content-section {
    margin-bottom: 5rem;
  }
  
  /* Filter Controls */
  .filter-controls {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    max-width: 600px;
    margin: 0 auto 3rem auto;
  }
  .filter-btn {
    min-height: 44px; /* WCAG 2.5.5 minimum touch target, preserved on mobile */
    padding: 1.25rem 1rem;
    background: rgba(10, 10, 10, 0.6);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--color-white, #fff);
    font-size: 1.1rem;
    font-weight: 700;
    font-family: var(--font-display, 'Inter', sans-serif);
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    outline: none;
    -webkit-tap-highlight-color: transparent;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  @media (hover: hover) and (pointer: fine) {
    .filter-btn:hover,
    .filter-btn:focus-visible {
      background: rgba(239, 68, 68, 0.1);
      border: 2px solid var(--color-accent, #ef4444);
      box-shadow: 0 0 15px rgba(239, 68, 68, 0.5);
      transform: translateY(-2px);
    }
  }

  .filter-btn.active {
    background: rgba(239, 68, 68, 0.1);
    border: 2px solid var(--color-accent, #ef4444);
    color: white;
    box-shadow: 0 0 20px rgba(239, 68, 68, 0.6);
  }

  @media (max-width: 767px) {
    .filter-controls {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 2rem;
    }
    .filter-btn {
      flex: 1;
      padding: 0.75rem 0.5rem;
      font-size: 0.9rem;
    }
  }
  
  /* The styles for the cards themselves are now unified via ContentCard.astro 
     and global tailwind classes */


  
  .empty-state {
    text-align: center;
    padding: 4rem;
    color: #a0a0a0;
    font-size: 1.2rem;
  }

  /* Visually hidden but exposed to assistive tech (used for the section <h2>
     that restores the heading hierarchy between the hero <h1> and card <h3>s). */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  // astro:page-load fires on the initial load AND after every View Transition
  // navigation, so the filters keep working after client-side nav.
  function initEventInteractions() {
    const filterBtns = Array.from(document.querySelectorAll('.filter-btn'));
    const contentCards = Array.from(document.querySelectorAll('.content-card'));

    filterBtns.forEach((btn) => {
      if ((btn as HTMLElement).dataset.bound === 'true') return;
      (btn as HTMLElement).dataset.bound = 'true';
      btn.addEventListener('click', () => {
        const wasActive = btn.classList.contains('active');
        filterBtns.forEach((b) => {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
        });

        let activeFilter = 'all';
        if (!wasActive) {
          btn.classList.add('active');
          btn.setAttribute('aria-pressed', 'true');
          activeFilter = (btn as HTMLElement).getAttribute('data-filter') || '';
        }

        contentCards.forEach((card) => {
          const show = activeFilter === 'all' || card.getAttribute('data-type') === activeFilter;
          (card as HTMLElement).style.display = show ? 'flex' : 'none';
        });
      });
    });

    // Keyboard activation for video cards exposed as role="button".
    document.querySelectorAll('[data-action="open-video"]').forEach((card) => {
      if ((card as HTMLElement).dataset.keybound === 'true') return;
      (card as HTMLElement).dataset.keybound = 'true';
      card.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
          e.preventDefault();
          (card as HTMLElement).click();
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initEventInteractions);
</script>

<script>
  // Expandable event blurb. max-height animates between the CSS collapsed value
  // (3em) and the measured full height, so the motion is smooth in both
  // directions with no arbitrary max-height and no snap at the end. Rapid
  // toggling is safe: each click retargets the same animated property and the
  // completion cleanup uses a single transitionend handler (no stray timeout).
  const COLLAPSED_MAX = '3em';

  function initEventAbout() {
    const text = document.getElementById('event-about-text');
    const toggle = document.getElementById('event-about-toggle');
    if (!text || !toggle) return;

    let expanded = false;


    // Toggle visibility depends on whether the (collapsed) text overflows.
    const evaluate = () => {
      if (expanded) return;
      toggle.hidden = text.scrollHeight <= text.clientHeight + 2;
    };

    if (toggle.dataset.bound !== 'true') {
      toggle.dataset.bound = 'true';
      toggle.addEventListener('click', () => {
        if (!expanded) {
          expanded = true;
          const fullHeight = text.scrollHeight + 'px';
          text.style.maxHeight = fullHeight;
          text.addEventListener('transitionend', function handler(e) {
            if (e.propertyName === 'max-height' && expanded) {
              text.style.maxHeight = 'none';
            }
            text.removeEventListener('transitionend', handler);
          });
          toggle.textContent = 'Read less';
          toggle.setAttribute('aria-expanded', 'true');
        } else {
          expanded = false;
          text.style.maxHeight = text.scrollHeight + 'px';
          text.offsetHeight; // force reflow
          text.style.maxHeight = COLLAPSED_MAX;
          toggle.textContent = 'Read more';
          toggle.setAttribute('aria-expanded', 'false');
        }
      });
    }

    // Evaluate after web fonts settle (wrong scrollHeight otherwise) and on any
    // resize/reflow of the text box.
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(evaluate);
    }
    evaluate();
    if ((text as any).__ro) (text as any).__ro.disconnect();
    const ro = new ResizeObserver(() => evaluate());
    ro.observe(text);
    (text as any).__ro = ro;
  }

  document.addEventListener('astro:page-load', initEventAbout);
</script>
