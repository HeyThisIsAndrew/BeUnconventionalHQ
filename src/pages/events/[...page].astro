---
import Layout from '../../layouts/Layout.astro';
import PageTitle from '../../components/PageTitle.astro';
import { site } from '../../data/site.js';
import { getArticles } from '../../data/feeds.js';
import { getVideosUnified } from '../../lib/videos-source';
import Pagination from '../../components/Pagination.astro';
import { parseVideoId } from '../../lib/platforms/youtube';
import type { GetStaticPathsOptions } from 'astro';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const articles = await getArticles();
  const videos = await getVideosUnified();

  const eventItems = [
    ...articles.map((a: any) => ({ ...a, type: 'article' })),
    ...videos.map((v: any) => ({ ...v, type: 'video', image: v.thumbnail })),
  ]
    .filter((item) => (item.type === 'video' && item.isEvent === true) || item.category === 'Events')
    .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

  return paginate(eventItems, { pageSize: 16 });
}

const { page } = Astro.props;
const eventItems = page.data;

const pageNum = page.currentPage > 1 ? ` - Page ${page.currentPage}` : '';
const title = `Events${pageNum} | ${site.name}`;
const description = 'Live coverage, premieres, and press event highlights from Be Unconventional HQ.';
---

<Layout title={title} description={description} prevUrl={page.url.prev} nextUrl={page.url.next}>
  <main class="events-page">
    <div class="container">
      <header class="section-header animate-on-scroll" data-nav-anchor>
        <PageTitle as="h1" kicker="Live Coverage" primary="Latest" secondary="Events" />
      </header>

      {/* Structural h2 so card h3s don't skip a heading level (axe: heading-order). */}
      <h2 class="sr-only">Event coverage</h2>
      <div class="event-grid">
        {
          eventItems.length > 0 ? (
            eventItems.map((item: any, index: number) => {
              const isVideo = item.type === 'video';
              const videoId = isVideo ? parseVideoId(item.link) : null;

              const CardWrapper = isVideo ? 'div' : 'a';
              const wrapperProps = isVideo
                ? {
                    class: 'event-card animate-on-scroll video-modal-trigger',
                    'data-video-id': videoId,
                    style: `--index: ${index}; cursor: pointer;`,
                  }
                : {
                    href: item.link,
                    target: '_blank',
                    rel: 'noopener noreferrer',
                    class: 'event-card animate-on-scroll',
                    style: `--index: ${index};`,
                  };

              const loadingStrategy = index < 6 ? 'eager' : 'lazy';

              return (
                <CardWrapper {...wrapperProps}>
                  <div class="event-image-wrapper">
                    <img
                      src={item.image}
                      alt={item.title}
                      loading={loadingStrategy}
                      decoding="async"
                      class="event-image"
                    />
                    <div class="event-overlay">
                      <span class="event-tag">{item.category}</span>
                      <h3 class="event-title line-clamp-2">{item.title}</h3>
                      <span class="event-date">{item.date}</span>
                    </div>
                  </div>
                </CardWrapper>
              );
            })
          ) : (
            <div
              class="empty-state animate-on-scroll"
              style="grid-column: 1 / -1; text-align: center; padding: 4rem 0; opacity: 0.6;"
            >
              <p>Check back soon for live coverage and event highlights.</p>
            </div>
          )
        }
      </div>

      <Pagination page={page} />

      <section
        class="press-kit-section animate-on-scroll"
      >
        <div class="section-header" style="margin-bottom: 2rem;">
          <PageTitle
            kicker="Bookings"
            primary="Want us at"
            secondary="Your event?"
            scale="secondary"
          />
        </div>
        <p class="press-kit-desc">
          We provide cinematic coverage for premieres, conventions, and gaming
          events.
        </p>
        <a href={`/contact`} class="cta-button-primary" data-modal-trigger="contact"
          >Get in Touch</a
        >
      </section>

    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  
  .events-page {
    padding: 120px 0;
    min-height: 80vh;
  }

  .event-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 350px), 1fr));
    gap: 3rem;
    max-width: 1200px;
    margin: 0 auto;
    margin-bottom: 4rem;
  }

  @media (max-width: 768px) {
    .event-grid {
      grid-template-columns: 1fr;
    }
  }
  
  .press-kit-section {
    text-align: center;
    padding: 6rem 0;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  
  .press-kit-desc {
    color: var(--color-white-muted);
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto 2rem;
  }
</style>
