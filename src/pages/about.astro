---
import Layout from '../layouts/Layout.astro';
import Socials from '../components/Socials.astro';
import { categories } from '../data/categories.js';
---

<Layout
  title="About"
  description="The story behind Be Unconventional HQ — a cinematic creator hub for film, TV, gaming, and events."
>
  <header class="page-head container">
    <p class="eyebrow">Who we are</p>
    <h1 class="heading">About the HQ</h1>
  </header>

  <section class="container section about" style="padding-top:0">
    <div class="about-media reveal">
      <img src="/profile.jpg" alt="Be Unconventional HQ" />
    </div>
    <div class="about-copy reveal" data-delay="80">
      <p>
        <strong>Be Unconventional HQ</strong> is a creator-led media hub for people
        who take their fandom seriously. We cover film, television, gaming, and the
        live events that bring it all together — with reviews, reactions, and the
        kind of deep dives the algorithm usually skips.
      </p>
      <p>
        No corporate hot-takes, no recycled press releases. Just honest,
        cinematic coverage of the stories worth caring about — published as
        videos on YouTube and long-form pieces on Substack.
      </p>
      <p>Sometimes unconventional is the only way forward.</p>
      <div class="about-socials">
        <Socials />
      </div>
    </div>
  </section>

  <section class="container section" style="padding-top:0">
    <h2 class="heading about-sub">What we cover</h2>
    <ul class="pillars">
      {
        categories.map((c) => (
          <li class="pillar reveal">
            <span class="pillar-label">{c.label}</span>
            <span class="pillar-blurb">{c.blurb}</span>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>

<style>
  .about {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: center;
  }
  .about-media img {
    width: 100%;
    border-radius: var(--radius);
    border: 1px solid var(--line);
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }
  .about-copy {
    display: flex;
    flex-direction: column;
    gap: 1.15rem;
    color: var(--text-2);
    font-size: 1.05rem;
    line-height: 1.7;
  }
  .about-copy strong {
    color: var(--text);
  }
  .about-socials {
    margin-top: 0.75rem;
  }
  .about-sub {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    margin-bottom: 1.75rem;
  }
  .pillars {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 240px), 1fr));
    gap: 1rem;
  }
  .pillar {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.5rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg-1);
  }
  .pillar-label {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 1.15rem;
  }
  .pillar-blurb {
    color: var(--text-2);
    font-size: 0.9rem;
  }

  @media (max-width: 760px) {
    .about {
      grid-template-columns: 1fr;
    }
    .about-media {
      max-width: 360px;
      margin-inline: auto;
    }
  }
</style>
