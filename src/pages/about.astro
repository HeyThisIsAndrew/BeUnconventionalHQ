---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site.js';

const base = import.meta.env.BASE_URL;
const title = `About | ${site.name}`;
const description =
  'The story behind Be Unconventional HQ – cinematic nerd culture coverage.';

const stats = [
  { label: 'Subscribers', value: '12K+', platform: 'YouTube' },
  { label: 'Followers', value: '8K+', platform: 'Instagram' },
  { label: 'Followers', value: '15K+', platform: 'TikTok' },
  { label: 'Readers', value: '5K+', platform: 'Substack' },
];
---

<Layout title={title} description={description}>
  <main class="about-page">
    <section class="about-hero">
      <div class="about-image-container animate-on-scroll">
        <img
          src={`${base}profile.jpg`}
          alt="Be Unconventional HQ Creator"
          class="about-profile-img"
        />
      </div>
      <div class="about-story animate-on-scroll" data-delay="200">
        <p class="section-kicker">The Story</p>
        <h2 class="about-title-main">UNCONVENTIONAL</h2>
        <h3 class="about-title-sub">TRUTH IN CULTURE</h3>
        <div class="about-text">
          <p>
            <strong>Be Unconventional HQ</strong> was born out of a desire for more
            cinematic, honest, and high-quality coverage of the things we love. In
            a world of rushed "hot takes" and clickbait, we choose to slow down and
            focus on the artistry.
          </p>
          <p>
            Whether it's a deep dive into the lighting of a new Batman film or a
            breakdown of the latest gaming mechanics, we believe everything
            deserves a cinematic perspective. Our mission is to bridge the gap
            between fan enthusiasm and professional film production quality.
          </p>
          <p>
            Based on a foundation of professional filmmaking, we use
            industry-standard tools like the <strong>Sony A7CR</strong>, <strong
              >Sony A7IV</strong
            >, and <strong>DaVinci Resolve</strong> to bring you content that looks
            and feels as good as the movies we cover.
          </p>
        </div>
      </div>
    </section>

    <section class="stats-section">
      <div class="stats-grid">
        {
          stats.map((stat, index) => (
            <div
              class="stat-card animate-on-scroll"
              data-delay={100 + index * 100}
            >
              <span class="stat-value">{stat.value}</span>
              <span class="stat-label">
                {stat.platform} {stat.label}
              </span>
            </div>
          ))
        }
      </div>
    </section>

    <section class="press-kit-section animate-on-scroll">
      <h2 class="press-kit-title">Press & Collaborations</h2>
      <p class="press-kit-desc">
        Interested in working together or want to feature Be Unconventional HQ?
        Download our media kit below.
      </p>
      <a href={`${base}press-kit`} class="cta-button-primary">View Press Kit</a>
    </section>
  </main>
</Layout>

<style>
  .about-title-main,
  .about-title-sub {
    text-align: center;
    font-family: var(--font-display);
    text-transform: uppercase;
    width: 100%;
    max-width: 100%;
    margin: 0;
    line-height: 1.1;
  }

  .about-title-main {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 600;
    color: var(--color-white);
  }

  .about-title-sub {
    font-size: clamp(1.25rem, 2.5vw, 2.25rem);
    font-weight: 700;
    color: var(--color-accent);
    margin-top: 0.25rem;
    margin-bottom: 2rem;
    letter-spacing: 0.1em;
  }

  @media (max-width: 768px) {
    .about-title-main {
      font-size: clamp(1.5rem, 8.5vw, 2.8rem);
    }

    .about-title-sub {
      font-size: clamp(1rem, 5.5vw, 1.6rem);
      margin-bottom: 1.5rem;
    }
  }
</style>
