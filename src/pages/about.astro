---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site.js';
import SocialsSection from '../components/SocialsSection.astro';

const title = `About | ${site.name}`;
const description =
  'Discover the story behind Be Unconventional HQ: a space dedicated to movies, games, technology, and storytelling from a cinematic perspective.';

const pillars = [
  {
    label: 'Production Quality',
    value: '4K',
    desc: 'Cinematic film-standard visuals',
  },
  {
    label: 'Filmmaker Perspective',
    value: 'Pro',
    desc: 'Expertise-driven industry analysis',
  },
  {
    label: 'Passionate Community',
    value: 'HQ',
    desc: 'Connecting nerd culture enthusiasts',
  },
  {
    label: 'Unfiltered Truth',
    value: '100%',
    desc: 'Honest reviews and deep dives',
  },
];
---

<Layout title={title} description={description}>
  <main class="about-page">
    <section class="about-hero">
      <div class="about-image-container animate-on-scroll">
        <img
          src={`/logo.png`}
          alt="Be Unconventional HQ"
          class="about-profile-img"
        />
      </div>
      <div class="about-story animate-on-scroll" data-delay="200">
        <p class="section-kicker about-kicker">The Story</p>
        <h1 class="about-title-main">UNCONVENTIONAL</h1>
        {/* A tagline, not a section heading — <p> keeps the heading outline
            valid (h1 was followed directly by h3). Styling is class-based. */}
        <p class="about-title-sub">TRUTH IN CULTURE</p>
        <div class="about-text">
          <p>
            “Be who you are and say what you feel, because those who mind don’t matter, and those who matter don’t mind.” That belief has guided me through much of my life, and it’s the foundation of <strong>Be Unconventional HQ</strong>. I created this space to share my passion for movies, games, technology, and storytelling with honesty, curiosity, and a cinematic perspective.
          </p>
          <p>
            Whether it’s breaking down the cinematography of a Batman film, exploring the latest gaming mechanics, or geeking out over the technology behind the creative process, the goal is always the same: to slow down, appreciate the craft, and have genuine conversations instead of chasing hot takes or clickbait.
          </p>
          <p>
            Every video and article is created with the same care and attention to detail as the work that inspires it. My hope is that you’ll find something that makes you think, discover something new, and feel at home celebrating the things you love.
          </p>
          <p>
            Be yourself. Be passionate. Be unconventional.
          </p>
        </div>
      </div>
    </section>

    <section class="stats-section">
      <div class="stats-grid">
        {
          pillars.map((pillar, index) => (
            <div
              class="stat-card animate-on-scroll"
              data-delay={100 + index * 100}
            >
              <span class="stat-value">{pillar.value}</span>
              <span class="stat-label">{pillar.label}</span>
              <p class="pillar-desc">{pillar.desc}</p>
            </div>
          ))
        }
      </div>
    </section>

    <div class="pb-8">
      <SocialsSection />
    </div>

    <!-- <section class="press-kit-section animate-on-scroll">
      <div class="section-header" style="margin-bottom: 2rem;">
        <PageTitle
          kicker="Media"
          primary="Press and"
          secondary="Collaborations"
          scale="secondary"
        />
      </div>
      <p class="press-kit-desc">
        Interested in working together or want to feature Be Unconventional HQ?
        Download our media kit below.
      </p>
      <a href={`/press-kit`} class="cta-button-primary">View Press Kit</a>
    </section> -->
  </main>
</Layout>

<style>
  .about-kicker {
    color: var(--color-accent);
    font-size: clamp(0.75rem, calc(0.375rem + 0.9vw), 1.1rem);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
    text-align: center;
  }

  .about-title-main {
    text-align: center;
    font-size: clamp(1.5rem, calc(0.75rem + 1.5vw), 2.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--color-white);
    text-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
    line-height: 1;
  }

  .about-title-sub {
    text-align: center;
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(0.75rem, calc(0.375rem + 0.9vw), 1.1rem);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    text-shadow: 0 0 15px rgba(255, 255, 255, 0.2);
    margin-top: -1rem;
    margin-bottom: 2rem;
  }

  .pillar-desc {
    font-size: 0.8rem;
    color: var(--color-white-muted);
    margin-top: 0.5rem;
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .about-title-main {
      font-size: clamp(1rem, calc(0.5rem + 2.75vw), 1.35rem);
      text-align: center;
    }
  }
</style>
