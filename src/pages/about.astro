---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site.js';
import PageTitle from '../components/PageTitle.astro';
import SocialsSection from '../components/SocialsSection.astro';

const title = `About | ${site.name}`;
const description =
  'The story behind Be Unconventional HQ – cinematic nerd culture coverage.';

const pillars = [
  {
    label: 'Production Quality',
    value: '4K',
    desc: 'Cinematic film-standard visuals',
  },
  {
    label: 'Filmmaker Perspective',
    value: 'Pro',
    desc: 'Expertise-driven industry analysis',
  },
  {
    label: 'Passionate Community',
    value: 'HQ',
    desc: 'Connecting nerd culture enthusiasts',
  },
  {
    label: 'Unfiltered Truth',
    value: '100%',
    desc: 'Honest reviews and deep dives',
  },
];
---

<Layout title={title} description={description}>
  <main class="about-page">
    <section class="about-hero">
      <div class="about-image-container animate-on-scroll">
        <img
          src={`/logo.png`}
          alt="Be Unconventional HQ"
          class="about-profile-img"
        />
      </div>
      <div class="about-story animate-on-scroll" data-delay="200">
        <p class="section-kicker about-kicker">The Story</p>
        <h1 class="about-title-main">UNCONVENTIONAL</h1>
        <h3 class="about-title-sub">TRUTH IN CULTURE</h3>
        <div class="about-text">
          <p>
            <strong>Be Unconventional HQ</strong> was born out of a desire for more
            cinematic, honest, and high-quality coverage of the things we love. In
            a world of rushed "hot takes" and clickbait, we choose to slow down and
            focus on the artistry.
          </p>
          <p>
            Whether it's a deep dive into the lighting of a new Batman film or a
            breakdown of the latest gaming mechanics, we believe everything
            deserves a cinematic perspective. Our mission is to nerd out on the
            details people might not even cover. Our goal is to bridge the gap
            between fan enthusiasm and professional film production quality.
          </p>
          <p>
            Based on a foundation of professional filmmaking, we use
            industry-standard tools to bring you quality content.
          </p>
        </div>
      </div>
    </section>

    <section class="stats-section">
      <div class="stats-grid">
        {
          pillars.map((pillar, index) => (
            <div
              class="stat-card animate-on-scroll"
              data-delay={100 + index * 100}
            >
              <span class="stat-value">{pillar.value}</span>
              <span class="stat-label">{pillar.label}</span>
              <p class="pillar-desc">{pillar.desc}</p>
            </div>
          ))
        }
      </div>
    </section>

    <SocialsSection />

    <section class="press-kit-section animate-on-scroll">
      <div class="section-header" style="margin-bottom: 2rem;">
        <PageTitle
          kicker="Media"
          primary="Press and"
          secondary="Collaborations"
          scale="secondary"
        />
      </div>
      <p class="press-kit-desc">
        Interested in working together or want to feature Be Unconventional HQ?
        Download our media kit below.
      </p>
      <a href={`/press-kit`} class="cta-button-primary">View Press Kit</a>
    </section>
  </main>
</Layout>

<style>
  .about-kicker {
    color: var(--color-accent);
    font-size: clamp(0.75rem, calc(0.375rem + 0.9vw), 1.1rem);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
    text-align: center;
  }

  .about-title-main {
    text-align: center;
    font-size: clamp(1.5rem, calc(0.75rem + 1.5vw), 2.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--color-white);
    text-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
    line-height: 1;
  }

  .about-title-sub {
    text-align: center;
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(0.75rem, calc(0.375rem + 0.9vw), 1.1rem);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    text-shadow: 0 0 15px rgba(255, 255, 255, 0.2);
    margin-top: -1rem;
    margin-bottom: 2rem;
  }

  .pillar-desc {
    font-size: 0.8rem;
    color: var(--color-white-muted);
    margin-top: 0.5rem;
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .about-title-main {
      font-size: clamp(1rem, calc(0.5rem + 2.75vw), 1.35rem);
      text-align: center;
    }
  }
</style>
