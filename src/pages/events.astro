---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site.js';
import { getArticles, getVideos } from '../data/feeds.js';

const title = `Events | ${site.name}`;
const description =
  'Live coverage, premieres, and press event highlights from Be Unconventional HQ.';

const articles = await getArticles();
const videos = await getVideos();

const eventItems = [
  ...articles.map((a) => ({ ...a, type: 'article' })),
  ...videos.map((v) => ({ ...v, type: 'video', image: v.thumbnail })),
]
  .filter((item) => item.category === 'Events')
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout title={title} description={description}>
  <main class="events-page">
    <div class="container">
      <header class="section-header animate-on-scroll">
        <p class="section-kicker">Live Coverage</p>
        <h1 class="section-title">Latest Events</h1>
      </header>

      <div class="event-grid">
        {
          eventItems.length > 0 ? (
            eventItems.map((item, index) => {
              const isVideo = item.type === 'video';
              const videoId = isVideo 
                ? (item.link.includes('shorts') ? item.link.split('/').pop() : new URL(item.link).searchParams.get('v'))
                : null;

              const CardWrapper = isVideo ? 'div' : 'a';
              const wrapperProps = isVideo 
                ? { 
                    class: "event-card animate-on-scroll video-modal-trigger",
                    "data-video-id": videoId,
                    style: `--index: ${index}; cursor: pointer;`
                  }
                : {
                    href: item.link,
                    target: "_blank",
                    rel: "noopener noreferrer",
                    class: "event-card animate-on-scroll",
                    style: `--index: ${index};`
                  };

              return (
                <CardWrapper {...wrapperProps}>
                  <div class="event-image-wrapper">
                    <img src={item.image} alt={item.title} class="event-image" />
                    <div class="event-overlay">
                      <span class="event-tag">{item.category}</span>
                      <h3 class="event-title">{item.title}</h3>
                      <span class="event-date">{item.date}</span>
                    </div>
                  </div>
                </CardWrapper>
              );
            })
          ) : (
            <div class="empty-state animate-on-scroll" style="grid-column: 1 / -1; text-align: center; padding: 4rem 0; opacity: 0.6;">
              <p>Check back soon for live coverage and event highlights.</p>
            </div>
          )
        }
      </div>

      <section
        class="press-kit-section animate-on-scroll"
        style="margin-top: 8rem;"
      >
        <h2 class="press-kit-title">Want Us at Your Event?</h2>
        <p class="press-kit-desc">
          We provide cinematic coverage for premieres, conventions, and gaming
          events.
        </p>
        <a href={`/contact`} class="cta-button-primary">Get in Touch</a>
      </section>
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
</style>
