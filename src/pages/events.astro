---
import Layout from '../layouts/Layout.astro';
import PageTitle from '../components/PageTitle.astro';
import EventCalendar from '../components/EventCalendar.astro';
import EventCard from '../components/EventCard.astro';
import EventBookingCTA from '../components/EventBookingCTA.astro';
import MiniCalendarSidebar from '../components/MiniCalendarSidebar.astro';
import SpanningCalendarModal from '../components/SpanningCalendarModal.astro';
import { site } from '../data/site.js';
import { sanityClient } from "sanity:client";

const title = `Events | ${site.name}`;
const description = 'Live coverage, premieres, and press event highlights from Be Unconventional HQ.';

const query = `*[_type == "event"] | order(startDate desc)`;
let allEvents = [];
try {
  allEvents = await sanityClient.fetch(query);
} catch (e) {
  console.error("Failed to fetch Sanity events", e);
}

const today = new Date().toISOString();
// Upcoming events: chronologically (earliest first)
const upcomingEvents = allEvents
  .filter(e => (e.endDate || e.startDate) >= today)
  .sort((a, b) => new Date(a.startDate).getTime() - new Date(b.startDate).getTime());

// Past events: reverse chronological (most recent first)
const pastEvents = allEvents.filter(e => (e.endDate || e.startDate) < today);
---

<Layout title={title} description={description}>
  <main class="events-page">
    <div class="container">
      
      {/* Upcoming Events Calendar */}
      <header class="section-header animate-on-scroll" data-nav-anchor style="text-align: center; margin-bottom: 2rem;">
        <PageTitle as="h1" kicker="Schedule" primary="Upcoming" secondary="Events" />
        <p style="color: #888; max-width: 600px; margin: 1.5rem auto 0; font-size: 1.1rem; line-height: 1.6;">
          Our coverage roadmap for conventions, premieres, and industry events.
        </p>
      </header>
      
      <div class="events-layout">
        <div class="events-timeline-col">
          <EventCalendar events={upcomingEvents} />
          
          {/* Past Events Coverage Portfolio */}
          <section class="past-events-section" style="margin-top: 6rem;">
            <header class="section-header animate-on-scroll">
              <PageTitle as="h2" kicker="Portfolio" primary="Coverage" secondary="Hubs" scale="secondary" />
            </header>
            
            <div class="event-grid">
              {pastEvents.length > 0 ? (
                pastEvents.map((event, index) => (
                  <EventCard event={event} index={index} />
                ))
              ) : (
                <div class="empty-state animate-on-scroll" style="grid-column: 1 / -1; text-align: center; padding: 4rem 0; opacity: 0.6;">
                  <p>No past coverage hubs available yet.</p>
                </div>
              )}
            </div>
          </section>
        </div>

        <div class="events-sidebar-col">
          <MiniCalendarSidebar events={upcomingEvents} />
          
          {/* Future advertising spot placeholder (e.g., Mint Mobile) */}
          <div class="sidebar-ad-space" style="display: none; margin-top: 3rem; padding: 2rem; border: 1px dashed rgba(255,255,255,0.2); border-radius: 12px; text-align: center; color: rgba(255,255,255,0.4); font-size: 0.9rem;">
            <p>Advertisement Space</p>
          </div>
        </div>
      </div>

      <EventBookingCTA />
      
    </div>
  </main>
  
  <SpanningCalendarModal events={allEvents} />
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  
  .events-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 3rem;
    /* Columns stretch to the full row height so the sticky sidebar has room to
       travel — it follows the timeline as you scroll and releases at its end. */
    align-items: stretch;
    max-width: 1000px; /* Restored to original 1000px constraint as requested */
    margin: 0 auto;
  }
  
  @media (max-width: 900px) {
    .events-layout {
      grid-template-columns: 1fr;
    }
    .events-sidebar-col {
      display: none; /* or move it below the timeline, up to design preference */
    }
  }

  .event-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }
</style>
