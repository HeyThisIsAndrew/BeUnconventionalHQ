---
import Layout from '../layouts/Layout.astro';
import PageTitle from '../components/PageTitle.astro';
import FeaturedEvent from '../components/FeaturedEvent.astro';
import UpcomingEventsList from '../components/UpcomingEventsList.astro';
import EventCard from '../components/EventCard.astro';
import SubscribeBox from '../components/SubscribeBox.astro';
import MiniCalendarSidebar from '../components/MiniCalendarSidebar.astro'; // Restored per blueprint
import SpanningCalendarModal from '../components/SpanningCalendarModal.astro';
import { site } from '../data/site.js';
// @ts-ignore - sanity:client is a virtual module resolved by @sanity/astro
import { sanityClient } from "sanity:client";
import { toYMD } from '../lib/events';

const title = `Events | ${site.name}`;
const description = 'Live coverage, premieres, and press event highlights from Be Unconventional HQ.';

const query = `*[_type == "event"] | order(startDate desc)`;
let allEvents = [];
try {
  allEvents = await sanityClient.fetch(query);
} catch (e) {
  console.error("Failed to fetch Sanity events", e);
}

// Today's calendar date (YYYY-MM-DD) in the brand's reference timezone. Both
// sides of the comparison are the SAME precision — comparing a bare
// "2026-07-26" against a full ISO timestamp would sort the shorter string
// lower and misclassify an event that ends *today* as past.
const today = toYMD();

// Upcoming: ends today or later, earliest start first. YYYY-MM-DD strings sort
// chronologically, so localeCompare needs no Date objects.
const upcomingEvents = allEvents
  .filter((e: any) => {
    if (!e.startDate) return false;
    const end = (e.endDate || e.startDate).slice(0, 10);
    return end >= today;
  })
  .sort((a: any, b: any) => a.startDate.localeCompare(b.startDate));

// The nearest upcoming event headlines the hub; the rest form the vertical list.
const featuredEvent = upcomingEvents[0] ?? null;
const secondaryUpcoming = upcomingEvents.slice(1);

// Past: already ended, most recent first.
const pastEvents = allEvents
  .filter((e: any) => {
    if (!e.startDate) return false;
    const end = (e.endDate || e.startDate).slice(0, 10);
    return end < today;
  })
  .sort((a: any, b: any) => b.startDate.localeCompare(a.startDate));
---

<Layout title={title} description={description}>
  <main class="events-page flex-1 flex flex-col w-full">
    <div class="container">
      {/*
        FULL-WIDTH HERO: header + FeaturedEvent sit outside/above the 12-col grid
        so they span the full .container width as the page's visual anchor. The
        70/30 split begins only below this section. (JSX comment — not shipped.)
      */}
      <header class="section-header animate-on-scroll" data-nav-anchor style="text-align: center; margin-bottom: 2.5rem;">
        <PageTitle as="h1" kicker="Coverage" primary="Upcoming" secondary="Events" />
      </header>
      {/* Featured hero: the single nearest upcoming event. */}
          {featuredEvent ? (
            <FeaturedEvent event={featuredEvent} />
          ) : (
            <p class="events-none">
              No upcoming events on the schedule right now — explore our past coverage below.
            </p>
          )}

      {/*
        70/30 ASYMMETRICAL GRID:
        - grid-cols-1     mobile portrait stacks in one column.
        - md:grid-cols-12 the 8/4 split engages at md (768px), not lg, so tablets
                          and landscape phones also get the two-column view.
        - lg:items-start  keeps the shorter sidebar column from stretching to the
                          feed's height, which would break position:sticky. Only
                          matters at lg, where sticky is active.
      */}
      <div class="grid grid-cols-1 md:grid-cols-12 md:gap-8 lg:items-start max-w-screen-2xl mx-auto w-full" style="margin-top: 3.5rem;">
        {/*
          OVERFLOW GUARDRAIL (min-w-0): grid/flex children default to
          min-width:auto and refuse to shrink below their intrinsic content, so a
          long unbreakable string or wide image can blow out the grid and cause
          horizontal scroll. min-w-0 lets the column shrink, surviving extreme
          content and high zoom (e.g. 300% on a 360px viewport).
        */}
        <section class="md:col-span-8 min-w-0">
          
          {/* Secondary upcoming events as a clean vertical list. */}
          {secondaryUpcoming.length > 0 && (
            <section class="upcoming-section animate-on-scroll" aria-labelledby="more-upcoming-heading">
              <h2 id="more-upcoming-heading" class="upcoming-heading">More Upcoming</h2>
              <UpcomingEventsList events={secondaryUpcoming} />
            </section>
          )}

          {/*
            ARCHITECTURAL LEDGER: MOBILE-ONLY CALENDAR CTA
            This button is the primary entry point to the full calendar modal on
            mobile devices. It is explicitly hidden on medium (`md`) viewports
            and larger because its function is replaced by the MiniCalendarSidebar
            component, which becomes visible at that breakpoint. This prevents
            duplicate calendar navigation UI on desktop and tablet.
          */}
          {allEvents.length > 0 && (
            <div class="calendar-cta-row animate-on-scroll md:hidden">
              <button class="open-full-calendar-btn" type="button">View Full Calendar</button>
            </div>
          )}

          {/* Past coverage portfolio. */}
          {pastEvents.length > 0 && (
            <section class="past-events-section animate-on-scroll">
              <header class="section-header">
                <PageTitle as="h2" kicker="Portfolio" primary="Coverage" secondary="Hubs" scale="secondary" />
              </header>
              <div class="event-grid">
                {pastEvents.map((event: any, index: number) => (
                  <EventCard event={event} index={index} />
                ))}
              </div>
            </section>
          )}
        </section>

        {/*
          MOBILE KILL-SWITCH: sidebar is `hidden` by default and only `md:block`
          — portrait mobile stays a clean single column; the sidebar would just
          push primary content down and add noise on small screens.
        */}
        <aside class="hidden md:block md:col-span-4" aria-label="Upcoming events at a glance">
          {/*
            DESKTOP-ONLY STICKY PHYSICS & FLEXBOX FLOW
            1. lg:sticky — sticky only at lg (1024px). At md (landscape mobile) a
               sticky sidebar would consume the short viewport and trap scrolling,
               so it's reserved for tall desktop viewports.
            2. flex flex-col gap-8 — enforces vertical flow with fixed spacing
               between sidebar modules so they can never overlap.
          */}
          <div class="lg:sticky lg:top-28 flex flex-col gap-8 items-start">

            <div class="w-full">
              <MiniCalendarSidebar events={upcomingEvents} />
            </div>

            {/*
              SIDEBAR DISCOVERY MODULE [FUTURE]: this slot is reserved for a
              <DiscoverySidebar /> powered by Sanity queries (latest videos /
              articles) to boost in-ecosystem engagement. Tracked on a separate
              ticket to avoid scope creep during Events Hub stabilization. The old
              third-party ad placeholder was removed — owned content is preferred.
            */}

          </div>
        </aside>
      </div>
    </div>
  </main>

  {/* Moved outside <main> so it becomes a direct child of #page-content. 
      Because #page-content is a flex column that spans the viewport, 
      margin-top: auto guarantees this box docks perfectly to the footer! */}
  <div style="margin-top: auto; width: 100%; max-width: 1536px; margin-left: auto; margin-right: auto; padding-left: 2rem; padding-right: 2rem; margin-bottom: 2rem; position: relative; z-index: 10;">
    <SubscribeBox subtitle="Subscribe to keep up with the latest events." />
  </div>

  <SpanningCalendarModal events={allEvents} />
</Layout>

<style>
  .container {
    max-width: 1536px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .events-none {
    text-align: center;
    color: #999;
    font-size: 1.05rem;
    margin: 2rem auto 3rem;
    max-width: 560px;
  }

  .upcoming-section {
    /* Spacing is now handled by the grid container's margin-top */
  }
  .upcoming-heading {
    font-family: var(--font-display, 'Syne Variable', sans-serif);
    font-size: 1.4rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
    margin: 0 0 1.5rem;
    text-align: left;
  }

  .calendar-cta-row {
    text-align: center;
    margin: 3rem 0;
  }
  .open-full-calendar-btn {
    width: 100%;
    max-width: 320px;
    min-height: 52px;
    padding: 1rem 1.5rem;
    background: transparent;
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.25);
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .open-full-calendar-btn:hover,
  .open-full-calendar-btn:focus-visible {
    background: rgba(204, 0, 0, 0.1);
    border-color: var(--color-accent, #cc0000);
    color: white;
    box-shadow: 0 0 20px rgba(204, 0, 0, 0.5);
    outline: none;
  }

  .past-events-section {
    margin-top: 4.5rem;
  }
  .event-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }
</style>
