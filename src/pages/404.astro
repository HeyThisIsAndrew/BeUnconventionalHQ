---
import Layout from '../layouts/Layout.astro';
import PageTitle from '../components/PageTitle.astro';
import Button from '../components/Button.astro';
import { site } from '../data/site.js';

const title = `Page Not Found | ${site.name}`;
const description =
  'That page went off-script. Head back to Be Unconventional HQ.';
---

<Layout title={title} description={description}>
  <main class="notfound-page">
    <div class="notfound-inner">
      <span class="notfound-code" aria-hidden="true">404</span>
      <PageTitle as="h1" kicker="Off The Map" primary="Page" secondary="Not Found" />
      <p class="notfound-text">
        This one went off-script. The page you're after moved, vanished, or
        never existed, but the good stuff is still one click away.
      </p>
      <div class="notfound-actions">
        <Button href="/">Back to Home</Button>
        <a class="notfound-link" href="/feed">Browse the Feed &rarr;</a>
      </div>
    </div>
  </main>
</Layout>

<style>
  .notfound-page {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6rem 1.5rem;
  }

  .notfound-inner {
    max-width: 640px;
  }

  .notfound-code {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(4rem, 18vw, 9rem);
    font-weight: 800;
    line-height: 1;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .notfound-text {
    font-family: var(--font-body);
    color: var(--color-white-muted);
    font-size: 1.05rem;
    line-height: 1.6;
    margin: 1.5rem auto 2.5rem;
    max-width: 32rem;
  }

  .notfound-actions {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    align-items: center;
  }

  .notfound-link {
    position: relative;
    color: var(--color-white);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding-bottom: 4px;
    transition:
      color 0.3s ease,
      text-shadow 0.3s ease;
  }

  .notfound-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-accent);
    transition: width 0.35s cubic-bezier(0.25, 0.8, 0.2, 1);
  }

  .notfound-link:hover {
    color: var(--color-accent);
    text-shadow: 0 0 16px rgba(204, 0, 0, 0.5);
  }

  .notfound-link:hover::after {
    width: 100%;
  }
</style>
