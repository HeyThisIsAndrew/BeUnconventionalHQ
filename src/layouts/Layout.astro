---
// Self-hosted fonts (was Google Fonts). Same-origin, no render-blocking
// external request, no third-party exposure of visitor IPs.
// @ts-ignore
import '@fontsource-variable/syne';
// @ts-ignore
import '@fontsource-variable/inter';
import '../styles/global-base.css';
import '../styles/global.css';
import '../styles/theme-red.css';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import ContactModal from '../components/ContactModal.astro';
import { site } from '../data/site.js';
import { ClientRouter } from 'astro:transitions';

const {
  title = site.name,
  description = site.description,
  image = site.image,
  type = 'website',
  // Opt-in gate for work-in-progress or draft routes. When true, we emit a
  // robots meta directive that tells search engines not to index the page or
  // follow its links. Keep the default false so existing production pages are
  // unaffected.
  noindex = false,
  prevUrl,
  nextUrl,
  preloadImage,
} = Astro.props;

// Self-referential canonical URL: absolute, always trailing-slashed to match
// how Cloudflare Pages serves routes. og:url reuses the same value so search
// engines never see a page advertise two different addresses for itself.
const canonicalPath = Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const url = Astro.props.url ?? new URL(canonicalPath, site.url).toString();

// Sitewide structured data: tells search engines who this brand is and
// which social accounts are officially ours. Per-page Article/VideoObject
// schema is layered on separately. SearchAction is intentionally omitted
// until on-site search exists.
const orgId = `${site.url}#organization`;
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': orgId,
      name: site.name,
      url: site.url,
      logo: new URL('logo.webp', site.url).toString(),
      description: site.description,
      sameAs: [
        site.socials.youtube,
        site.socials.instagram,
        site.socials.tiktok,
        site.socials.threads,
        site.socials.facebook,
        site.socials.twitter,
        site.socials.letterboxd,
        site.socials.substack,
      ].filter(Boolean),
    },
    {
      '@type': 'WebSite',
      '@id': `${site.url}#website`,
      name: site.name,
      url: site.url,
      description: site.description,
      publisher: { '@id': orgId },
    },
  ],
};

const gtmId = import.meta.env.PUBLIC_GTM_ID;
---

<html lang="en">
  <head>
    <ClientRouter />
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <!-- Google Tag Manager (Worker) -->
    {gtmId && (
      <>
        <script is:inline type="text/partytown" is:inline>
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            'gtm.start': new Date().getTime(),
            event: 'gtm.js',
          });
        </script>
        <script is:inline type="text/partytown" src={`https://www.googletagmanager.com/gtm.js?id=${gtmId}`} />
      </>
    )}

    <!-- Google Tag Manager (Main Thread Navigation) -->
    <script is:inline>
      if (typeof window !== 'undefined') {
        if (!window['setup']) {
          window['setup'] = true;
          // ClientRouter swaps pages without full reloads, so this script only
          // runs once per session. astro:page-load fires on the initial load
          // AND after every client-side navigation — the GA4 tag in the GTM
          // dashboard triggers on this event (not "All Pages") to avoid
          // double-counting the first view.
          document.addEventListener('astro:page-load', function () {
            const pushGA = () => {
              window.dataLayer = window.dataLayer || [];
              window.dataLayer.push({
                event: 'page_view',
                page_location: window.location.href,
                page_path: window.location.pathname,
                page_title: document.title,
              });
            };
            if ('requestIdleCallback' in window) {
              requestIdleCallback(pushGA);
            } else {
              setTimeout(pushGA, 200);
            }
          });
        }
      }
    </script>

    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#000000" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {prevUrl && <link rel="prev" href={prevUrl} />}
    {nextUrl && <link rel="next" href={nextUrl} />}
    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}
    <link rel="canonical" href={url} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
    <link rel="icon" type="image/svg+xml" href={`/favicon.svg`} />
    <link rel="icon" type="image/x-icon" href={`/favicon.ico`} />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={url} />
    <meta property="og:type" content={type} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
  </head>
  <body>
    <a href="#page-content" class="skip-link">Skip to main content</a>
    {
      gtmId && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
            title="Google Tag Manager"
          />
        </noscript>
      )
    }
    <div class="safe-area-blackout"></div>
    <!-- Navbar and Footer are siblings of #page-content, so inert-ing only
         #page-content would still let Tab reach them. Wrap all three in
         #app-wrapper and inert THAT while a modal is open — the modals live
         outside the wrapper, so they stay reachable. -->
    <div id="app-wrapper" class="min-h-[100svh] flex flex-col">
      <Navbar />
      <div id="page-content" class="flex-1 flex flex-col">
        <slot />
      </div>
      <Footer />
    </div>
    <ContactModal />
    <slot name="modals" />

    <!-- Unified Video Modal -->
    <div
      id="video-modal"
      class="modal-overlay"
      aria-hidden="true"
      role="dialog"
      aria-modal="true"
      aria-label="Video Player"
    >
      <div class="modal-content">
        <button class="modal-close" aria-label="Close modal">&times;</button>
        <div class="video-container">
          <iframe
            id="modal-iframe"
            src=""
            
            allow="autoplay; encrypted-media"
            allowfullscreen
            title="YouTube video player"></iframe>
        </div>
      </div>
    </div>

    <script is:inline>
      // Guarded so this page-load listener binds exactly once, not once per
      // client-side navigation (Astro re-executes <body> scripts on every swap).
        if (!window['setup']) {
          window['setup'] = true;
        console.log('Layout script initialized');
        document.addEventListener('astro:page-load', () =>
          console.log('Astro Page Load')
        );
      }

      (function () {
        // Remembers what had focus before the modal opened, to restore it on
        // close instead of dropping keyboard users at the top of the page.
        let lastFocused = null;

        function openModal(videoId) {
          const modal = document.getElementById('video-modal');
          const modalIframe = document.getElementById('modal-iframe');

          if (videoId && modal && modalIframe) {
            // Save focus + trap it: inert the whole app wrapper (navbar,
            // content, footer), not just #page-content.
            lastFocused = document.activeElement;

            // Capture scroll position
            const scrollY = window.scrollY;
            document.body.style.top = `-${scrollY}px`;

            // ACTION 2.1 & 2.2: No autoplay, use rel=0 and modestbranding=1
            modalIframe.src = `https://www.youtube.com/embed/${videoId}?rel=0&modestbranding=1`;
            modal.classList.add('active');
            document.documentElement.classList.add('modal-open');
            modal.setAttribute('aria-hidden', 'false');
            document.getElementById('app-wrapper')?.setAttribute('inert', '');

            const closeBtn = modal.querySelector('.modal-close');
            if (closeBtn) setTimeout(() => closeBtn.focus(), 100);
          }
        }

        function closeModal() {
          const modal = document.getElementById('video-modal');
          const modalIframe = document.getElementById('modal-iframe');

          if (modal && modalIframe) {
            // Guard clause to prevent state corruption
            if (!document.documentElement.classList.contains('modal-open'))
              return;

            const scrollY = Math.abs(parseInt(document.body.style.top || '0'));

            modal.classList.remove('active');
            document.documentElement.classList.remove('modal-open');
            modal.setAttribute('aria-hidden', 'true');
            document.getElementById('app-wrapper')?.removeAttribute('inert');
            // 'about:blank', NOT '' — an empty src resolves to the current
            // page URL, silently reloading the whole site inside the hidden
            // iframe on every close.
            modalIframe.src = 'about:blank';

            document.body.style.position = '';
            document.body.style.top = '';
            document.body.style.width = '';
            document.body.style.overflowY = '';

            // Restore focus to the element that opened the modal.
            if (lastFocused && typeof lastFocused.focus === 'function') {
              lastFocused.focus();
            }
            lastFocused = null;

            // Double requestAnimationFrame for native thread safety
            requestAnimationFrame(() => {
              requestAnimationFrame(() => {
                const originalBehavior =
                  document.documentElement.style.scrollBehavior;
                document.documentElement.style.scrollBehavior = 'auto'; // Force instant
                window.scrollTo(0, scrollY);
                document.documentElement.style.scrollBehavior =
                  originalBehavior;
              });
            });
          }
        }

        // Global Event Delegation for Video Triggers
        if (!window.videoModalSetup) {
          document.addEventListener('click', (e) => {
          if (!(e.target instanceof Element)) return;
          const trigger = e.target.closest('[data-action="open-video"]');
          
          if (trigger) {
            e.preventDefault();
              const videoId = trigger.getAttribute('data-video-id');
              if (videoId) openModal(videoId);
            }

            const currentModal = document.getElementById('video-modal');
            if (e.target === currentModal || e.target.closest('.modal-close')) {
              closeModal();
            }
          });
          window.videoModalSetup = true;
        }

        if (!window.videoModalEscSetup) {
          document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeModal();

            if (e.key === 'Enter' || e.key === ' ') {
              if (!(e.target instanceof Element)) return;
              const trigger = e.target.closest('[data-action="open-video"]');
              if (trigger) {
                e.preventDefault();
                const videoId = trigger.getAttribute('data-video-id');
                if (videoId) openModal(videoId);
              }
            }
          });
          window.videoModalEscSetup = true;
        }

        if (!window.videoModalNavSetup) {
          document.addEventListener('astro:before-preparation', closeModal);
          window.videoModalNavSetup = true;
        }
      })();
    </script>
    <script>
      let isInitialLoad = true;

      function initReveal() {
        const els = document.querySelectorAll('.reveal, .animate-on-scroll');
        const reduce = window.matchMedia(
          '(prefers-reduced-motion: reduce)'
        ).matches;
        if (reduce || !('IntersectionObserver' in window)) {
          els.forEach((elem) => {
            const el = elem as HTMLElement;
            el.setAttribute('data-state', 'in');
            el.setAttribute('data-state', 'active');
            el.style.opacity = '1';
            el.style.transform = 'none';
          });
          return;
        }
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const el = entry.target as HTMLElement;
              const delay = el.dataset.delay || '0';
              el.style.transitionDelay = `${delay}ms`;
              el.setAttribute('data-state', 'in');
              el.setAttribute('data-state', 'active');
              el.style.opacity = '1';
              el.style.transform = 'none';
              obs.unobserve(el);
              
              // Clear the delay after the animation completes so hover effects aren't permanently delayed
              setTimeout(() => {
                if (el) el.style.transitionDelay = '';
              }, parseInt(delay) + 600);
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );
        els.forEach((el) => io.observe(el));
      }

      function handlePageLoad() {
        if (isInitialLoad) {
          initReveal();
          isInitialLoad = false;
        } else {
          document.querySelectorAll('.reveal, .animate-on-scroll').forEach((elem) => {
            const el = elem as HTMLElement;
            const originalTransition = el.style.transition;
            el.style.transition = 'none';
            el.setAttribute('data-state', 'in');
            el.setAttribute('data-state', 'active');
            el.style.opacity = '1';
            el.style.transform = 'none';

            // Restore transition for hover effects after rendering
            requestAnimationFrame(() => {
              requestAnimationFrame(() => {
                el.style.transition = originalTransition;
              });
            });
          });
        }
      }

      document.addEventListener('astro:page-load', handlePageLoad);
    </script>
    <script>
      // Step 1: Strip mobile scroll locks BEFORE Astro takes its snapshot
      document.addEventListener('astro:before-preparation', () => {
        document.documentElement.classList.remove('modal-open', 'menu-open');
        const body = document.body;
        // Class-based locks (html.modal-open body { position: fixed }) leave the
        // inline body.style.position empty, so `=== 'fixed'` misses the video
        // modal and its scroll offset leaks into the snapshot. The inline
        // `top: -[scrollY]px` is set for every lock type — key off that.
        if (body.style.top) {
          const scrollY = Math.abs(parseInt(body.style.top || '0', 10));
          body.style.position = '';
          body.style.top = '';
          body.style.width = '';
          body.style.overflowY = '';
          window.scrollTo(0, scrollY);
        }
        if (body.style.overflow === 'hidden') {
          body.style.overflow = '';
        }
        // Never cache an OPEN modal: with the scroll lock already cleared above,
        // a cached-open modal causes a big scroll jump when closed after Back.
        // Release the focus trap and close/reset both modals.
        document.getElementById('app-wrapper')?.removeAttribute('inert');
        const videoModal = document.getElementById('video-modal');
        if (videoModal) {
          videoModal.classList.remove('active');
          videoModal.setAttribute('aria-hidden', 'true');
          const iframe = videoModal.querySelector('#modal-iframe') as HTMLIFrameElement | null;
          if (iframe) iframe.src = 'about:blank';
        }
        const successContainer = document.getElementById('success-message');
        if (successContainer && !successContainer.classList.contains('hidden')) {
          successContainer.classList.add('hidden');
          const iframe = document.getElementById('hidden_iframe') as HTMLIFrameElement | null;
          if (iframe) iframe.src = 'about:blank';
        }
        const contactModal = document.getElementById('contact-modal');
        if (contactModal) {
          const formContainer = document.getElementById('form-container');
          if (formContainer && !formContainer.classList.contains('hidden')) {
            formContainer.classList.add('hidden');
            const form = document.getElementById('contact-modal-form') as HTMLFormElement | null;
            form?.reset();
          }
          document
            .getElementById('modal-form-status')
            ?.classList.remove('is-visible');
        }
        const calendarModal = document.getElementById('spanning-calendar-modal');
        if (calendarModal) {
          calendarModal.classList.remove('is-active');
          calendarModal.setAttribute('aria-hidden', 'true');
        }
        const modal = document.querySelector('#category-modal') as HTMLDialogElement | null;
        modal?.close();
      });

      // Step 2: Force scroll to top instantly BEFORE the DOM swaps
      document.addEventListener('astro:before-swap', () => {
        window.scrollTo({ left: 0, top: 0, behavior: 'instant' });
      });
    </script>
  </body>
</html>
