---
import { site } from '../data/site.js';

const base = import.meta.env.BASE_URL;
---

<section class="hero">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="hero-content">
    <p class="hero-kicker">{site.tagline}</p>
    <h1 class="hero-title">{site.name}</h1>
    <p class="hero-subtitle">
      Sometimes Unconventional is the Only Way Forward
    </p>
    <a href={`${base}videos`} class="hero-cta">Explore Content</a>
  </div>
</section>

<script define:vars={{ bannerUrl: `${base}banner.png` }}>
  const heroBackground = document.querySelector('.hero-bg');

  if (heroBackground) {
    heroBackground.style.backgroundImage = `url('${bannerUrl}')`;

    const updateHeroParallax = () => {
      const offset = Math.min(window.scrollY * 0.4, 80);
      heroBackground.style.setProperty('--hero-parallax', `${offset}px`);
    };

    updateHeroParallax();
    window.addEventListener('scroll', updateHeroParallax, { passive: true });
  }
</script>
