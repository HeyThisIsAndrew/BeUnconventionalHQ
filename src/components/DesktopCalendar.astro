---
export interface Props {
  events: any[];
}
const { events } = Astro.props;

// Basic logic to generate calendar grid for the current month.
const today = new Date();
const year = today.getFullYear();
const month = today.getMonth();

const firstDay = new Date(year, month, 1);
const lastDay = new Date(year, month + 1, 0);
const monthStart = new Date(year, month, 1);
const monthEnd = new Date(year, month + 1, 0, 23, 59, 59, 999);
const startingDayOfWeek = firstDay.getDay(); // 0 (Sun) to 6 (Sat)
const totalDays = lastDay.getDate();

const days = [];
for (let i = 0; i < startingDayOfWeek; i++) {
  days.push({ empty: true });
}
for (let i = 1; i <= totalDays; i++) {
  days.push({ day: i, empty: false });
}

const currentMonthEvents = events.filter((event) => {
  if (!event.startDate) return false;
  const start = new Date(event.startDate);
  const end = new Date(event.endDate || event.startDate);

  if (Number.isNaN(start.getTime()) || Number.isNaN(end.getTime())) {
    return false;
  }

  return start <= monthEnd && end >= monthStart;
});

// Sort events by start date for the list view
const sortedEvents = [...currentMonthEvents].sort((a, b) => {
  return new Date(a.startDate).getTime() - new Date(b.startDate).getTime();
});

const todayDate = new Date();
todayDate.setHours(0, 0, 0, 0);

const calendarSegments = currentMonthEvents.flatMap((event) => {
  const start = new Date(event.startDate);
  const end = event.endDate ? new Date(event.endDate) : start;

  if (Number.isNaN(start.getTime()) || Number.isNaN(end.getTime())) {
    return [];
  }
  
  const eventEndDate = new Date(end);
  eventEndDate.setHours(0, 0, 0, 0);
  const isPast = eventEndDate < todayDate;

  const startDay = start < monthStart ? 1 : start.getDate();
  const endDay = end > monthEnd ? totalDays : end.getDate();

  const startIndex = startingDayOfWeek + startDay - 1;
  const endIndex = startingDayOfWeek + endDay - 1;

  const startRow = Math.floor(startIndex / 7) + 1;
  const startCol = (startIndex % 7) + 1;
  const endRow = Math.floor(endIndex / 7) + 1;
  const endCol = (endIndex % 7) + 1;

  const color = event.brandColor || 'var(--color-accent, #cc0000)';
  const segments = [];

  const slug = event.slug?.current ?? event.slug ?? '';

  for (let row = startRow; row <= endRow; row++) {
    const colStart = row === startRow ? startCol : 1;
    const colEnd = row === endRow ? endCol : 7;
    const span = colEnd - colStart + 1;
    const isStart = row === startRow;
    const isEnd = row === endRow;

    segments.push({
      row,
      colStart,
      colEnd,
      span,
      color,
      slug,
      title: event.title,
      isStart,
      isEnd,
      isContinuation: !isStart,
      isPast,
    });
  }

  return segments;
});

const segmentsPerRow: Record<number, any[]> = {};
calendarSegments.forEach(segment => {
  if (!segmentsPerRow[segment.row]) segmentsPerRow[segment.row] = [];
  
  let overlapIndex = 0;
  const rowSegments = segmentsPerRow[segment.row];
  
  while (rowSegments.some(s => s.overlapIndex === overlapIndex && 
         !(segment.colEnd < s.colStart || segment.colStart > s.colEnd))) {
    overlapIndex++;
  }
  
  segment.overlapIndex = overlapIndex;
  rowSegments.push(segment);
});

// Helper for formatting event dates in the sidebar
const formatDate = (dateStr: string) => {
  return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
};
---

<div class="dc-container">
  <!-- Left Column: Sidebar -->
  <aside class="dc-sidebar">
    <div class="dc-sidebar-header">
      <h2 class="dc-month">{today.toLocaleString('en-US', { month: 'long' })}</h2>
      <span class="dc-year">{today.getFullYear()}</span>
    </div>
    
    <div class="dc-event-list">
      {sortedEvents.map(event => {
        const eventEnd = event.endDate ? new Date(event.endDate) : new Date(event.startDate);
        eventEnd.setHours(0,0,0,0);
        const isPast = eventEnd < todayDate;
        
        return (
          <a 
            href={isPast ? undefined : `/events-new/${event.slug?.current ?? event.slug}`} 
            class:list={['dc-event-item', { 'is-past': isPast }]}
            data-event-id={event.slug?.current ?? event.slug}
          >
            <div class="dc-event-indicator" style={`background-color: ${event.brandColor || 'var(--color-accent)'}`}></div>
            <div class="dc-event-content">
              <h3 class="dc-event-title">{event.title}</h3>
              <p class="dc-event-date">
                {formatDate(event.startDate)}
                {event.endDate && event.endDate !== event.startDate && ` - ${formatDate(event.endDate)}`}
              </p>
            </div>
          </a>
        );
      })}
      {sortedEvents.length === 0 && <p class="dc-no-events">No events this month.</p>}
    </div>
  </aside>

  <!-- Right Column: Interactive Grid -->
  <main class="dc-main">
    <div class="dc-calendar-grid-wrapper">
      <div class="dc-calendar-header-row">
        <span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span>
      </div>
      
      <div class="dc-calendar-grid">
        {days.map((d, i) => (
          <div class={`dc-calendar-cell ${d.empty ? 'empty' : ''}`} style={`grid-column: ${(i % 7) + 1}; grid-row: ${Math.floor(i / 7) + 1};`}>
            {!d.empty && <span class="dc-day-number">{d.day}</span>}
          </div>
        ))}
        
        {calendarSegments.map((segment) => {
          const Element = segment.isPast ? 'div' : 'a';
          return (
            <Element
              href={segment.isPast ? undefined : `/events-new/${segment.slug}`}
              data-event-id={segment.slug}
              class:list={[
                'dc-highlighter-bar',
                { 'is-start': segment.isStart, 'is-end': segment.isEnd, 'is-continuation': segment.isContinuation, 'is-past': segment.isPast },
              ]}
              style={`grid-row: ${segment.row}; grid-column: ${segment.colStart} / span ${segment.span}; --bar-color: ${segment.color}; --overlap-index: ${segment.overlapIndex};`}
            >
              {segment.isContinuation && <span class="dc-bar-cont" aria-hidden="true">↳ </span>}
              <span class="dc-bar-label">{segment.title}</span>
            </Element>
          );
        })}
      </div>
    </div>
  </main>
</div>

<style>
  .dc-container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    height: 100%;
    background: transparent;
    border: none;
    padding: 0;
    box-shadow: none;
  }

  /* Breakpoint for Desktop */
  @media (min-width: 900px) {
    .dc-container {
      display: grid;
      grid-template-columns: 350px 1fr;
      gap: 2rem;
      background: #111;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      padding: 2rem;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    }
  }
  @media (min-width: 900px) and (max-height: 600px) {
    .dc-container {
      padding: 1rem;
      gap: 1rem;
      grid-template-columns: 280px 1fr;
    }
  }

  /* SIDEBAR */
  .dc-sidebar {
    display: flex;
    flex-direction: column;
    border-right: none;
    padding-right: 0;
    overflow: hidden;
  }
  @media (min-width: 900px) {
    .dc-sidebar {
      border-right: 1px solid rgba(255, 255, 255, 0.1);
      padding-right: 2rem;
    }
  }

  .dc-sidebar-header {
    margin-bottom: 1.5rem;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }
  @media (min-width: 900px) {
    .dc-sidebar-header {
      margin-bottom: 2rem;
    }
  }
  @media (max-height: 600px) {
    .dc-sidebar-header {
      margin-bottom: 1rem;
    }
  }

  .dc-month {
    font-size: 2rem;
    font-weight: 800;
    font-family: var(--font-display, 'Inter', sans-serif);
    margin: 0;
    line-height: 1;
    color: white;
  }
  @media (min-width: 900px) {
    .dc-month {
      font-size: 2.5rem;
    }
  }
  @media (max-height: 600px) {
    .dc-month {
      font-size: 1.75rem;
    }
  }

  .dc-year {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.5);
    font-weight: 600;
  }
  @media (min-width: 900px) {
    .dc-year {
      font-size: 1.5rem;
    }
  }

  .dc-event-list {
    flex: 1;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-right: 0.5rem;
    max-height: 35vh; /* Limit height on mobile */
  }
  @media (min-width: 900px) {
    .dc-event-list {
      max-height: none;
      gap: 1rem;
    }
  }
  @media (min-width: 900px) and (max-height: 600px) {
    .dc-event-list {
      max-height: 40vh; /* keep it scrollable but fit inside modal */
    }
  }

  .dc-event-list::-webkit-scrollbar {
    width: 6px;
  }
  .dc-event-list::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
  }
  .dc-event-list::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.2);
    border-radius: 4px;
  }
  
  .dc-event-item {
    display: flex;
    gap: 1rem;
    padding: 0.75rem 1rem;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease;
    border: 1px solid transparent;
  }
  @media (min-width: 900px) {
    .dc-event-item {
      padding: 1rem;
    }
  }
  @media (max-height: 600px) {
    .dc-event-item {
      padding: 0.5rem 0.75rem;
    }
  }

  .dc-event-item:hover:not(.is-past) {
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.1);
  }
  .dc-event-item.is-past {
    opacity: 0.5;
    cursor: default;
    filter: grayscale(1);
  }
  .dc-event-indicator {
    width: 4px;
    border-radius: 4px;
    flex-shrink: 0;
  }
  .dc-event-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .dc-event-title {
    margin: 0;
    font-size: 0.95rem;
    color: white;
    font-weight: 600;
  }
  @media (min-width: 900px) {
    .dc-event-title { font-size: 1rem; }
  }
  .dc-event-date {
    margin: 0;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
  }
  @media (min-width: 900px) {
    .dc-event-date { font-size: 0.85rem; }
  }

  /* CALENDAR MAIN */
  .dc-main {
    display: flex;
    flex-direction: column;
    min-height: 0;
  }
  .dc-calendar-grid-wrapper {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }
  .dc-calendar-header-row {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    text-align: right;
    font-weight: 700;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    margin-bottom: 0.5rem;
  }
  @media (min-width: 900px) {
    .dc-calendar-header-row {
      font-size: 0.9rem;
      padding-bottom: 1rem;
      margin-bottom: 1rem;
    }
  }

  .dc-calendar-header-row span {
    padding-right: 0.25rem;
  }
  @media (min-width: 900px) {
    .dc-calendar-header-row span { padding-right: 0.5rem; }
  }

  .dc-calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    grid-auto-rows: minmax(45px, 1fr); /* Small mini calendar for mobile */
    gap: 1px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    flex: 1;
    overflow-y: auto;
    position: relative;
  }
  @media (min-width: 900px) {
    .dc-calendar-grid {
      grid-auto-rows: minmax(100px, 1fr); /* Full size for desktop */
    }
  }
  @media (min-width: 900px) and (max-height: 600px) {
    .dc-calendar-grid {
      grid-auto-rows: minmax(45px, 1fr); /* Shrink rows down for short landscape */
    }
  }

  .dc-calendar-cell {
    background: #111;
    padding: 0.25rem;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    border-right: 1px solid rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  @media (min-width: 900px) {
    .dc-calendar-cell { padding: 0.5rem; }
  }

  .dc-calendar-cell.empty {
    background: rgba(255, 255, 255, 0.02);
  }
  .dc-day-number {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.8);
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  @media (min-width: 900px) {
    .dc-day-number {
      font-size: 1rem;
      margin-bottom: 0.5rem;
    }
  }

  /* HIGHLIGHTER BARS */
  .dc-highlighter-bar {
    position: relative;
    z-index: 10;
    margin-top: calc(1.25rem + (var(--overlap-index, 0) * 8px)); /* Tightly packed for mobile */
    height: 6px; /* Thin bars for mobile view */
    background: var(--bar-color);
    color: transparent; /* Hide text on mobile */
    font-size: 0;
    font-weight: 700;
    text-decoration: none;
    display: flex;
    align-items: center;
    padding: 0;
    box-sizing: border-box;
    cursor: default; /* Not meant to be clicked on mobile */
    overflow: hidden;
    white-space: nowrap;
    transition: filter 0.2s, transform 0.1s;
    border-radius: 4px;
    margin-left: 2px;
    margin-right: 2px;
  }
  @media (min-width: 900px) {
    .dc-highlighter-bar {
      margin-top: calc(2rem + (var(--overlap-index, 0) * 26px));
      height: 22px;
      color: white;
      font-size: 0.75rem;
      padding: 0 0.5rem;
      cursor: pointer;
    }
  }
  @media (min-width: 900px) and (max-height: 600px) {
    .dc-highlighter-bar {
      margin-top: calc(1.25rem + (var(--overlap-index, 0) * 8px)); /* Tightly packed for landscape */
      height: 6px; /* Thin bars */
      color: transparent; /* Hide text */
      font-size: 0;
      padding: 0;
      cursor: pointer; /* Keep clickable on desktop */
    }
  }
  .dc-highlighter-bar.is-start {
    border-top-left-radius: 4px;
    border-bottom-left-radius: 4px;
    margin-left: 4px;
  }
  .dc-highlighter-bar.is-end {
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
    margin-right: 4px;
  }
  .dc-highlighter-bar:hover {
    filter: brightness(1.2);
    z-index: 20;
  }
  .dc-highlighter-bar.is-past {
    background: rgba(255, 255, 255, 0.1) !important;
    color: rgba(255, 255, 255, 0.4);
    cursor: default;
  }
  .dc-bar-label {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .dc-bar-cont {
    margin-right: 4px;
    opacity: 0.7;
  }
</style>
