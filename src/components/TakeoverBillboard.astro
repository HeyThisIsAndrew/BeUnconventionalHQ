---
/**
 * Takeover Billboard (issue #20) — the homepage's "we are LIVE" state.
 *
 * Progressive enhancement: this renders into the static HTML `hidden` and only
 * reveals when /api/live-status.json reports an active stream. Every failure
 * mode — endpoint not deployed yet, API key not configured, quota exhausted,
 * network error — leaves the page exactly as it is today. Ship-safe before
 * credentials exist.
 *
 * Playback reuses the site's global video modal (Layout's #video-modal via the
 * .video-modal-trigger delegation); the script injects the live videoId before
 * revealing. A "Watch on YouTube" link is populated as the escape hatch for
 * streams that disallow embedding.
 */
---

<section
  id="takeover-billboard"
  class="tb-container"
  hidden
  aria-live="polite"
  aria-label="Live broadcast announcement"
>
  <div class="tb-banner">
    <div class="tb-overlay"></div>
    <div class="tb-content">
      <p class="tb-kicker">
        <span class="tb-live-dot" aria-hidden="true"></span>
        Live Right Now
      </p>
      <h2 class="tb-title">We're live!</h2>
      <div class="tb-actions">
        <button class="cta-button-primary video-modal-trigger" data-video-id="">
          Watch The Stream
        </button>
        <a class="tb-external" href="#" target="_blank" rel="noopener noreferrer">
          Watch on YouTube →
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .tb-container {
    max-width: 1536px;
    margin: 3rem auto 0;
    padding: 0 2rem;
  }

  .tb-banner {
    position: relative;
    min-height: 320px;
    background-color: #111;
    background-size: cover;
    background-position: center;
    border: 1px solid rgba(204, 0, 0, 0.6);
    display: flex;
    align-items: center;
    overflow: hidden;
    /* The takeover glow — this banner only ever exists while live. */
    box-shadow:
      0 0 35px rgba(204, 0, 0, 0.45),
      0 20px 40px rgba(0, 0, 0, 0.4);
    animation: tb-glow 2.5s ease-in-out infinite alternate;
  }
  @keyframes tb-glow {
    from {
      box-shadow:
        0 0 25px rgba(204, 0, 0, 0.35),
        0 20px 40px rgba(0, 0, 0, 0.4);
    }
    to {
      box-shadow:
        0 0 50px rgba(204, 0, 0, 0.65),
        0 20px 40px rgba(0, 0, 0, 0.4);
    }
  }

  .tb-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.92) 0%,
      rgba(0, 0, 0, 0.45) 60%,
      transparent 100%
    );
  }

  .tb-content {
    position: relative;
    z-index: 2;
    padding: 2.5rem 3rem;
    max-width: 640px;
  }

  .tb-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-accent, #cc0000);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin: 0 0 1rem;
  }
  .tb-live-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-accent, #cc0000);
    animation: tb-pulse 1.4s ease-in-out infinite;
  }
  @keyframes tb-pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.45;
      transform: scale(0.8);
    }
  }

  .tb-title {
    font-family: var(--font-display, 'Syne Variable', sans-serif);
    font-size: clamp(1.75rem, calc(1rem + 2vw), 2.75rem);
    font-weight: 800;
    line-height: 1.15;
    margin: 0 0 1.75rem;
    color: white;
  }

  .tb-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .tb-external {
    color: var(--color-white-muted, #aaa);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: color 0.2s ease;
  }
  .tb-external:hover,
  .tb-external:focus-visible {
    color: white;
  }

  @media (prefers-reduced-motion: reduce) {
    .tb-banner {
      animation: none;
    }
    .tb-live-dot {
      animation: none;
    }
  }

  @media (max-width: 768px) {
    .tb-banner {
      min-height: 380px;
      align-items: flex-end;
    }
    .tb-overlay {
      background: linear-gradient(
        to top,
        rgba(0, 0, 0, 0.92) 0%,
        rgba(0, 0, 0, 0.45) 100%
      );
    }
    .tb-content {
      padding: 2rem;
    }
  }
</style>

<script>
  // Reveal the billboard only when the edge endpoint reports a live stream.
  // Any failure (endpoint 404 before the worker is deployed, key missing,
  // network error, malformed body) leaves the billboard hidden — the static
  // page is the fallback state.
  async function checkTakeover() {
    const billboard = document.getElementById('takeover-billboard');
    if (!billboard) return;

    try {
      const res = await fetch('/api/live-status.json');
      if (!res.ok) return;
      const status = await res.json();
      const stream =
        status?.streams?.find?.((s: any) => s.platform === 'youtube') ??
        status?.streams?.[0];
      if (!status?.isLive || !stream?.videoId) return;

      const title = billboard.querySelector('.tb-title');
      if (title && stream.title) title.textContent = stream.title;

      const trigger = billboard.querySelector('.video-modal-trigger');
      if (trigger) trigger.setAttribute('data-video-id', stream.videoId);

      const external = billboard.querySelector<HTMLAnchorElement>('.tb-external');
      if (external && stream.url) external.href = stream.url;

      // Live thumbnail as the banner art (YouTube serves a frame for live IDs).
      const banner = billboard.querySelector<HTMLElement>('.tb-banner');
      if (banner) {
        banner.style.backgroundImage = `url(https://i.ytimg.com/vi/${stream.videoId}/maxresdefault.jpg)`;
      }

      billboard.hidden = false;
    } catch {
      // Dormant by design on any failure.
    }
  }

  document.addEventListener('astro:page-load', checkTakeover);
</script>
