---
const currentPath = Astro.url.pathname;
const navItems = [
  { label: 'Videos', href: 'videos' },
  { label: 'Articles', href: 'articles' },
  { label: 'Feed', href: 'feed' },
  { label: 'Events', href: 'events' },
  { label: 'About', href: 'about' },
  { label: 'Contact', href: 'contact', className: 'cta' },
];

const isActive = (href) =>
  currentPath === `/${href}` || currentPath === `/${href}/`;
---

<header id="navbar">
  <div class="container nav-inner">
  <a href={`/`} class="nav-logo">
    <img src={`/logo.png`} alt="Be Unconventional HQ" />
  </a>

  <!-- Mobile Toggle -->
  <button class="nav-toggle" aria-label="Toggle Menu" aria-expanded="false">
    <span class="line line-1"></span>
    <span class="line line-2"></span>
    <span class="line line-3"></span>
  </button>

  <div class="nav-identity-wrapper">
    <div class="nav-identity-stack">
      <span class="nav-word-be">Be</span>
      <span class="nav-word-unconventional">Unconventional</span>
      <span class="nav-word-hq">HQ</span>
    </div>
    <div class="nav-subline" id="nav-subline">
      {
        currentPath.includes('videos')
          ? 'Cinematic Vault'
          : currentPath.includes('articles')
            ? 'Editorial Feed'
            : currentPath.includes('feed')
              ? 'All Content'
              : currentPath.includes('category/movies')
                ? 'Film Archive'
                : currentPath.includes('category/tv')
                  ? 'Streaming Hub'
                  : currentPath.includes('category/gaming')
                    ? 'Interactive Media'
                    : currentPath.includes('about')
                      ? 'The Story'
                      : currentPath.includes('contact')
                        ? 'Direct Line'
                        : currentPath.includes('events')
                          ? 'Live Coverage'
                          : 'Media Hub'
      }
    </div>
  </div>

  <nav class="nav-container">
    <ul class="nav-list">
      {
        navItems.map((item) => (
          <li class="nav-item">
            <a
              href={`/${item.href}`}
              class:list={[item.className, { active: isActive(item.href) }]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar');
  const toggle = document.querySelector('.nav-toggle');

  if (navbar && toggle) {
    // Scroll handling
    window.addEventListener('scroll', () => {
      if (window.scrollY > 60) {
        navbar.classList.add('scrolled');
      } else {
        navbar.classList.remove('scrolled');
      }
    });

    // Mobile menu toggle
    toggle.addEventListener('click', () => {
      const isOpened = navbar.classList.contains('menu-open');
      if (isOpened) {
        navbar.classList.remove('menu-open');
        toggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      } else {
        navbar.classList.add('menu-open');
        toggle.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }
    });

    // Close menu on link click
    const navLinks = navbar.querySelectorAll('.nav-list a');
    navLinks.forEach((link) => {
      link.addEventListener('click', () => {
        navbar.classList.remove('menu-open');
        toggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      });
    });
  }
</script>
