---
const currentPath = Astro.url.pathname;
const navItems = [
  { label: 'Videos', href: 'videos' },
  { label: 'Articles', href: 'articles' },
  { label: 'Feed', href: 'feed' },
  { label: 'Events', href: 'events' },
  { label: 'About', href: 'about' },
  { label: 'Contact', href: 'contact', className: 'cta' },
];

const isActive = (href) =>
  currentPath === `/${href}` || currentPath === `/${href}/`;
---

<header id="navbar">
  <div class="container nav-inner">
    <div class="nav-brand-group">
      <a href="/" class="nav-logo">
        <img src="/logo.png" alt="Be Unconventional HQ" />
      </a>
      <a
        href="#"
        class="nav-identity-wrapper"
        id="nav-identity"
        style="transform: translateY(-10px) scale(0.95); pointer-events: none; transition: opacity 0.4s ease, transform 0.4s ease; display: flex; flex-direction: column; align-items: center; justify-content: center; margin-left: 1rem; text-decoration: none; cursor: pointer;"
      >
        <div class="nav-identity-stack">
          <span class="nav-word-be">BE</span>
          <span class="nav-word-unconventional">UNCONVENTIONAL</span>
          <span class="nav-word-hq">HQ</span>
        </div>
        <div class="nav-subline" id="nav-subline"></div>
      </a>
    </div>
    <button class="nav-toggle" aria-label="Toggle Menu" aria-expanded="false">
      <span class="line line-1"></span><span class="line line-2"></span><span
        class="line line-3"></span>
    </button>
    <nav class="nav-container">
      <ul class="nav-list">
        {
          navItems.map((item) => (
            <li class="nav-item">
              <a
                href={`/${item.href}`}
                class:list={[item.className, { active: isActive(item.href) }]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    function initNavObserver() {
      const identity = document.getElementById('nav-identity');
      const sublineEl = document.getElementById('nav-subline');
      if (!identity) return;

      // 1. Dynamic Red Subline
      const path = window.location.pathname;
      let subtext = '';
      if (path.includes('videos')) subtext = 'VIDEOS';
      else if (path.includes('articles')) subtext = 'ARTICLES';
      else if (path.includes('category')) subtext = 'HUB';
      else if (path.includes('about')) subtext = 'ABOUT';
      else if (path.includes('contact')) subtext = 'CONTACT';

      if (sublineEl) {
        sublineEl.textContent = subtext;
        sublineEl.style.display = subtext ? 'inline-block' : 'none';
      }

      // 2. Smooth Scroll to Top
      identity.addEventListener('click', (e) => {
        e.preventDefault();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      // 3. IntersectionObserver Logic
      // If we are on a subpage (no Hero), show it by default after scrolling down slightly
      const heroText = document.querySelector('.hero-title-stack');

      if (heroText) {
        // We are on the homepage. Watch the Hero text.
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) {
                // Hero text left the screen -> Show Navbar text
                identity.style.opacity = '1';
                identity.style.transform = 'translateY(0) scale(1)';
                identity.style.pointerEvents = 'auto';
              } else {
                // Hero text is on screen -> Hide Navbar text
                identity.style.opacity = '0';
                identity.style.transform = 'translateY(-10px) scale(0.95)';
                identity.style.pointerEvents = 'none';
              }
            });
          },
          { rootMargin: '-80px 0px 0px 0px' }
        ); // Offset for the navbar height

        observer.observe(heroText);
      } else {
        // We are on a subpage. Fallback to basic scroll threshold.
        window.addEventListener(
          'scroll',
          () => {
            const scroll = window.scrollY || document.documentElement.scrollTop;
            if (scroll > 100) {
              identity.style.opacity = '1';
              identity.style.transform = 'translateY(0) scale(1)';
              identity.style.pointerEvents = 'auto';
            } else {
              identity.style.opacity = '0';
              identity.style.transform = 'translateY(-10px) scale(0.95)';
              identity.style.pointerEvents = 'none';
            }
          },
          { passive: true }
        );
      }
    }

    initNavObserver();
    document.addEventListener('astro:page-load', initNavObserver);
  })();

  (function () {
    const ScrollLock = {
      elementToScroll: null,
      handleTouchMove(e) {
        if (!ScrollLock.elementToScroll) return;
        const target = e.target;
        const isScrollable = target.closest('.scroll-lock-allow');
        if (!isScrollable) {
          if (e.cancelable) e.preventDefault();
          return;
        }
        const el = ScrollLock.elementToScroll;
        if (el.scrollTop <= 0) el.scrollTop = 1;
        if (el.scrollTop + el.offsetHeight >= el.scrollHeight) el.scrollTop = el.scrollHeight - el.offsetHeight - 1;
      },
      lock(el) {
        this.elementToScroll = el;
        el.classList.add('scroll-lock-allow');
        document.documentElement.classList.add('menu-open');
        window.addEventListener('touchmove', this.handleTouchMove, { passive: false });
      },
      unlock() {
        if (this.elementToScroll) this.elementToScroll.classList.remove('scroll-lock-allow');
        this.elementToScroll = null;
        document.documentElement.classList.remove('menu-open');
        window.removeEventListener('touchmove', this.handleTouchMove);
      }
    };

    function initMobileMenu() {
      const navbar = document.getElementById('navbar');
      const toggle = document.querySelector('.nav-toggle');
      const navContainer = document.querySelector('.nav-container');

      if (navbar && toggle && navContainer) {
        const newToggle = toggle.cloneNode(true);
        toggle.parentNode.replaceChild(newToggle, toggle);

        newToggle.addEventListener('click', () => {
          const isOpened = navbar.classList.contains('menu-open');
          if (isOpened) {
            navbar.classList.remove('menu-open');
            ScrollLock.unlock();
            newToggle.setAttribute('aria-expanded', 'false');
          } else {
            navbar.classList.add('menu-open');
            ScrollLock.lock(navContainer);
            newToggle.setAttribute('aria-expanded', 'true');
          }
        });

        const navLinks = navbar.querySelectorAll('.nav-list a');
        navLinks.forEach((link) => {
          link.addEventListener('click', () => {
            navbar.classList.remove('menu-open');
            ScrollLock.unlock();
            newToggle.setAttribute('aria-expanded', 'false');
          });
        });
      }
    }

    initMobileMenu();
    document.addEventListener('astro:page-load', initMobileMenu);
  })();
</script>
