---
import ContentCard from './ContentCard.astro';
import Pagination from './Pagination.astro';

export interface Props {
  page: any;
  allItems: any[];
}

const { page, allItems } = Astro.props;
const currentItems = page.data;
---

<script is:inline>
  if (typeof window !== 'undefined' && window.location.hash) {
    document.documentElement.classList.add('js-feed-filtering');
  }
</script>
<style>
  html.js-feed-filtering #feed-grid-wrapper {
    opacity: 0 !important;
  }
</style>
<div id="feed-grid-wrapper" style="width: 100%; clear: both; transition: opacity 0.2s ease;">
{currentItems.length > 0 ? (
  <div id="feed-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 w-full max-w-screen-2xl mx-auto px-4 md:px-8">
    {
      currentItems.map((item: any, index: number) => (
        <ContentCard item={item} index={index} />
      ))
    }
  </div>
) : (
  <div id="feed-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 w-full max-w-screen-2xl mx-auto px-4 md:px-8">
    <div class="col-span-full flex flex-col items-center justify-center text-center py-32 text-white/70 gap-8" style="min-height: 40vh;">
      <svg class="w-16 h-16 text-white/20" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
      </svg>
      <p class="text-2xl font-display font-bold tracking-widest uppercase mt-4">No content found.</p>
      <a href="/feed" class="cta-button-primary mt-2" style="padding: 0.75rem 2.5rem; font-size: 1rem;">
        View All Content
      </a>
    </div>
  </div>
)}
</div>

<template id="full-dataset-cards">
  {allItems.map((item: any, index: number) => (
    <ContentCard item={item} index={index} />
  ))}
</template>

{currentItems.length > 0 && (
  <div class="mt-auto w-full max-w-screen-2xl mx-auto px-4 md:px-8" style="padding-top: 3.5rem;">
    <div id="standard-pagination">
      <Pagination page={page} />
    </div>
    <div id="load-more-container" style="display: none;" class="text-center w-full">
      <button id="load-more-btn" class="cta-button-primary" style="margin: 0 auto; position: relative; z-index: 10;">
        Load More
      </button>
    </div>
  </div>
)}



<script>
  function initFeedClientFiltering() {
    const isFeedPage = window.location.pathname.startsWith('/feed');
    if (!isFeedPage) return;

    const feedGrid = document.getElementById('feed-grid');
    const template = document.getElementById('full-dataset-cards') as HTMLTemplateElement;
    const standardPagination = document.getElementById('standard-pagination');
    const loadMoreContainer = document.getElementById('load-more-container');
    const loadMoreBtn = document.getElementById('load-more-btn');
    const categoryBtns = document.querySelectorAll('.cat-btn');
    const typeBtns = document.querySelectorAll('.type-btn');
    const openCategoriesBtn = document.getElementById('open-categories-btn');
    const paginationLinks = document.querySelectorAll('.pagination-number, .pagination-arrow');

    if (!feedGrid || !template) return;

    // Save initial static HTML if not saved yet so we can restore it on clear filter
    if (!feedGrid.dataset.originalHtml) {
      feedGrid.dataset.originalHtml = feedGrid.innerHTML;
    }

    let currentMatches: HTMLElement[] = [];
    let currentlyDisplayedCount = 0;
    let hasFiltered = false;
    const PAGE_SIZE = 12;

    function renderMoreItems() {
      const fragment = document.createDocumentFragment();
      const nextBatch = currentMatches.slice(currentlyDisplayedCount, currentlyDisplayedCount + PAGE_SIZE);
      
      nextBatch.forEach((node, index) => {
        node.style.display = 'flex'; 
        // Force the reveal animation state so the observer isn't needed
        node.setAttribute('data-state', 'in');
        node.style.opacity = '1';
        node.style.transform = 'none';
        
        // Re-calculate animation delays based on index in current batch
        node.style.transitionDelay = (index * 100) + 'ms';
        node.setAttribute('data-delay', (index * 100).toString());
        
        // Clear the delay after the entrance animation finishes
        setTimeout(() => {
          if (node) node.style.transitionDelay = '';
        }, (index * 100) + 600);
        
        fragment.appendChild(node);
      });

      feedGrid?.appendChild(fragment);
      currentlyDisplayedCount += nextBatch.length;

      if (loadMoreContainer) {
        if (currentlyDisplayedCount < currentMatches.length) {
          loadMoreContainer.style.display = 'block';
        } else {
          loadMoreContainer.style.display = 'none';
        }
      }
    }

    function applyFilters() {
      const hash = window.location.hash.replace('#', '').toLowerCase();

      // Maintain hash on Type filter buttons
      typeBtns.forEach(btn => {
        if (!btn.hasAttribute('data-base-href')) {
          btn.setAttribute('data-base-href', btn.getAttribute('href') || '');
        }
        const baseHref = btn.getAttribute('data-base-href');
        if (hash) {
          btn.setAttribute('href', `${baseHref}#${hash}`);
        } else {
          btn.setAttribute('href', baseHref || '');
        }
      });

      // Maintain hash on Pagination links
      paginationLinks.forEach(link => {
        if (!link.hasAttribute('data-base-href') && link.hasAttribute('href')) {
          link.setAttribute('data-base-href', link.getAttribute('href') || '');
        }
        const baseHref = link.getAttribute('data-base-href');
        if (baseHref) {
          if (hash) {
            link.setAttribute('href', `${baseHref}#${hash}`);
          } else {
            link.setAttribute('href', baseHref);
          }
        }
      });

      // Update Category Buttons Active State
      categoryBtns.forEach((btn) => {
        const btnCategory = btn.getAttribute('data-category');
        if (hash && btnCategory === hash) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });

      // Update Mobile button state
      if (openCategoriesBtn) {
        if (hash) {
          const activeBtn = Array.from(categoryBtns).find(btn => btn.getAttribute('data-category') === hash);
          if (activeBtn) {
            openCategoriesBtn.textContent = `Categories | ${activeBtn.textContent?.trim()}`;
            openCategoriesBtn.classList.add('active');
          }
        } else {
          openCategoriesBtn.textContent = 'Categories';
          openCategoriesBtn.classList.remove('active');
        }
      }

      if (!hash) {
        // If we haven't filtered yet, the DOM is perfectly intact from Astro.
        if (!hasFiltered) return;

        // Reset State
        if (feedGrid) {
          feedGrid.innerHTML = feedGrid.dataset.originalHtml || '';
          // Ensure restored cards become visible since the original observer is gone
          const restoredCards = feedGrid.querySelectorAll('.reveal');
          restoredCards.forEach((node: any, index: number) => {
            node.setAttribute('data-state', 'in');
            node.style.opacity = '1';
            node.style.transform = 'none';
            node.style.transitionDelay = (index * 50) + 'ms';
            
            setTimeout(() => {
              if (node) node.style.transitionDelay = '';
            }, (index * 50) + 600);
          });
        }
        if (standardPagination) standardPagination.style.display = '';
        if (loadMoreContainer) loadMoreContainer.style.display = 'none';
        return;
      }

      hasFiltered = true;

      // Hide standard pagination
      if (standardPagination) {
        standardPagination.style.display = 'none';
      }

      // Filter elements from the full dataset template
      const allCards = template.content.querySelectorAll('.content-card');
      currentMatches = [];
      currentlyDisplayedCount = 0;

      allCards.forEach(card => {
        const categoriesAttr = card.getAttribute('data-categories') || '';
        const categories = categoriesAttr.split(',');
        if (categories.includes(hash)) {
          currentMatches.push(card.cloneNode(true) as HTMLElement);
        }
      });

      // Clear current grid
      if (feedGrid) {
        feedGrid.innerHTML = '';
        if (currentMatches.length === 0) {
          feedGrid.innerHTML = `
            <div class="col-span-full flex flex-col items-center justify-center text-center py-32 text-white/70 gap-8" style="min-height: 40vh;">
              <svg class="w-16 h-16 text-white/20" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
              </svg>
              <p class="text-2xl font-display font-bold tracking-widest uppercase mt-4">No items found for this filter.</p>
              <button onclick="window.history.pushState(null, '', '/feed'); window.dispatchEvent(new Event('hashchange'));" class="cta-button-primary mt-2" style="padding: 0.75rem 2.5rem; font-size: 1rem;">
                Clear Filters
              </button>
            </div>
          `;
          if (loadMoreContainer) loadMoreContainer.style.display = 'none';
        } else {
          renderMoreItems();
        }
      }
    }

    if (loadMoreBtn && !loadMoreBtn.dataset.bound) {
      loadMoreBtn.addEventListener('click', renderMoreItems);
      loadMoreBtn.dataset.bound = 'true';
    }

    // Attach click listeners to category buttons for smooth hash updates without scrolling
    categoryBtns.forEach((btn) => {
      if (!(btn as any).dataset.feedBound) {
        btn.addEventListener('click', (e) => {
          const hrefAttr = btn.getAttribute('href');
          if (hrefAttr && hrefAttr.startsWith('#')) {
            e.preventDefault();
            const category = btn.getAttribute('data-category');
            const currentHash = window.location.hash.replace('#', '').toLowerCase();
            
            if (currentHash === category) {
              history.pushState(null, '', '/feed'); // Toggle off
            } else {
              history.pushState(null, '', `/feed#${category}`); // Toggle on
            }
            applyFilters();
          }
        });
        (btn as any).dataset.feedBound = 'true';
      }
    });

    if ((window as any)._feedHashChangeListener) {
      window.removeEventListener('hashchange', (window as any)._feedHashChangeListener);
    }
    (window as any)._feedHashChangeListener = applyFilters;
    window.addEventListener('hashchange', applyFilters);
    
    // Initial execution on load
    applyFilters();
    document.documentElement.classList.remove('js-feed-filtering');
  }

  document.addEventListener('astro:page-load', initFeedClientFiltering);
</script>
