---
export interface Props {
  events: any[];
}
const { events } = Astro.props;

// Current month/year for the top-right period label.
const today = new Date();
const periodLabel = today.toLocaleString('en-US', { month: 'long', year: 'numeric' });

// Get top 3 upcoming events for the sidebar
const topEvents = events.slice(0, 3);
---

<div class="mini-calendar-wrapper animate-on-scroll">
  {/* No "Calendar" label — the widget speaks for itself. Just the formatted
      month/year, pinned top-right. */}
  <div class="mini-cal-topbar">
    <span class="mini-cal-period">{periodLabel}</span>
  </div>

  <div class="calendar-events-list">
    {topEvents.length > 0 ? topEvents.map(event => {
      const start = new Date(event.startDate);
      const end = event.endDate ? new Date(event.endDate) : start;
      const monthShort = start.toLocaleString('en-US', { month: 'short' });
      const dateLabel = start.getDate() === end.getDate()
        ? `${monthShort} ${start.getDate()}`
        : `${monthShort} ${start.getDate()}–${end.getDate()}`;

      return (
        <a href={`/events/${event.slug.current}`} class="mini-event-row">
          <span class="mini-meta">
            <span class="mini-tag">Event</span>
            <span class="mini-dot" aria-hidden="true">&bull;</span>
            <span class="mini-dates">{dateLabel}</span>
          </span>
          <span class="mini-title">{event.title}</span>
        </a>
      );
    }) : (
      <p class="mini-empty">No upcoming events this month.</p>
    )}
  </div>

  <button class="open-full-calendar-btn" id="open-calendar-btn">
    View Full Calendar
  </button>
</div>

<style>
  .mini-calendar-wrapper {
    background: rgba(15, 15, 15, 0.8);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 1.5rem;
    /* Follows the page as you scroll the timeline, then releases at the bottom
       of its column. top offset clears the fixed navbar (~1.25rem padding). */
    position: sticky;
    top: 100px;
  }

  /* Month/year pinned top-right with an accent underline for weight. */
  .mini-cal-topbar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 1.75rem;
  }

  .mini-cal-period {
    font-family: var(--font-display, 'Syne Variable', sans-serif);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-white, #f0f0f0);
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--color-accent, #cc0000);
  }

  .calendar-events-list {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    margin-bottom: 2rem;
  }

  .mini-event-row {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    text-decoration: none;
  }

  /* Meta line: "EVENT • Jul 24–26" — matches the card meta pattern. */
  .mini-meta {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.7rem;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .mini-tag {
    color: var(--color-accent, #cc0000);
    font-weight: 700;
  }
  .mini-dot {
    color: #666;
  }
  .mini-dates {
    color: #888;
    font-weight: 600;
  }

  /* Title: white by default, transitions to red with a left-to-right underline
     drawn in on hover/focus. */
  .mini-title {
    position: relative;
    align-self: flex-start;
    display: inline-block;
    font-family: var(--font-display, 'Syne Variable', sans-serif);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-white, #f0f0f0);
    transition: color 0.3s ease;
  }
  .mini-title::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -3px;
    width: 100%;
    height: 2px;
    background: var(--color-accent, #cc0000);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s ease;
  }
  .mini-event-row:hover .mini-title,
  .mini-event-row:focus-visible .mini-title {
    color: var(--color-accent, #cc0000);
  }
  .mini-event-row:hover .mini-title::after,
  .mini-event-row:focus-visible .mini-title::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .mini-empty {
    color: #888;
    font-size: 0.9rem;
  }

  .open-full-calendar-btn {
    width: 100%;
    padding: 1rem;
    background: transparent;
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .open-full-calendar-btn:hover {
    background: rgba(204, 0, 0, 0.1);
    border-color: var(--color-accent, #cc0000);
    color: var(--color-accent, #cc0000);
  }
</style>
