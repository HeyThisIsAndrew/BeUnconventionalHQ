---
export interface Props {
  events: any[];
}
const { events } = Astro.props;

// Get current month
const today = new Date();
const monthLabel = today.toLocaleString('en-US', { month: 'long' });
const yearLabel = today.getFullYear().toString();

// Get top 3 upcoming events for the sidebar
const topEvents = events.slice(0, 3);
---

<div class="mini-calendar-wrapper animate-on-scroll">
  {/* Custom, fixed-rem header sized for the 300px column. The global PageTitle
      uses vw-based clamps that break out of a constrained sidebar, so this is a
      localised, high-contrast lockup: kicker + overlapping month/year. */}
  <div class="mini-cal-header">
    <span class="mini-cal-kicker">Calendar</span>
    <div class="mini-cal-lockup">
      <span class="mini-cal-month">{monthLabel}</span>
      <span class="mini-cal-year">{yearLabel}</span>
    </div>
  </div>
  
  <div class="calendar-events-list">
    {topEvents.length > 0 ? topEvents.map(event => {
      const start = new Date(event.startDate);
      const end = event.endDate ? new Date(event.endDate) : start;
      const dayStr = start.getDate() === end.getDate() ? `${start.getDate()}` : `${start.getDate()}-${end.getDate()}`;
      
      return (
        <a href={`/events/${event.slug.current}`} class="mini-event-row">
          <span class="mini-date">{start.toLocaleString('en-US', { month: 'short' })} {dayStr}</span>
          <span class="mini-title">{event.title}</span>
        </a>
      );
    }) : (
      <p style="color:#888; font-size:0.9rem;">No upcoming events this month.</p>
    )}
  </div>
  
  <button class="open-full-calendar-btn" id="open-calendar-btn">
    View Full Calendar
  </button>
</div>

<style>
  .mini-calendar-wrapper {
    background: rgba(15, 15, 15, 0.8);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 1.5rem;
    position: relative;
    /* removed sticky positioning so it floats naturally with document scroll */
  }
  
  /* Localised header — fixed rem sizing tuned for the 300px column. */
  .mini-cal-header {
    margin-bottom: 1.75rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .mini-cal-kicker {
    display: block;
    font-family: var(--font-display, 'Syne Variable', sans-serif);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-accent, #cc0000);
    margin-bottom: 0.35rem;
  }

  .mini-cal-lockup {
    display: flex;
    flex-direction: column;
    line-height: 0.82;
    font-family: var(--font-display, 'Syne Variable', sans-serif);
    text-transform: uppercase;
  }

  .mini-cal-month {
    font-size: 2.25rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: white;
  }

  .mini-cal-year {
    /* Overlaps up under the month for the unconventional stacked lockup. */
    align-self: flex-end;
    margin-top: -0.15rem;
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: var(--color-accent, #cc0000);
    text-shadow: 0 0 20px rgba(204, 0, 0, 0.4);
  }

  .calendar-events-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  
  .mini-event-row {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  
  .mini-event-row:hover .mini-title {
    color: var(--color-accent, #cc0000);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  
  .mini-event-row:hover .mini-date {
    color: white;
  }
  
  .mini-date {
    font-size: 0.8rem;
    color: var(--color-accent, #cc0000);
    font-weight: 700;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }
  
  .mini-title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
    color: white;
  }
  
  .open-full-calendar-btn {
    width: 100%;
    padding: 1rem;
    background: transparent;
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .open-full-calendar-btn:hover {
    background: rgba(204, 0, 0, 0.1);
    border-color: var(--color-accent, #cc0000);
    color: var(--color-accent, #cc0000);
  }
</style>
