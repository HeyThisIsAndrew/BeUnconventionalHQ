---
// ARCHITECTURAL LEDGER: STATIC CHILD COMPONENT
// This component is designed to be a "dumb," static block element. It MUST NOT
// contain any internal `sticky`, `absolute`, or `fixed` positioning classes.
// All complex layout physics (like making the sidebar scroll with the page)
// are deferred to and handled by its parent wrapper in the page layout
// (e.g., `src/pages/events-new.astro`). This strict separation of concerns
// ensures this component is reusable and prevents conflicting or unpredictable
// scroll behaviors.
import { formatEventDateRange } from "../lib/events";

export interface Props {
  events: any[];
}
const { events } = Astro.props;

// Get top 3 upcoming events for the sidebar
const topEvents = events.slice(0, 3);
---

<div class="mini-calendar-wrapper animate-on-scroll">
  <div class="mini-cal-topbar">
    <!-- Static, thematic header replacing the dynamic month. -->
    <span class="mini-cal-header-title">Upcoming</span>
  </div>

  <div class="calendar-events-list">
    {topEvents.length > 0 ? topEvents.map(event => {
      if (!event.startDate) return null;
      // year:false -> "Jul 22–26"; also renders cross-month ranges correctly
      // ("Jul 30 – Aug 2") instead of the old "Jul 30–2".
      const dateLabel = formatEventDateRange(event.startDate, event.endDate, { year: false });

      return (
        <a href={`/events-new/${event.slug.current}`} class="mini-event-row">
          <span class="mini-event-name">{event.title}</span>
          <span class="mini-event-dates"><span class="mini-dot" aria-hidden="true">&bull;</span> {dateLabel}</span>
        </a>
      );
    }) : (
      <p class="mini-empty">No upcoming events this month.</p>
    )}
  </div>

  <button class="open-full-calendar-btn" id="open-calendar-btn">
    View Full Calendar
  </button>
</div>

<style>
  .mini-calendar-wrapper {
    background: rgba(15, 15, 15, 0.8);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .mini-cal-topbar {
    display: flex;
    justify-content: flex-start;
    margin-bottom: 2rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .mini-cal-header-title {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #888;
  }

  .calendar-events-list {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    margin-bottom: 2rem;
  }

  /* One line per event: "San Diego Comic Con 2026 • Jul 23–27". The name is the
     emphasis (white → red with a draw-on underline); the dates trail after a
     dot in muted grey. A background-size underline animates even if the name
     wraps to a second line, unlike a scaleX pseudo-element. */
  .mini-event-row {
    display: block;
    text-decoration: none;
    line-height: 1.4;
  }

  .mini-event-name {
    font-family: var(--font-display, 'Syne Variable', sans-serif);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-white, #f0f0f0);
    background-image: linear-gradient(
      var(--color-accent, #cc0000),
      var(--color-accent, #cc0000)
    );
    background-repeat: no-repeat;
    background-position: 0 100%;
    background-size: 0% 2px;
    padding-bottom: 2px;
    transition: color 0.3s ease, background-size 0.3s ease;
  }
  .mini-event-dates {
    font-size: 0.8rem;
    font-weight: 600;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }
  .mini-dot {
    color: #666;
    margin: 0 0.3rem;
  }
  .mini-event-row:hover .mini-event-name,
  .mini-event-row:focus-visible .mini-event-name {
    color: var(--color-accent, #cc0000);
    background-size: 100% 2px;
  }

  .mini-empty {
    color: #888;
    font-size: 0.9rem;
  }

  .open-full-calendar-btn {
    width: 100%;
    padding: 1rem;
    background: transparent;
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .open-full-calendar-btn:hover,
  .open-full-calendar-btn:focus-visible {
    background: rgba(204, 0, 0, 0.1);
    border-color: var(--color-accent, #cc0000);
    color: white;
    box-shadow: 0 0 20px rgba(204, 0, 0, 0.5);
  }
</style>
