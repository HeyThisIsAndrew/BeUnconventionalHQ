---
export interface Props {
  events: any[];
}
const { events } = Astro.props;

// Current month/year for the top-right period label.
const today = new Date();
const periodLabel = today.toLocaleString('en-US', { month: 'long', year: 'numeric' });

// Get top 3 upcoming events for the sidebar
const topEvents = events.slice(0, 3);
---

<div class="mini-calendar-wrapper animate-on-scroll">
  <div class="mini-cal-topbar">
    <span class="mini-cal-period">{periodLabel}</span>
  </div>

  <div class="calendar-events-list">
    {topEvents.length > 0 ? topEvents.map(event => {
      const start = new Date(event.startDate);
      const end = event.endDate ? new Date(event.endDate) : start;
      // UTC so dates don't shift a day back for viewers west of UTC.
      const monthShort = start.toLocaleString('en-US', { timeZone: 'UTC', month: 'short' });
      const dateLabel = start.getUTCDate() === end.getUTCDate()
        ? `${monthShort} ${start.getUTCDate()}`
        : `${monthShort} ${start.getUTCDate()}–${end.getUTCDate()}`;

      return (
        <a href={`/events-new/${event.slug.current}`} class="mini-event-row">
          <span class="mini-event-name">{event.title}</span>
          <span class="mini-event-dates"><span class="mini-dot" aria-hidden="true">&bull;</span> {dateLabel}</span>
        </a>
      );
    }) : (
      <p class="mini-empty">No upcoming events this month.</p>
    )}
  </div>

  <button class="open-full-calendar-btn" id="open-calendar-btn">
    View Full Calendar
  </button>
</div>

<style>
  .mini-calendar-wrapper {
    background: rgba(15, 15, 15, 0.8);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 1.5rem;
    /* The user wants this to 'move down with the page' (follow the viewport).
       In CSS, this is position: sticky. */
    position: sticky;
    top: 120px;
    z-index: 10;
  }

  .mini-cal-topbar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 2rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Removed .mini-cal-kicker completely as requested */

  .mini-cal-period {
    font-size: 1.25rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-white, #f0f0f0);
    /* Right alignment */
    text-align: right;
  }

  .calendar-events-list {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    margin-bottom: 2rem;
  }

  /* One line per event: "San Diego Comic Con 2026 • Jul 23–27". The name is the
     emphasis (white → red with a draw-on underline); the dates trail after a
     dot in muted grey. A background-size underline animates even if the name
     wraps to a second line, unlike a scaleX pseudo-element. */
  .mini-event-row {
    display: block;
    text-decoration: none;
    line-height: 1.4;
  }

  .mini-event-name {
    font-family: var(--font-display, 'Syne Variable', sans-serif);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-white, #f0f0f0);
    background-image: linear-gradient(
      var(--color-accent, #cc0000),
      var(--color-accent, #cc0000)
    );
    background-repeat: no-repeat;
    background-position: 0 100%;
    background-size: 0% 2px;
    padding-bottom: 2px;
    transition: color 0.3s ease, background-size 0.3s ease;
  }
  .mini-event-dates {
    font-size: 0.8rem;
    font-weight: 600;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }
  .mini-dot {
    color: #666;
    margin: 0 0.3rem;
  }
  .mini-event-row:hover .mini-event-name,
  .mini-event-row:focus-visible .mini-event-name {
    color: var(--color-accent, #cc0000);
    background-size: 100% 2px;
  }

  .mini-empty {
    color: #888;
    font-size: 0.9rem;
  }

  .open-full-calendar-btn {
    width: 100%;
    padding: 1rem;
    background: transparent;
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .open-full-calendar-btn:hover {
    background: rgba(204, 0, 0, 0.1);
    border-color: var(--color-accent, #cc0000);
    color: var(--color-accent, #cc0000);
  }
</style>
