---
import PageTitle from './PageTitle.astro';

export interface Props {
  events: any[];
}
const { events } = Astro.props;

// Get current month
const today = new Date();
const currentMonthStr = today.toLocaleString('en-US', { month: 'long', year: 'numeric' });

// Get top 3 upcoming events for the sidebar
const topEvents = events.slice(0, 3);
---

<div class="mini-calendar-wrapper animate-on-scroll">
  <div class="calendar-header" style="justify-content: center; text-align: center; border-bottom: none; margin-bottom: 1.5rem; padding-bottom: 0;">
    <PageTitle 
      as="div" 
      kicker="Calendar"
      primary={today.toLocaleString('en-US', { month: 'long' })} 
      secondary={today.getFullYear().toString()} 
    />
  </div>
  
  <div class="calendar-events-list">
    {topEvents.length > 0 ? topEvents.map(event => {
      const start = new Date(event.startDate);
      const end = event.endDate ? new Date(event.endDate) : start;
      const dayStr = start.getDate() === end.getDate() ? `${start.getDate()}` : `${start.getDate()}-${end.getDate()}`;
      
      return (
        <a href={`/events/${event.slug.current}`} class="mini-event-row">
          <span class="mini-date">{start.toLocaleString('en-US', { month: 'short' })} {dayStr}</span>
          <span class="mini-title">{event.title}</span>
        </a>
      );
    }) : (
      <p style="color:#888; font-size:0.9rem;">No upcoming events this month.</p>
    )}
  </div>
  
  <button class="open-full-calendar-btn" id="open-calendar-btn">
    View Full Calendar
  </button>
</div>

<style>
  .mini-calendar-wrapper {
    background: rgba(15, 15, 15, 0.8);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 1.5rem;
    position: relative;
    /* removed sticky positioning so it floats naturally with document scroll */
  }
  
  .calendar-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    padding-bottom: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .calendar-icon {
    color: var(--color-accent, #cc0000);
    display: flex;
  }
  
  .calendar-events-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  
  .mini-event-row {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  
  .mini-event-row:hover .mini-title {
    color: var(--color-accent, #cc0000);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  
  .mini-event-row:hover .mini-date {
    color: white;
  }
  
  .mini-date {
    font-size: 0.8rem;
    color: var(--color-accent, #cc0000);
    font-weight: 700;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }
  
  .mini-title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
    color: white;
  }
  
  .open-full-calendar-btn {
    width: 100%;
    padding: 1rem;
    background: transparent;
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .open-full-calendar-btn:hover {
    background: rgba(204, 0, 0, 0.1);
    border-color: var(--color-accent, #cc0000);
    color: var(--color-accent, #cc0000);
  }
</style>
