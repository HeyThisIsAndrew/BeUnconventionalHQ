---
import PageTitle from './PageTitle.astro';

export interface Props {
  kicker?: string;
  primary?: string;
  secondary?: string;
  description?: string;
  buttonText?: string;
  buttonLink?: string;
}

const {
  kicker = "Bookings",
  primary = "Want us at",
  secondary = "Your event?",
  description = "We provide cinematic coverage for premieres, conventions, and gaming events.",
  buttonText = "Get in Touch",
  buttonLink = "/contact"
} = Astro.props;
---

{/* Sponsor/Booking CTA */}
<section class="press-kit-section animate-on-scroll">
  <div class="section-header" style="margin-bottom: 2rem;">
    <PageTitle kicker={kicker} primary={primary} secondary={secondary} scale="secondary" />
  </div>
  <p class="press-kit-desc" style="max-width: 600px; margin: 0 auto 2rem; color: #a0a0a0;">
    {description}
  </p>
  <a href={buttonLink} class="cta-button-primary" data-modal-trigger={buttonLink === "/contact" ? "contact" : undefined}>{buttonText}</a>
</section>

<style>
  /* This style is added to enforce the brand's cinematic hover glow,
     resolving an inconsistency on the new event pages. */
  .cta-button-primary:hover,
  .cta-button-primary:focus-visible {
    box-shadow: 0 0 25px rgba(204, 0, 0, 0.5);
  }
</style>
