---
import PageTitle from './PageTitle.astro';
---

{/* Sponsor/Booking CTA */}
<section class="press-kit-section animate-on-scroll" style="margin-top: 8rem; margin-bottom: 6rem; text-align: center;">
  <div class="section-header" style="margin-bottom: 2rem;">
    <PageTitle kicker="Bookings" primary="Want us at" secondary="Your event?" scale="secondary" />
  </div>
  <p class="press-kit-desc" style="max-width: 600px; margin: 0 auto 2rem; color: #a0a0a0;">
    We provide cinematic coverage for premieres, conventions, and gaming events.
  </p>
  <a href="/contact" class="cta-button-primary" data-modal-trigger="contact">Get in Touch</a>
</section>
