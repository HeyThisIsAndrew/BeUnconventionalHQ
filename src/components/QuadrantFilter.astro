    */

    /* =========================================================================
       NEW FULL-SCREEN IMMERSIVE LOGIC
       ========================================================================= */
    const overlay = document.getElementById('category-fullscreen-overlay');
    const openBtn = document.getElementById('open-categories-btn');
    const closeBtn = document.getElementById('close-categories-btn');

    function closeFullscreenOverlay() {
      if (!overlay || !overlay.classList.contains('is-open')) return;
      overlay.classList.remove('is-open');
      document.body.classList.remove('modal-open');
      
      // Use the global scroll lock cleanup logic from the main nav
      document.documentElement.classList.remove('menu-open');
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.width = '';
      document.body.style.overflowY = '';
      
      if (openBtn) {
        openBtn.setAttribute('aria-expanded', 'false');
        openBtn.focus();
      }
    }

    function openFullscreenOverlay() {
      if (!overlay) return;
      
      // Standardize scroll lock
      const scrollY = window.scrollY;
      document.body.style.top = `-${scrollY}px`;
      document.body.style.position = 'fixed';
      document.body.style.width = '100%';
      document.body.style.overflowY = 'scroll';
      
      overlay.classList.add('is-open');
      document.body.classList.add('modal-open'); // keep for backward compatibility
      document.documentElement.classList.add('menu-open'); // global body lock
      
      if (openBtn) openBtn.setAttribute('aria-expanded', 'true');
    }

    if (closeBtn && !(closeBtn as HTMLElement).dataset.bound) {
      closeBtn.addEventListener('click', closeFullscreenOverlay);
      (closeBtn as HTMLElement).dataset.bound = 'true';
    }

    if (openBtn && overlay && !openBtn.dataset.bound) {
      openBtn.addEventListener('click', (e) => {
        e.preventDefault();
        if (overlay.classList.contains('is-open')) {
          closeFullscreenOverlay();
        } else {
          openFullscreenOverlay();
        }
      });
      openBtn.dataset.bound = 'true';
    }

    // Close modal on link click during nav mode (Event Delegation)
    if (overlay && !overlay.dataset.boundNavDelegation) {
      overlay.addEventListener('click', (e) => {
        const link = (e.target as HTMLElement).closest('a.cat-btn');
        if (!link) return;

        const hrefAttr = link.getAttribute('href');
        closeFullscreenOverlay();
        
        if (hrefAttr && !hrefAttr.startsWith('#')) {
          e.preventDefault();
          navigate((link as HTMLAnchorElement).href);
        }
      });
      overlay.dataset.boundNavDelegation = 'true';
    }

    // Update the Categories button text based on active route
    if (openBtn) {
      const activeCat = document.querySelector('.desktop-category-row .cat-btn.active');
      if (activeCat) {
        openBtn.textContent = `Categories | ${activeCat.textContent?.trim()}`;
        openBtn.classList.add('active');
      } else {
        openBtn.textContent = `Categories`;
        openBtn.classList.remove('active');
      }
    }
  }

  // Handle Astro page loads
  document.addEventListener('astro:page-load', initQuadrantFilter);
</script>
