<!-- NEW FULL-SCREEN IMMERSIVE OVERLAY -->
<div id="category-fullscreen-overlay" class="category-fullscreen-overlay" aria-hidden="true">
  <button class="close-fullscreen-btn nav-toggle menu-open" aria-label="Close categories" id="close-categories-btn">
    <span class="line line-1"></span>
    <span class="line line-2"></span>
    <span class="line line-3"></span>
  </button>
  <div class="fullscreen-content filter-row category-row">
    <div class="filter-grid">
      {
        categories.map((c) => {
          const slug = c.toLowerCase();
          const expectedHubPath = `/category/${slug}${Astro.url.search}`;
          
          const isFeedContext = currentPath.startsWith('/feed');
          const isActive = !isFeedContext && currentPath.startsWith(`/category/${slug}`);
          const className = `quadrant-btn cat-btn ${isActive ? 'active' : ''}`;
          
          const hrefTarget = isFeedContext ? `#${slug}` : expectedHubPath;

          return (
            <a href={hrefTarget} class={className} data-category={slug} aria-current={isActive ? 'true' : undefined}>
              {c}
            </a>
          );
        })
      }
    </div>
  </div>
</div>

<style>
  .quadrant-filter-container {
    margin: 2rem 0 3rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    width: 100%;
  }

  .filter-row {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .type-row-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    visibility: hidden;
    transition:
      grid-template-rows 0.3s ease,
      opacity 0.3s ease,
      visibility 0.3s ease;
  }

  .type-row-wrapper.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
    visibility: visible;
  }

  .type-row-inner {
    overflow: hidden;
    min-height: 0;
    padding-top: 10px;
    margin-top: -10px;
  }

  .filter-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--color-white-muted);
    text-transform: uppercase;
  }

  .filter-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1rem;
  }

  .type-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .quadrant-btn {
    padding: 1.25rem 1rem;
    background: rgba(10, 10, 10, 0.6);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--color-white);
    font-size: 1.25rem;
    font-weight: 700;
    font-family: var(--font-display);
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    outline: 2px solid transparent;
    outline-offset: -2px;
    -webkit-tap-highlight-color: transparent;
    text-decoration: none;
    display: block;
    appearance: none;
    -webkit-appearance: none;
    border-radius: 0;
  }

  @media (hover: hover) and (pointer: fine) {
    .type-btn:hover,
    .cat-btn:hover {
      background: rgba(239, 68, 68, 0.1);
      outline: 2px solid var(--color-accent, #ef4444);
      outline-offset: -2px;
      box-shadow: 0 0 15px rgba(239, 68, 68, 0.5);
      transform: translateY(-2px);
    }

    .quadrant-btn:not(.type-btn):not(.cat-btn):hover {
      background: rgba(255, 255, 255, 0.05);
      transform: translateY(-2px);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    }
  }

  .type-btn:focus-visible,
  .cat-btn:focus-visible,
  .quadrant-btn:focus-visible {
    outline: 2px solid white;
    outline-offset: 4px;
    background: rgba(239, 68, 68, 0.1);
  }

  @media (prefers-reduced-motion: reduce) {
    .quadrant-btn,
    .quadrant-btn:hover,
    .quadrant-btn:focus-visible,
    .type-btn:hover,
    .cat-btn:hover,
    .quadrant-btn:not(.type-btn):not(.cat-btn):hover {
      transform: none !important;
      transition: none !important;
    }
  }

  .quadrant-btn.active {
    background: rgba(239, 68, 68, 0.1);
    outline: 2px solid var(--color-accent, #ef4444);
    outline-offset: -2px;
    border-color: transparent;
    color: white;
    box-shadow: 0 0 20px rgba(239, 68, 68, 0.6);
  }

  @media (max-width: 768px) {
    .filter-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .mobile-top-bar {
    display: none;
  }

  .mobile-category-row {
    display: none;
  }

  @media (max-width: 768px) {
    .mobile-top-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      position: sticky;
      top: 80px;
      z-index: 50;
      margin-bottom: 1rem;
    }
    .mobile-type-toggles {
      display: flex;
      flex-grow: 1;
      gap: 0.5rem;
    }
    .mobile-type-toggles .quadrant-btn {
      flex: 1;
      padding: 0.75rem 0.5rem;
      font-size: 0.9rem;
    }
    .mobile-category-row {
      display: flex;
      width: 100%;
      margin-bottom: 2rem;
    }
    .full-width-btn {
      width: 100%;
      flex: 1;
      font-size: 1.1rem;
      padding: 1rem;
    }
    .desktop-type-row {
      display: none;
    }
    .desktop-category-row {
      display: none;
    }
  }

