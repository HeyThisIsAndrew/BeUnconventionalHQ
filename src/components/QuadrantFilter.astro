  /* =========================================================================
     FULL-SCREEN IMMERSIVE OVERLAY STYLES
     ========================================================================= */
  .category-fullscreen-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100dvh;
    background: #000000;
    z-index: 10005;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.4s ease;
    padding-top: env(safe-area-inset-top);
    overscroll-behavior: contain;
  }

  .category-fullscreen-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  .close-fullscreen-btn {
    position: absolute;
    top: max(1rem, env(safe-area-inset-top, 1rem));
    right: max(1rem, env(safe-area-inset-right, 1rem));
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 10006;
    padding: 0;
  }

  .close-fullscreen-btn .line {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-white);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
  }

  /* Pre-transformed into an X */
  .close-fullscreen-btn .line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .close-fullscreen-btn .line:nth-child(2) { opacity: 0; }
  .close-fullscreen-btn .line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .category-fullscreen-overlay .filter-grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem; /* Matched exactly to #navbar nav ul */
    width: 100%;
    max-width: 100%;
  }

  .category-fullscreen-overlay .cat-btn {
    position: relative;
    display: block;
    padding: 1.5rem 1.25rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 700;
    color: rgba(245, 245, 245, 0.8);
    text-transform: uppercase;
    text-decoration: none;
    letter-spacing: 0.15em;
    transition: color 0.3s ease, text-shadow 0.3s ease;
    background: transparent;
    border: none;
    box-shadow: none;
    backdrop-filter: none;
  }

  .category-fullscreen-overlay .cat-btn::after {
    content: '';
    position: absolute;
    bottom: 0.75rem;
    left: 1.25rem;
    width: 0;
    height: 1px;
    background: var(--color-accent);
    transition: width 0.35s cubic-bezier(0.25, 0.8, 0.2, 1);
  }

  .category-fullscreen-overlay .cat-btn:hover,
  .category-fullscreen-overlay .cat-btn.active {
    color: var(--color-accent);
    text-shadow: 0 0 16px rgba(204, 0, 0, 0.45);
    background: transparent;
    box-shadow: none;
    outline: none;
    transform: none;
  }

  .category-fullscreen-overlay .cat-btn:hover::after,
  .category-fullscreen-overlay .cat-btn.active::after {
    width: calc(100% - 2.5rem);
  }

  :global(body.modal-open) {
    overflow: hidden !important;
  }
</style>

