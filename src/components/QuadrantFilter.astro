---
export interface Props {
  showTypes?: boolean;
  isNavMode?: boolean; // Kept for backward compatibility, but we now always use Nav mode behavior.
}
const { showTypes = false } = Astro.props;

const categories = ['Film', 'TV', 'Gaming', 'Events'];
const types = [
  { label: 'Article', href: '/feed/articles' },
  { label: 'Video', href: '/feed/videos' },
];

const currentPath = Astro.url.pathname;

---

<div
  class="quadrant-filter-container animate-on-scroll"
  id="quadrant-filter-wrapper"
>
  <div id="global-type-row" class={`type-row-wrapper ${showTypes ? 'is-open' : ''}`}>
    <div class="type-row-inner">
      <div class="mobile-top-bar">
        <div class="filter-grid type-grid mobile-type-toggles">
          {
            types.map((t) => {
              const isActive = currentPath.includes(t.href);
              let target = isActive ? '/feed' : t.href;
              if (!isActive && currentPath.startsWith('/category/')) {
                const categorySlug = currentPath.split('/category/')[1].split('/')[0];
                target = `${target}#${categorySlug}`;
              }
              return (
                <a
                  href={target}
                  class={`quadrant-btn type-btn ${isActive ? 'active' : ''}`}
                  aria-current={isActive ? 'true' : undefined}
                >
                  {t.label.toUpperCase()}
                </a>
              );
            })
          }
        </div>
      </div>

      <div class="filter-row desktop-type-row">
        <div class="filter-grid type-grid">
          {
            types.map((t) => {
              const isActive = currentPath.includes(t.href);
              let target = isActive ? '/feed' : t.href;
              if (!isActive && currentPath.startsWith('/category/')) {
                const categorySlug = currentPath.split('/category/')[1].split('/')[0];
                target = `${target}#${categorySlug}`;
              }
              return (
                <a
                  href={target}
                  class={`quadrant-btn type-btn ${isActive ? 'active' : ''}`}
                  aria-current={isActive ? 'true' : undefined}
                >
                  {t.label.toUpperCase()}
                </a>
              );
            })
          }
        </div>
      </div>
    </div>
  </div>

  <div class="mobile-category-row">
    <button id="open-categories-btn" class="quadrant-btn full-width-btn" aria-haspopup="dialog" aria-expanded="false"
      >Categories</button
    >
  </div>

  <div class="filter-row category-row desktop-category-row">
    <div class="filter-grid">
      {
        categories.map((c) => {
          const slug = c.toLowerCase();
          const expectedHubPath = `/category/${slug}${Astro.url.search}`;
          
          const isFeedContext = currentPath.startsWith('/feed');
          // In feed context, active state is primarily managed client-side via hash
          const isActive = !isFeedContext && currentPath.startsWith(`/category/${slug}`);
          const className = `quadrant-btn cat-btn ${isActive ? 'active' : ''}`;
          
          const hrefTarget = isFeedContext ? `#${slug}` : expectedHubPath;

          return (
            <a href={hrefTarget} class={className} data-category={slug} aria-current={isActive ? 'true' : undefined}>
              {c}
            </a>
          );
        })
      }
    </div>
  </div>
</div>

