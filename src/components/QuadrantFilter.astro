---
export interface Props {
  showTypes?: boolean;
  isNavMode?: boolean;
}
const { showTypes = false, isNavMode = false } = Astro.props;

const categories = ['Film', 'TV', 'Gaming', 'Events'];
const types = ['Article', 'Video'];
const currentPath = Astro.url.pathname;
---

<div class="quadrant-filter-container animate-on-scroll" id="quadrant-filter-wrapper" data-nav-mode={isNavMode ? 'true' : 'false'}>
  
  <div id="global-type-row" class="type-row-wrapper">
    <div class="type-row-inner">
      <div class="mobile-top-bar">
        <div class="filter-grid type-grid mobile-type-toggles">
          {types.map(t => (
            <button class="quadrant-btn type-btn" data-filter-type={t.toLowerCase()}>{t.toUpperCase()}</button>
          ))}
        </div>
        <button id="open-categories-btn" class="quadrant-btn" style="display: none;">Categories</button>
      </div>

      <div class="filter-row desktop-type-row">
        <span class="filter-label">TYPE</span>
        <div class="filter-grid type-grid">
          {types.map(t => (
            <button class="quadrant-btn type-btn" data-filter-type={t.toLowerCase()}>{t.toUpperCase()}</button>
          ))}
        </div>
      </div>
    </div>
  </div>

  <div class="filter-row category-row desktop-category-row">
    <span class="filter-label desktop-category-label">CATEGORY</span>
    <div class="filter-grid">
      {categories.map(c => {
        const slug = c.toLowerCase();
        const isActive = isNavMode && currentPath.includes(`/category/${slug}`);
        const className = `quadrant-btn cat-btn ${isActive ? 'active' : ''}`;
        
        // Active Toggle Escape Route: if active on Hub page, link to /feed to deselect
        const hrefTarget = isActive ? '/feed' : `/category/${slug}`;
        
        return isNavMode ? (
          <a href={hrefTarget} class={className}>{c}</a>
        ) : (
          <button class="quadrant-btn cat-btn" data-filter-cat={slug}>{c}</button>
        );
      })}
    </div>
  </div>
</div>

<dialog id="category-modal" class="fade-in-overlay">
  <div class="modal-content">
    <button class="modal-close" aria-label="Close categories" id="close-categories-btn">&times;</button>
    <div class="filter-row category-row">
      <span class="filter-label">CATEGORY</span>
      <div class="filter-grid">
        {categories.map(c => {
          const slug = c.toLowerCase();
          const isActive = isNavMode && currentPath.includes(`/category/${slug}`);
          const className = `quadrant-btn cat-btn ${isActive ? 'active' : ''}`;
          
          const hrefTarget = isActive ? '/feed' : `/category/${slug}`;
          
          return isNavMode ? (
            <a href={hrefTarget} class={className}>{c}</a>
          ) : (
            <button class="quadrant-btn cat-btn" data-filter-cat={slug}>{c}</button>
          );
        })}
      </div>
    </div>
  </div>
</dialog>

<style>
  .quadrant-filter-container {
    margin: 2rem 0 3rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    width: 100%;
  }

  .filter-row {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .type-row-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    visibility: hidden;
    transition: grid-template-rows 0.3s ease, opacity 0.3s ease, visibility 0.3s ease;
  }

  .type-row-wrapper.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
    visibility: visible;
  }

  .type-row-inner {
    overflow: hidden;
    min-height: 0;
  }

  .filter-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--color-white-muted);
    text-transform: uppercase;
  }

  .filter-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1rem;
  }

  .type-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .quadrant-btn {
    padding: 1.25rem 1rem;
    background: rgba(10, 10, 10, 0.6);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    color: var(--color-white);
    font-size: 1.1rem;
    font-weight: 700;
    font-family: var(--font-display);
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    outline: none;
    -webkit-tap-highlight-color: transparent;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (hover: hover) {
    .quadrant-btn:hover {
      background: rgba(255, 255, 255, 0.05);
      transform: translateY(-2px);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    }
  }

  .quadrant-btn.active {
    background: rgba(229, 9, 20, 0.1);
    border: 2px solid var(--color-accent);
    color: white;
    box-shadow: 0 0 15px rgba(229, 9, 20, 0.3);
  }

  @media (max-width: 768px) {
    .filter-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .mobile-top-bar {
    display: none;
  }

  @media (max-width: 767px) {
    .mobile-top-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      position: sticky;
      top: 20px;
      z-index: 50;
      margin-bottom: 2rem;
    }
    .mobile-type-toggles {
      display: flex;
      flex-grow: 1;
      gap: 0.5rem;
    }
    .mobile-type-toggles .quadrant-btn {
      flex: 1;
      padding: 0.75rem 0.5rem;
      font-size: 0.9rem;
    }
    #open-categories-btn {
      padding: 0.75rem 1rem;
      font-size: 0.9rem;
      white-space: nowrap;
      display: flex; /* Replaces !important */
    }
    .desktop-type-row {
      display: none;
    }
    .desktop-category-row {
      display: none;
    }
    #category-modal .filter-grid {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      justify-content: center;
      gap: 1rem;
    }
    #category-modal .modal-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }
  }

  /* Dialog Styles for Category Overlay */
  #category-modal {
    view-transition-name: cinematic-overlay;
    background: transparent;
    border: none;
    margin: auto;
    padding: 0;
    max-width: 90vw;
    width: 100%;
  }

  #category-modal[open] {
    animation: fadeIn 0.3s ease-out forwards;
  }
  
  #category-modal::backdrop {
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(8px);
  }

  #category-modal[open]::backdrop {
    animation: fadeInBackdrop 0.3s ease-out forwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(10px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  @keyframes fadeInBackdrop {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  #category-modal.closing {
    animation: fadeOut 0.3s ease-in forwards;
  }

  #category-modal.closing::backdrop {
    animation: fadeOutBackdrop 0.3s ease-in forwards;
  }

  @keyframes fadeOut {
    from {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
    to {
      opacity: 0;
      transform: scale(0.95) translateY(10px);
    }
  }

  @keyframes fadeOutBackdrop {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }

  .modal-content {
    background: var(--color-background, #000);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 3rem 2rem 2rem;
    position: relative;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
  }

  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: transparent;
    border: none;
    color: var(--color-white-muted, #aaa);
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    transition: color 0.3s ease;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
  }

  .modal-close:hover {
    color: white;
  }

  /* Completely eliminates JS scroll-locking */
  :global(body:has(#category-modal[open])) {
    overflow: hidden;
  }
</style>

<script>
  function initQuadrantFilter() {
    const container = document.getElementById('quadrant-filter-wrapper');
    if (!container) return;
    const isNavMode = container.getAttribute('data-nav-mode') === 'true';

    // Modal Logic
    const categoryModal = document.getElementById('category-modal') as HTMLDialogElement;
    const openBtn = document.getElementById('open-categories-btn');
    const closeBtn = document.getElementById('close-categories-btn');

    function closeCategoryModal() {
      if (!categoryModal || !categoryModal.open || categoryModal.classList.contains('closing')) return;
      categoryModal.classList.add('closing');
      categoryModal.addEventListener('animationend', function handleAnimationEnd(e) {
        if (e.target !== categoryModal) return;
        categoryModal.classList.remove('closing');
        categoryModal.close();
        categoryModal.removeEventListener('animationend', handleAnimationEnd);
      });
    }

    if (openBtn && categoryModal && !openBtn.dataset.bound) {
      openBtn.addEventListener('click', () => {
        categoryModal.showModal();
      });
      openBtn.dataset.bound = 'true';
    }

    if (closeBtn && categoryModal && !closeBtn.dataset.bound) {
      closeBtn.addEventListener('click', closeCategoryModal);
      closeBtn.dataset.bound = 'true';
    }

    // Close when clicking on backdrop
    if (categoryModal && !categoryModal.dataset.boundClick) {
      categoryModal.addEventListener('click', (e) => {
        const rect = categoryModal.getBoundingClientRect();
        const isInDialog = (
          rect.top <= e.clientY &&
          e.clientY <= rect.top + rect.height &&
          rect.left <= e.clientX &&
          e.clientX <= rect.left + rect.width
        );
        if (!isInDialog && categoryModal.open) {
          closeCategoryModal();
        }
      });
      categoryModal.dataset.boundClick = 'true';
    }


    // 1. RUN ONCE: Attach events only if not already initialized
    if (container.dataset.initialized !== 'true') {
      const typeBtns = document.querySelectorAll('.type-btn');
      const catBtns = document.querySelectorAll('.cat-btn');

      typeBtns.forEach((btn) =>
        btn.addEventListener('click', (e) => {
          const type = (e.currentTarget as HTMLElement).dataset.filterType;
          const wasActive = (e.currentTarget as HTMLElement).classList.contains('active');
          
          document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('active'));

          if (wasActive) {
            sessionStorage.removeItem('activeType');
          } else {
            document.querySelectorAll(`.type-btn[data-filter-type="${type}"]`).forEach(b => {
               b.classList.add('active');
            });
            if (type) sessionStorage.setItem('activeType', type);
          }
          update();
        })
      );

      catBtns.forEach((btn) =>
        btn.addEventListener('click', (e) => {
          const wasActive = (e.currentTarget as HTMLElement).classList.contains('active');
          
          // Strip active from all to enforce single selection
          document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
          
          if (wasActive) {
            // Toggle-to-Clear logic (Deselects entirely)
            history.pushState("", document.title, window.location.pathname);
          } else {
            // Sync all category buttons with same filter
            const filterCat = (e.currentTarget as HTMLElement).dataset.filterCat;
            document.querySelectorAll(`.cat-btn[data-filter-cat="${filterCat}"]`).forEach(b => {
               b.classList.add('active');
            });
            window.location.hash = filterCat || '';
          }
          
          update();
          // Also close modal if open
          if (categoryModal && categoryModal.open) {
            closeCategoryModal();
          }
        })
      );

      window.addEventListener('hashchange', () => {
        const newHash = window.location.hash.replace('#', '').toLowerCase();
        
        document.querySelectorAll('.cat-btn').forEach((b) => {
          if (newHash && (b as HTMLElement).dataset.filterCat === newHash) {
            b.classList.add('active');
          } else {
            b.classList.remove('active');
          }
        });
        
        update();
      });

      container.dataset.initialized = 'true';
    }

    // 2. RUN EVERY TIME: Sync visual state
    const urlHash = window.location.hash.replace('#', '').toLowerCase();
    const currentCatBtns = document.querySelectorAll('.cat-btn');

    const typeRow = document.getElementById('global-type-row');
    if (typeRow) {
      if (window.location.pathname === '/feed' || window.location.pathname === '/feed/') {
        typeRow.classList.add('is-open');
      } else {
        typeRow.classList.remove('is-open');
      }
    }

    // Also sync sessionStorage on load
    const storedType = sessionStorage.getItem('activeType');
    if (storedType) {
      document.querySelectorAll('.type-btn').forEach(b => {
        if ((b as HTMLElement).dataset.filterType === storedType) {
          b.classList.add('active');
        } else {
          b.classList.remove('active');
        }
      });
    } else {
      document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('active'));
    }

    // IF THIS IS NAV MODE AND PERSISTED, WE MUST UPDATE THE ACTIVE STATE MANUALLY ON SPA TRANSITIONS
    if (isNavMode) {
      const currentPath = window.location.pathname.replace(/\/$/, '').toLowerCase();
      
      currentCatBtns.forEach(b => {
        const slug = b.textContent?.toLowerCase() || '';
        const expectedPath = `/category/${slug}`;
        
        if (currentPath === expectedPath) {
          b.classList.add('active');
          if (b.tagName === 'A') (b as HTMLAnchorElement).href = '/feed'; // Active Toggle Escape Route
        } else {
          b.classList.remove('active');
          if (b.tagName === 'A') (b as HTMLAnchorElement).href = expectedPath;
        }
      });

      // Close modal on link click during nav mode
      if (categoryModal) {
        const modalLinks = categoryModal.querySelectorAll('a.cat-btn');
        modalLinks.forEach(link => {
          link.addEventListener('click', () => {
            if (categoryModal.open) {
              closeCategoryModal();
            }
          });
        });
      }
      return;
    }

    // Apply active class if hash is present
    if (urlHash) {
      currentCatBtns.forEach(b => {
        if ((b as HTMLElement).dataset.filterCat === urlHash) {
          b.classList.add('active');
        } else {
          b.classList.remove('active');
        }
      });
    }

    function update() {
      // Query fresh cards dynamically (solves stale references issue)
      const freshCards = document.querySelectorAll('.article-card, .video-card');
      if (freshCards.length === 0) return;

      const path = window.location.pathname;
      const isDedicatedRoute = path.includes('/videos') || path.includes('/articles');

      // Get single active type
      const activeTypeBtn = document.querySelector('.type-btn.active');
      let activeType = activeTypeBtn ? (activeTypeBtn as HTMLElement).dataset.filterType : 'all';

      // Force type on dedicated pages to ignore UI toggles
      if (isDedicatedRoute) {
        activeType = path.includes('/videos') ? 'video' : 'article';
      }

      // Get single active category
      const activeCatBtn = document.querySelector('.cat-btn.active');
      const cat = activeCatBtn ? (activeCatBtn as HTMLElement).dataset.filterCat : 'all';

      freshCards.forEach((card) => {
        const cardElem = card as HTMLElement;
        const cardType = cardElem.dataset.type || 'article';
        const cardCat = cardElem.dataset.category || 'general';

        const matchesType = activeType === 'all' || cardType.toLowerCase() === activeType;
        const matchesCat = cat === 'all' || cardCat.toLowerCase() === cat;

        if (matchesType && matchesCat) {
          cardElem.style.display = 'flex';
          cardElem.style.opacity = '1';
          cardElem.style.pointerEvents = 'auto';
          cardElem.style.transform = 'scale(1)';
          cardElem.style.filter = 'grayscale(0)';
        } else {
          cardElem.style.display = 'none';
        }
      });
    }

    // Run on initial load and view transitions
    update();
  }

  // Handle Astro page loads
  document.addEventListener('astro:page-load', initQuadrantFilter);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initQuadrantFilter);
  } else {
    initQuadrantFilter();
  }
</script>
