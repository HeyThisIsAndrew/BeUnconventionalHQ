---
export interface Props {
  showTypes?: boolean;
  isNavMode?: boolean; // Kept for backward compatibility, but we now always use Nav mode behavior.
}
const { showTypes = false } = Astro.props;

const categories = ['Film', 'TV', 'Gaming', 'Events'];
const types = [
  { label: 'Article', href: '/feed/articles' },
  { label: 'Video', href: '/feed/videos' },
];

const currentPath = Astro.url.pathname;
const isFeed = currentPath === '/feed' || currentPath === '/feed/';
---

<div
  class="quadrant-filter-container animate-on-scroll"
  id="quadrant-filter-wrapper"
>
  <div id="global-type-row" class={`type-row-wrapper ${showTypes ? 'is-open' : ''}`}>
    <div class="type-row-inner">
      <div class="mobile-top-bar">
        <div class="filter-grid type-grid mobile-type-toggles">
          {
            types.map((t) => {
              const isActive = currentPath.includes(t.href);
              const target = isActive ? '/feed' : t.href;
              return (
                <a
                  href={target}
                  class={`quadrant-btn type-btn ${isActive ? 'active' : ''}`}
                >
                  {t.label.toUpperCase()}
                </a>
              );
            })
          }
        </div>
      </div>

      <div class="filter-row desktop-type-row">
        <div class="filter-grid type-grid">
          {
            types.map((t) => {
              const isActive = currentPath.includes(t.href);
              const target = isActive ? '/feed' : t.href;
              return (
                <a
                  href={target}
                  class={`quadrant-btn type-btn ${isActive ? 'active' : ''}`}
                >
                  {t.label.toUpperCase()}
                </a>
              );
            })
          }
        </div>
      </div>
    </div>
  </div>

  <div class="mobile-category-row">
    <button id="open-categories-btn" class="quadrant-btn full-width-btn"
      >Categories</button
    >
  </div>

  <div class="filter-row category-row desktop-category-row">
    <div class="filter-grid">
      {
        categories.map((c) => {
          const slug = c.toLowerCase();
          const expectedHubPath = `/category/${slug}`;
          const expectedFeedPath = `/feed/${slug}`;
          
          const isActive = currentPath.startsWith(expectedHubPath) || currentPath.startsWith(expectedFeedPath);
          const className = `quadrant-btn cat-btn ${isActive ? 'active' : ''}`;
          
          const isFeedContext = currentPath.startsWith('/feed');
          const baseRoute = isFeedContext ? expectedFeedPath : expectedHubPath;
          const hrefTarget = (isActive && isFeedContext) ? '/feed' : baseRoute;

          return (
            <a href={hrefTarget} class={className}>
              {c}
            </a>
          );
        })
      }
    </div>
  </div>
</div>

<dialog
  id="category-modal"
  class="fade-in-overlay"
>
  <div class="modal-content">
    <div class="filter-row category-row">
      <div class="filter-grid">
        {
          categories.map((c) => {
            const slug = c.toLowerCase();
            const expectedHubPath = `/category/${slug}`;
            const expectedFeedPath = `/feed/${slug}`;
            
            const isActive = currentPath.startsWith(expectedHubPath) || currentPath.startsWith(expectedFeedPath);
            const className = `quadrant-btn cat-btn ${isActive ? 'active' : ''}`;
            
            const isFeedContext = currentPath.startsWith('/feed');
            const baseRoute = isFeedContext ? expectedFeedPath : expectedHubPath;
            const hrefTarget = (isActive && isFeedContext) ? '/feed' : baseRoute;

            return (
              <a href={hrefTarget} class={className}>
                {c}
              </a>
            );
          })
        }
      </div>
    </div>
  </div>
</dialog>

<style>
  .quadrant-filter-container {
    margin: 2rem 0 3rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    width: 100%;
  }

  .filter-row {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .type-row-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    visibility: hidden;
    transition:
      grid-template-rows 0.3s ease,
      opacity 0.3s ease,
      visibility 0.3s ease;
  }

  .type-row-wrapper.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
    visibility: visible;
  }

  .type-row-inner {
    overflow: hidden;
    min-height: 0;
    padding-top: 10px;
    margin-top: -10px;
  }

  .filter-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--color-white-muted);
    text-transform: uppercase;
  }

  .filter-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1rem;
  }

  .type-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .quadrant-btn {
    padding: 1.25rem 1rem;
    background: rgba(10, 10, 10, 0.6);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--color-white);
    font-size: 1.1rem;
    font-weight: 700;
    font-family: var(--font-display);
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    outline: none;
    -webkit-tap-highlight-color: transparent;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (hover: hover) and (pointer: fine) {
    .type-btn:hover,
    .cat-btn:hover,
    .type-btn:focus-visible,
    .cat-btn:focus-visible {
      background: rgba(239, 68, 68, 0.1);
      border: 2px solid var(--color-accent, #ef4444);
      box-shadow: 0 0 15px rgba(239, 68, 68, 0.5);
      transform: translateY(-2px);
    }

    .quadrant-btn:not(.type-btn):not(.cat-btn):hover {
      background: rgba(255, 255, 255, 0.05);
      transform: translateY(-2px);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    }
  }

  .quadrant-btn.active {
    background: rgba(239, 68, 68, 0.1);
    border: 2px solid var(--color-accent, #ef4444);
    color: white;
    box-shadow: 0 0 20px rgba(239, 68, 68, 0.6);
  }

  @media (max-width: 768px) {
    .filter-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .mobile-top-bar {
    display: none;
  }

  .mobile-category-row {
    display: none;
  }

  @media (max-width: 767px) {
    .mobile-top-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      position: sticky;
      top: 20px;
      z-index: 50;
      margin-bottom: 1rem;
    }
    .mobile-type-toggles {
      display: flex;
      flex-grow: 1;
      gap: 0.5rem;
    }
    .mobile-type-toggles .quadrant-btn {
      flex: 1;
      padding: 0.75rem 0.5rem;
      font-size: 0.9rem;
    }
    .mobile-category-row {
      display: flex;
      width: 100%;
      margin-bottom: 2rem;
    }
    .full-width-btn {
      width: 100%;
      flex: 1;
      font-size: 1.1rem;
      padding: 1rem;
    }
    .desktop-type-row {
      display: none;
    }
    .desktop-category-row {
      display: none;
    }
  }

  /* Dialog Styles for Category Overlay */
  #category-modal {
    view-transition-name: cinematic-overlay;
    background: transparent;
    border: none;
    margin: auto;
    padding: 0;
    max-width: 90vw;
    width: 100%;
  }

  #category-modal[open] {
    animation: fadeIn 0.3s ease-out forwards;
  }

  #category-modal::backdrop {
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(8px);
  }

  #category-modal[open]::backdrop {
    animation: fadeInBackdrop 0.3s ease-out forwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(10px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  @keyframes fadeInBackdrop {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  #category-modal.closing {
    animation: fadeOut 0.3s ease-in forwards;
  }

  #category-modal.closing::backdrop {
    animation: fadeOutBackdrop 0.3s ease-in forwards;
  }

  @keyframes fadeOut {
    from {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
    to {
      opacity: 0;
      transform: scale(0.95) translateY(10px);
    }
  }

  @keyframes fadeOutBackdrop {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }

  #category-modal .modal-content {
    background: transparent;
    border: none;
    box-shadow: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  #category-modal .filter-grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
    max-width: 100%;
  }

  #category-modal .cat-btn {
    background: rgba(20, 20, 20, 0.7);
    backdrop-filter: blur(25px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 0 30px rgba(255, 255, 255, 0.05);
    width: 60vw;
    min-width: 280px;
    max-width: 400px;
    padding: 1.5rem;
    font-size: 1.3rem;
    letter-spacing: 0.1em;
  }

  :global(body:has(#category-modal[open])) {
    overflow: hidden;
  }
</style>

<script>
  import { navigate } from 'astro:transitions/client';

  function initQuadrantFilter() {
    const categoryModal = document.getElementById('category-modal') as HTMLDialogElement;
    const openBtn = document.getElementById('open-categories-btn');

    function handleAnimationEnd(e: Event) {
      if (e.target !== categoryModal) return;
      categoryModal.classList.remove('closing');
      categoryModal.close();
      categoryModal.removeEventListener('animationend', handleAnimationEnd);
    }

    function closeCategoryModal() {
      if (!categoryModal || !categoryModal.open || categoryModal.classList.contains('closing')) return;
      categoryModal.classList.add('closing');
      categoryModal.addEventListener('animationend', handleAnimationEnd);
    }

    if (openBtn && categoryModal && !openBtn.dataset.bound) {
      openBtn.addEventListener('click', (e) => {
        e.preventDefault();
        if (categoryModal.open) {
          if (categoryModal.classList.contains('closing')) {
            categoryModal.classList.remove('closing');
            categoryModal.removeEventListener('animationend', handleAnimationEnd);
          } else {
            closeCategoryModal();
          }
        } else {
          categoryModal.showModal();
        }
      });
      openBtn.dataset.bound = 'true';
    }

    if (categoryModal && !categoryModal.dataset.boundClick) {
      categoryModal.addEventListener('click', (e) => {
        const rect = categoryModal.getBoundingClientRect();
        if (
          e.clientY < rect.top ||
          e.clientY > rect.bottom ||
          e.clientX < rect.left ||
          e.clientX > rect.right
        ) {
          if (categoryModal.open) closeCategoryModal();
        }
      });
      categoryModal.dataset.boundClick = 'true';
    }

    // Update the Categories button text based on active route
    const openCategoriesBtn = document.getElementById('open-categories-btn');
    if (openCategoriesBtn) {
      const activeCat = document.querySelector('.desktop-category-row .cat-btn.active');
      if (activeCat) {
        openCategoriesBtn.textContent = `Categories | ${activeCat.textContent?.trim()}`;
        openCategoriesBtn.classList.add('active');
      } else {
        openCategoriesBtn.textContent = `Categories`;
        openCategoriesBtn.classList.remove('active');
      }
    }

    // Close modal on link click during nav mode (Event Delegation)
    if (categoryModal && !categoryModal.dataset.boundNavDelegation) {
      categoryModal.addEventListener('click', (e) => {
        const link = (e.target as HTMLElement).closest('a.cat-btn');
        if (!link) return;

        e.preventDefault();

        if (categoryModal.open) {
          categoryModal.classList.remove('closing');
          categoryModal.close();
        }

        navigate((link as HTMLAnchorElement).href);
      });
      categoryModal.dataset.boundNavDelegation = 'true';
    }
  }

  // Handle Astro page loads
  document.addEventListener('astro:page-load', initQuadrantFilter);
</script>
