---
import { sanityClient } from "sanity:client";
import imageUrlBuilder from "@sanity/image-url";

const builder = imageUrlBuilder(sanityClient);
const urlFor = (source: any) => {
  return builder.image(source);
};

const { events } = Astro.props;

// Helper to format date ranges
function formatDateRange(start, end) {
  const startDate = new Date(start);
  const startMonth = startDate.toLocaleString('en-US', { month: 'short' }).toUpperCase();
  const startDay = startDate.getDate();
  
  if (!end) {
    return { month: startMonth, days: `${startDay}` };
  }
  
  const endDate = new Date(end);
  const endMonth = endDate.toLocaleString('en-US', { month: 'short' }).toUpperCase();
  const endDay = endDate.getDate();
  
  if (startMonth === endMonth) {
    return { month: startMonth, days: `${startDay}-${endDay}` };
  } else {
    return { month: `${startMonth}-${endMonth}`, days: `${startDay}-${endDay}` };
  }
}
---

<div class="timeline-container">
  {events.length > 0 ? (
    <div class="timeline">
      {events.map((event: any, index: number) => {
        const heroUrl = event.heroImage ? urlFor(event.heroImage).width(800).height(450).url() : '';
        const logoUrl = event.logo ? urlFor(event.logo).height(80).url() : '';
        const dateFormatted = formatDateRange(event.startDate, event.endDate);
        
        return (
          <div class="timeline-item animate-on-scroll" style={`--index: ${index};`}>
            {/* Date Block */}
            <div class="timeline-date">
              <span class="date-month">{dateFormatted.month}</span>
              <span class="date-days">{dateFormatted.days}</span>
              <span class="date-year">{new Date(event.startDate).getFullYear()}</span>
            </div>
            
            {/* Timeline Dot & Line */}
            <div class="timeline-divider">
              <div class="timeline-dot"></div>
              <div class="timeline-line"></div>
            </div>
            
            {/* Event Content Card */}
            <div class="timeline-content">
              <div class="calendar-timeline-card" style={heroUrl ? `background-image: url('${heroUrl}');` : 'background: #111;'}>
                <a href={`/events/${event.slug.current}`} class="event-link-overlay" aria-label={`View ${event.title}`}></a>
                
                <div class="card-inner">
                  <div class="card-meta">
                    <span class="event-tag">EVENTS</span>
                    {event.location && <span class="event-location">• {event.location}</span>}
                  </div>
                  
                  {logoUrl ? (
                    <img src={logoUrl} alt={`${event.title} logo`} class="event-logo" />
                  ) : (
                    <h3 class="event-title">{event.title}</h3>
                  )}
                  
                  <div class="card-actions">
                    <span class="view-hub-link">View Coverage Hub &rarr;</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        )
      })}
    </div>
  ) : (
    <div class="empty-calendar">
      <p>No upcoming events currently scheduled. Check back soon!</p>
    </div>
  )}
</div>

<style>
  .timeline-container {
    margin: 2rem auto 5rem;
    max-width: 1000px;
    padding: 0 1rem;
  }
  
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  
  .timeline-item {
    display: flex;
    position: relative;
    gap: 1.5rem;
  }
  
  /* Date Block */
  .timeline-date {
    width: 100px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
    padding-top: 1.5rem;
    color: var(--color-accent, #cc0000);
  }
  .date-month {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 2px;
  }
  .date-days {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1;
    color: white;
    margin: 0.1rem 0;
  }
  .date-year {
    font-size: 1rem;
    color: #888;
  }
  
  /* Divider */
  .timeline-divider {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    padding-top: 3.6rem; /* Accurately aligns dot with the center of the massive date-days text */
  }
  
  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(204,0,0,0.8);
    }
    70% {
      box-shadow: 0 0 0 15px rgba(204,0,0,0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(204,0,0,0);
    }
  }
  
  .timeline-dot {
    width: 14px;
    height: 14px;
    background: var(--color-accent, #cc0000);
    border-radius: 50%;
    position: relative;
    z-index: 2;
    animation: pulse 2s infinite ease-in-out;
  }
  .timeline-line {
    position: absolute;
    top: 3.6rem;
    bottom: -2rem; /* Extend to next item */
    width: 2px;
    background: rgba(255,255,255,0.1);
    z-index: 1;
  }
  .timeline-item:last-child .timeline-line {
    display: none;
  }
  
  /* Content Card */
  .timeline-content {
    flex-grow: 1;
    padding-bottom: 3rem;
  }
  
  .calendar-timeline-card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    background-size: cover;
    background-position: center;
    background-color: #000;
    border: 2px solid #000;
    /* Card stays put on hover — matches the homepage tiles: accent outline and
       a soft glow, no fill or movement. */
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
    min-height: 200px;
  }

  /* Gradient overlay using ::before to eliminate subpixel rendering gaps */
  .calendar-timeline-card::before {
    content: '';
    position: absolute;
    inset: -1px; /* Overflow to cover border anti-aliasing artifacts */
    background: linear-gradient(to right, rgba(0,0,0,1) 0%, rgba(0,0,0,0.9) 5%, rgba(0,0,0,0.7) 40%, rgba(0,0,0,0.4) 100%);
    pointer-events: none;
    z-index: 3; /* Above background image, below content */
    border-radius: 12px;
  }

  .calendar-timeline-card:hover {
    border-color: var(--color-accent, #cc0000);
    box-shadow: 0 8px 30px rgba(204, 0, 0, 0.15);
  }
  .calendar-timeline-card:hover .view-hub-link {
    color: var(--color-accent, #cc0000);
  }
  .calendar-timeline-card:hover .view-hub-link::after {
    transform: scaleX(1);
    transform-origin: left;
  }
  
  .event-link-overlay {
    position: absolute;
    inset: 0;
    z-index: 10; /* Put overlay on top to make entire card clickable */
  }
  
  .card-inner {
    position: relative;
    z-index: 5; /* Above gradient overlay (::before is 3), below link overlay (10) */
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    justify-content: center;
    pointer-events: none; /* Let clicks pass through to overlay */
  }
  
  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #aaa;
    line-height: 1; 
  }
  
  .event-tag {
    background: rgba(255,255,255,0.1);
    padding: 0.4rem 0.6rem; 
    border-radius: 4px;
    color: white;
    font-weight: 700;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  
  .event-location {
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }
  
  .event-logo {
    max-height: 60px;
    width: auto;
    object-fit: contain;
    object-position: left;
    margin-bottom: 1rem;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5));
  }
  
  .event-title {
    font-size: 2rem;
    margin: 0 0 1rem 0;
    font-weight: 700;
  }
  
  .card-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1rem;
  }
  
  .view-hub-link {
    color: white;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 0.9rem;
    position: relative;
    display: inline-block;
    transition: color 0.3s ease;
  }
  
  .view-hub-link::after {
    content: '';
    position: absolute;
    width: 100%;
    height: 2px;
    bottom: -4px;
    left: 0;
    background-color: var(--color-accent, #cc0000);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s ease;
  }
  
  .rsvp-btn {
    background: white;
    color: black;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 800;
    padding: 0.5rem 1.25rem;
    border-radius: 30px;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: background 0.3s ease, transform 0.2s ease;
    pointer-events: auto; /* Re-enable clicks for RSVP button */
    position: relative;
    z-index: 20; /* Ensure it's above the overlay link */
  }
  .rsvp-btn:hover {
    background: #f0f0f0;
    transform: scale(1.05);
  }
  
  .empty-calendar {
    text-align: center;
    padding: 4rem;
    background: rgba(255,255,255,0.05);
    border-radius: 12px;
    color: #888;
  }
  
  @media (max-width: 768px) {
    .timeline-item {
      flex-direction: column;
      gap: 0.5rem;
    }
    .timeline-date {
      width: 100%;
      text-align: left;
      align-items: flex-start;
      flex-direction: row;
      gap: 1rem;
      align-items: baseline;
      padding-top: 0;
    }
    .date-days {
      font-size: 1.5rem;
    }
    .timeline-divider {
      display: none;
    }
    .timeline-content {
      padding-bottom: 2rem;
    }
    .card-inner {
      padding: 1.5rem;
    }
  }
</style>
