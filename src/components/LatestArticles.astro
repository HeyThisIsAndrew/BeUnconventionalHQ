---
import { getArticles } from '../pages/articles.astro';
const allArticles = await getArticles();
const latestArticles = allArticles.slice(0, 3);
---

<section class="latest-section">
  <div class="section-header animate-on-scroll">
    <h2 class="hero-title-stack">
      <span class="word-be">From</span>
      <span class="word-unconventional">The Feed</span>
      <span class="word-hq">Latest</span>
    </h2>
  </div>

  <div class="articles-grid">
    {
      latestArticles.map((article, index) => (
        <article
          class="article-card animate-on-scroll"
          data-delay={index * 100}
        >
          <div class="article-image-wrapper">
            <span class="content-badge">{article.category}</span>
            <img
              src={article.image}
              alt={article.title}
              class="article-image"
            />
          </div>
          <div class="article-content">
            <span class="article-date">{article.date}</span>
            <h2 class="article-title">{article.title}</h2>
            <p class="article-excerpt">{article.excerpt}</p>
            <a
              href={article.link}
              target="_blank"
              rel="noopener noreferrer"
              class="article-link"
            >
              Read Full Article
            </a>
          </div>
        </article>
      ))
    }
  </div>

  <div class="latest-view-all animate-on-scroll">
    <a href={`/feed`} class="view-all-link"> View All Content → </a>
  </div>
</section>
