---
import { getArticles } from '../data/feeds.js';
import PageTitle from './PageTitle.astro';
import ContentCard from './ContentCard.astro';
const allArticles = getArticles();
const latestArticles = allArticles.slice(0, 3);
---

<section class="latest-section">
  <div class="section-header animate-on-scroll">
    <PageTitle kicker="From" primary="The Feed" secondary="Latest" />
  </div>

  <div class="latest-grid">
    {
      latestArticles.map((article, index) => (
        <ContentCard item={article} index={index} />
      ))
    }
  </div>

  <div class="latest-view-all animate-on-scroll">
    <a href={`/feed`} class="view-all-link"> View All Content → </a>
  </div>
</section>
