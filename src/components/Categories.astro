---
import { categories } from '../data/categories.js';
---

<section class="categories-section">
  <div class="section-header animate-on-scroll">
    <h2 class="hero-title-stack">
      <span class="word-be">Explore The HQ</span>
      <span class="word-unconventional">What We</span>
      <span class="word-hq">Cover</span>
    </h2>
  </div>

  <div class="cat-grid">
    {categories.map((cat, i) => (
      <a class="cat reveal" href={`/videos#${cat.slug}`} data-delay={i * 80} style={`background-image:url('${cat.image}')`}>
        <span class="cat-overlay"></span>
        <span class="cat-body">
          <span class="cat-label">{cat.label}</span>
          <span class="cat-blurb">{cat.blurb}</span>
          <span class="cat-cta">Explore →</span>
        </span>
      </a>
    ))}
  </div>
</section>
