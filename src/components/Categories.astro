---
import { categories } from '../data/categories.js';
---

<div class="cat-grid" style="max-width: 1536px; margin: 0 auto;">
  {
    categories.map((cat, i) => (
      <a class="cat reveal" href={`/feed?category=${cat.slug}`} data-delay={i * 80}>
        <img src={cat.image} alt={cat.label} class="cat-bg-img" />
        <span class="cat-overlay" />
        <span class="cat-body">
          <span class="cat-label">{cat.label}</span>
          <span class="cat-blurb">{cat.blurb}</span>
          <span class="cat-cta action-link">{cat.action} &rarr;</span>
        </span>
      </a>
    ))
  }
</div>
