---
import { categories } from '../data/categories.js';

const base = import.meta.env.BASE_URL;
---

<!-- 3D root wrapper: provides perspective/overflow for future cinematic interactions -->
<div class="categories-3d-root" style="position:relative; overflow:visible; -webkit-perspective:1200px; perspective:1200px;">

  <!-- preserve-3d on the section so child transforms maintain 3D space -->
  <section class="categories-section" style="-webkit-transform-style:preserve-3d; transform-style:preserve-3d; overflow:visible;">
  <h2 class="hero-title-stack">
    <span class="word-be">Explore The HQ</span>
    <span class="word-unconventional">What We</span>
    <span class="word-hq">Cover</span>
  </h2>

  <div class="categories-grid">
    {
      categories.map((cat, index) => (
        <a href={`${base}${cat.href}`} class="category-card animate-on-scroll">
          <div class="category-label">{cat.label}</div>

          <span class="category-icon">{cat.icon}</span>

          <h3 class="category-title">{cat.title}</h3>

          <p class="category-description">{cat.description}</p>

          <div class="explore-arrow">Explore →</div>
        </a>
      ))
    }
  </div>
</section>
</div>

<!-- Note: scroll-linked compression script removed to restore stable visuals.
     Structural 3D prep (wrapper + preserve-3d) remains in place. -->
