---
import { categories } from '../data/categories.js';
---
<div class="cat-grid" style="max-width: 1200px; margin: 0 auto;">
  {categories.map((cat, i) => (
    <a class="cat reveal" href={`/category/${cat.slug}`} data-delay={i * 80} style={`background-image:url('${cat.image}')`}>
      <span class="cat-overlay"></span>
      <span class="cat-body">
        <span class="cat-label">{cat.label}</span>
        <span class="cat-blurb">{cat.blurb}</span>
        <span class="cat-cta">Explore →</span>
      </span>
    </a>
  ))}
</div>