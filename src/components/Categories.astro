---
import { categories } from '../data/categories.js';

const base = import.meta.env.BASE_URL;
---

<div class="categories-3d-root">
  <div class="categories-scroll-region">
    <div class="categories-sticky-viewport">
      <section class="categories-section">
        <div class="animate-on-scroll" style="margin-bottom: 3.5rem;">
          <h2 class="hero-title-stack">
            <span class="word-be">Explore The HQ</span>
            <span class="word-unconventional">What We</span>
            <span class="word-hq">Cover</span>
          </h2>
        </div>

        <div class="categories-grid">
          {
            categories.map((cat, index) => (
              <a href={`${base}${cat.href}`} class="category-card animate-on-scroll" data-delay={index * 20}>
                <div class="category-label">{cat.label}</div>
                <span class="category-icon">{cat.icon}</span>
                <h3 class="category-title">{cat.title}</h3>
                <p class="category-description">{cat.description}</p>
                <div class="explore-arrow">Explore →</div>
              </a>
            ))
          }
        </div>
      </section>
    </div>
  </div>
</div>

<!-- Note: Structural 3D prep restored for cinematic centering. IntersectionObserver handles entry stability. -->
