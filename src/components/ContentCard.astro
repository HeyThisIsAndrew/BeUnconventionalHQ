---
import { parseVideoId } from '../lib/platforms/youtube';

export interface Props {
  item: any;
  index: number;
}

const { item, index = 0 } = Astro.props;
const isVideo = item.contentType === 'video' || item.type === 'video';
const videoId = isVideo ? parseVideoId(item.link) : null;
const isPlayable = isVideo && !!videoId;

// Determine primary label for the badge
const baseTags = Array.isArray(item.tags) ? item.tags : [];
const itemTags = [...baseTags, item.category || 'General'];
const lowerTags = itemTags.map((t: string) => typeof t === 'string' ? t.toLowerCase() : '');
let primaryLabel = 'General';
if (isVideo) primaryLabel = 'Video';
else if (lowerTags.includes('tv')) primaryLabel = 'TV';
else if (lowerTags.includes('film')) primaryLabel = 'Film';
else if (lowerTags.includes('gaming')) primaryLabel = 'Gaming';
else if (lowerTags.includes('event') || lowerTags.includes('events')) primaryLabel = 'Event';
else primaryLabel = item.category || 'Article';

// Render anchor or div depending on type. We use 'video-card-home' for both
// so they share the exact hover effects from home-cards.css.
const CardWrapper = isPlayable ? 'button' : 'a';
const wrapperProps = isPlayable
  ? {
      class: "reveal video-card-home content-card w-full text-left block h-full appearance-none",
      'aria-label': `Watch video: ${item.title}`,
      'data-delay': index * 100,
      'data-type': 'video',
      'data-categories': lowerTags.join(','),
      'data-video-id': videoId,
      'data-action': 'open-video'
    }
  : {
      href: item.link || '#',
      target: '_blank',
      rel: 'noopener noreferrer',
      class: `reveal video-card-home content-card w-full block h-full`,
      'data-type': isVideo ? 'video' : 'article',
      'data-categories': lowerTags.join(','),
      'data-delay': index * 100
    };
---

<CardWrapper {...wrapperProps}>
  <div class="flex flex-col h-full w-full">
    <div class="relative w-full aspect-video overflow-hidden">
      <img
        src={item.image || item.thumbnail}
        alt={item.title}
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover transition-transform duration-500 ease-in-out"
        onerror="this.onerror=null;this.src=this.src.replace('maxresdefault','hqdefault')"
      />
    </div>
    <div class="p-6 flex flex-col flex-grow">
      <div class="flex items-center gap-2 text-xs text-gray-400 font-bold uppercase tracking-widest mb-3">
        <span>{primaryLabel}</span>
        {item.date && (
          <>
            <span>&bull;</span>
            <span>{item.date}</span>
          </>
        )}
      </div>
      <h3 class="text-white font-display text-[1.1rem] font-bold mb-4 leading-[1.4]">
        {item.title}
      </h3>
      <span
        class="watch-now-btn mt-auto text-white text-xs font-semibold uppercase tracking-[0.15em] inline-block relative w-fit transition-colors duration-300"
      >
        {isVideo ? 'Watch Now' : 'Read Now'}{' '}
        <span style="color: var(--color-accent);">&rarr;</span>
        <span
          class="btn-underline absolute -bottom-1 left-0 w-0 h-[1px] transition-all duration-300"
          style="background: var(--color-accent);"
        />
      </span>
    </div>
  </div>
</CardWrapper>
