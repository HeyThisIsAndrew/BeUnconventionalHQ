---
import { parseVideoId } from '../lib/platforms/youtube';

export interface Props {
  item: any;
  index: number;
}

const { item, index = 0 } = Astro.props;
const isVideo = item.contentType === 'video' || item.type === 'video';
const videoId = isVideo ? parseVideoId(item.link) : null;

// Determine primary label for the badge
const itemTags = Array.isArray(item.tags) ? item.tags : [item.category || 'General'];
const lowerTags = itemTags.map((t: string) => typeof t === 'string' ? t.toLowerCase() : '');
let primaryLabel = 'General';
if (isVideo) primaryLabel = 'Video';
else if (lowerTags.includes('tv')) primaryLabel = 'TV';
else if (lowerTags.includes('film')) primaryLabel = 'Film';
else if (lowerTags.includes('gaming')) primaryLabel = 'Gaming';
else if (lowerTags.includes('event') || lowerTags.includes('events')) primaryLabel = 'Event';
else primaryLabel = item.category || 'Article';

// Render anchor or div depending on type. We use 'video-card-home' for both
// so they share the exact hover effects from home-cards.css.
const CardWrapper = isVideo ? 'div' : 'a';
const wrapperProps = isVideo
  ? {
      class: "reveal video-card-home video-modal-trigger w-full",
      'data-delay': index * 100,
      'data-video-id': videoId,
      style: "background: var(--color-surface); border: 1px solid rgba(255,255,255,0.05); overflow: hidden; text-decoration: none; display: flex; flex-direction: column; transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease; min-height: 100%; cursor: pointer;"
    }
  : {
      href: item.link || '#',
      target: '_blank',
      rel: 'noopener noreferrer',
      class: "reveal video-card-home w-full",
      'data-delay': index * 100,
      style: "background: var(--color-surface); border: 1px solid rgba(255,255,255,0.05); overflow: hidden; text-decoration: none; display: flex; flex-direction: column; transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease; min-height: 100%; cursor: pointer;"
    };
---

<CardWrapper {...wrapperProps}>
  <div style="position: relative; width: 100%; aspect-ratio: 16/9; overflow: hidden;">
    <img
      src={item.image || item.thumbnail}
      alt={item.title}
      loading="lazy"
      decoding="async"
      style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;"
      onerror="this.onerror=null;this.src=this.src.replace('maxresdefault','hqdefault')"
    />
  </div>
  <div style="padding: 1.5rem; display: flex; flex-direction: column; flex-grow: 1;">
    <div class="flex items-center gap-2 text-[10px] text-gray-400 font-bold uppercase tracking-widest mb-3">
      <span>{primaryLabel}</span>
      {item.date && (
        <>
          <span>&bull;</span>
          <span>{item.date}</span>
        </>
      )}
    </div>
    <h3 style="color: white; font-family: var(--font-display); font-size: 1.1rem; font-weight: 700; margin-bottom: 1rem; line-height: 1.4;">
      {item.title}
    </h3>
    <span
      class="watch-now-btn"
      style="margin-top: auto; color: var(--color-white); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; display: inline-block; position: relative; width: fit-content; transition: color 0.3s ease;"
    >
      {isVideo ? 'Watch Now' : 'Read Now'}{' '}
      <span style="color: var(--color-accent);">&rarr;</span>
      <span
        class="btn-underline"
        style="position: absolute; bottom: -4px; left: 0; width: 0; height: 1px; background: var(--color-accent); transition: width 0.3s ease;"
      />
    </span>
  </div>
</CardWrapper>
