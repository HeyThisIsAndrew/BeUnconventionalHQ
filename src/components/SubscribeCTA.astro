---
import PageTitle from './PageTitle.astro';
import { site } from '../data/site.js';

export interface Props {
  subtitle?: string;
  variant?: 'default' | 'compact';
}

const {
  subtitle = "New videos and articles, straight from Be Unconventional HQ.",
  variant = 'default',
} = Astro.props;
---

{variant === 'compact' ? (
  <section class="reveal" data-delay="400" style="margin-top: 1rem;">
    <div
      class="cta-band"
      style="flex-direction: column; justify-content: center; align-items: center; text-align: center;"
    >
      <div style="text-align: center; width: 100%;">
        <div class="section-header" style="margin-bottom: 1rem;">
          <PageTitle kicker="Don't miss a drop" primary="Subscribe" secondary="For Updates" scale="secondary" />
        </div>
        <p style="color: var(--color-white-muted); font-size: 0.9rem;">
          {subtitle}
        </p>
      </div>
      <div class="cta-buttons-wrapper" style="flex-wrap: wrap;">
        <a
          class="cta-button-primary"
          style="white-space: nowrap;"
          href={site.socials.substack}
          target="_blank"
          rel="noopener">Subscribe on Substack</a
        >
        <a
          class="cta-button-primary"
          style="white-space: nowrap;"
          href={site.socials.youtube}
          target="_blank"
          rel="noopener">Subscribe on YouTube</a
        >
      </div>
    </div>
  </section>
) : (
  <section
    class="container"
    style="margin-bottom: 2rem; position: relative; z-index: 10;"
  >
    <div
      class="cta-band reveal"
      style="flex-direction: column; justify-content: center; align-items: center; text-align: center;"
    >
      <div style="width: 100%;">
        <div class="section-header" style="margin-bottom: 1rem;">
          <PageTitle kicker="Don't miss a drop" primary="Subscribe" secondary="For Updates" scale="secondary" />
        </div>
        <p style="color: var(--color-white-muted);">
          {subtitle}
        </p>
      </div>
      <div class="cta-buttons-wrapper">
        <a
          class="cta-button-primary"
          href={site.socials.substack}
          target="_blank"
          rel="noopener">Subscribe on Substack</a
        >
        <a
          class="cta-button-primary"
          href={site.socials.youtube}
          target="_blank"
          rel="noopener">Subscribe on YouTube</a
        >
      </div>
    </div>
  </section>
)}

<style>
  .cta-buttons-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2rem;
    width: 100%;
  }

  .cta-buttons-wrapper .cta-button-primary {
    width: 100%;
    text-align: center;
  }

  @media (min-width: 768px) {
    .cta-buttons-wrapper {
      flex-direction: row;
    }

    .cta-buttons-wrapper .cta-button-primary {
      flex: 1;
    }
  }
</style>
