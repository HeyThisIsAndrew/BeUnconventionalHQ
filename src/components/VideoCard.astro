---
const { video } = Astro.props;
const { title, link, thumbnail, category, date } = video;
---

<a
  class="vcard reveal"
  href={link}
  target="_blank"
  rel="noopener noreferrer"
  data-category={(category || 'General').toLowerCase()}
>
  <div class="vcard-media">
    <img
      src={thumbnail}
      alt={title}
      loading="lazy"
      onerror="this.onerror=null;this.src=this.src.replace('maxresdefault','hqdefault')"
    />
    {category && <span class="badge">{category}</span>}
    <span class="play" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="currentColor"
        ><path d="M8 5v14l11-7z"></path></svg
      >
    </span>
  </div>
  <div class="vcard-body">
    {date && <span class="meta">{date}</span>}
    <h3 class="vcard-title">{title}</h3>
    <span class="vcard-cta">Watch on YouTube →</span>
  </div>
</a>

<style>
  .vcard {
    display: flex;
    flex-direction: column;
    background: var(--bg-1);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }
  .vcard:hover {
    transform: translateY(-6px);
    border-color: var(--line-strong);
    box-shadow: var(--shadow);
  }
  .vcard-media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg-2);
  }
  .vcard-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .vcard:hover .vcard-media img {
    transform: scale(1.06);
  }
  .badge {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    background: rgba(9, 9, 11, 0.72);
    backdrop-filter: blur(6px);
    color: #fff;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.35rem 0.65rem;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
  }
  .play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .play svg {
    width: 30px;
    height: 30px;
    color: #fff;
    background: var(--accent);
    border-radius: 50%;
    padding: 14px;
    box-shadow: var(--shadow-accent);
  }
  .vcard:hover .play {
    opacity: 1;
  }
  .vcard-body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.25rem 1.35rem 1.5rem;
  }
  .meta {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
  }
  .vcard-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    line-height: 1.25;
    color: var(--text);
  }
  .vcard-cta {
    margin-top: auto;
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--accent-ink);
  }
</style>
