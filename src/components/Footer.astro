const socialLinks = [
  { label: 'YouTube', href: site.socials.youtube },
  { label: 'Instagram', href: site.socials.instagram },
  { label: 'TikTok', href: site.socials.tiktok },
  { label: 'Threads', href: site.socials.threads },
  { label: 'Letterboxd', href: site.socials.letterboxd },
  { label: 'Substack', href: site.socials.substack },
  { label: 'Amazon', href: site.socials.amazon },
  { label: 'Facebook', href: site.socials.facebook },
  { label: 'Twitter', href: site.socials.twitter },
];
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <div class="mobile-footer-brand-wrapper">
        <a href="/" class="footer-logo footer-logo-wrapper">
          <img src="/logo.png" alt="HQ" />
        </a>

        <div class="footer-tagline-group">
          <span class="footer-brand-line1"
            >BE UNCONVENTIONAL <span style="color: var(--color-accent)">HQ</span
            ></span
          >
          <span class="footer-brand-line2"
            >WHERE NERD CULTURE GETS CINEMATIC</span
          >
          <span class="footer-brand-line3"
            >SOMETIMES UNCONVENTIONAL IS THE ONLY WAY FORWARD</span
          >
        </div>
      </div>
    </div>

    <nav class="footer-nav" aria-label="Footer Navigation">
      <p class="footer-nav-label">Explore</p>
      <ul>
        <li><a href={`/feed`}>Feed</a></li>
        <li><a href={`/events`}>Events</a></li>
        <li><a href={`/featured`}>Featured</a></li>
        <li class="break"></li>
        <li><a href={`/about`}>About</a></li>
        <li><a href={`/contact`} data-modal-trigger="contact">Contact</a></li>
        {import.meta.env.DEV && (
          <li class="break"></li>
        )}
        {import.meta.env.DEV && (
          <li><a href={`/links`} style="color: var(--color-accent); font-weight: 600;">Links (Dev)</a></li>
        )}
      </ul>
    </nav>

    <div class="footer-socials-col">
      <p class="footer-nav-label">Follow</p>
      <ul class="footer-socials">
        {
          socialLinks.map((social) => (
            <li>
              <a
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                class="footer-social-link"
                aria-label={social.label}
                set:html={socialIcons[social.label]}
              />
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <p class="footer-copy">
      &copy; {new Date().getFullYear()} Be Unconventional HQ. All rights reserved.
    </p>
    <p class="footer-credit">Where Nerd Culture Gets Cinematic</p>
  </div>
</footer>

<style>
  .footer-nav ul .break {
    flex-basis: 100%;
    height: 0;
    margin: 0;
    padding: 0;
  }
</style>
