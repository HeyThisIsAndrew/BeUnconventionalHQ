---
import { site } from '../data/site.js';
import Socials from './Socials.astro';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a class="footer-wordmark" href="/">
        Be Unconventional <span>HQ</span>
      </a>
      <p class="footer-tagline">{site.tagline}.</p>
      <Socials />
    </div>

    <nav class="footer-nav" aria-label="Footer">
      <span class="footer-nav-title">Explore</span>
      {site.nav.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href="/links">Links</a>
    </nav>
  </div>

  <div class="container footer-base">
    <span>© {year} {site.name}</span>
    <span class="footer-credit">Where nerd culture gets cinematic.</span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line);
    background: linear-gradient(to bottom, var(--bg), #060607);
    padding-top: clamp(3rem, 7vw, 5rem);
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 2.5rem;
    padding-bottom: 3rem;
  }
  .footer-brand {
    max-width: 38ch;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .footer-wordmark {
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: clamp(1.05rem, 4vw, 1.25rem);
  }
  .footer-wordmark span {
    color: var(--accent);
    margin-left: 0.3em;
  }
  .footer-tagline {
    color: var(--text-2);
    font-size: 0.95rem;
  }
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .footer-nav-title {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 0.2rem;
  }
  .footer-nav a {
    color: var(--text-2);
    font-size: 0.92rem;
    width: fit-content;
    transition: color 0.2s ease;
  }
  .footer-nav a:hover {
    color: var(--accent-ink);
  }
  .footer-base {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem;
    padding-block: 1.5rem;
    border-top: 1px solid var(--line);
    color: var(--text-3);
    font-size: 0.8rem;
  }
</style>
