---
interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  [x: string]: any;
}

const { href, type = 'button', class: className = '', ...rest } = Astro.props;
const Tag = href ? 'a' : 'button';
---

<Tag href={href} type={href ? undefined : type} class={`cta-button-primary ${className}`} {...rest}>
  <slot />
</Tag>

<style>
  .cta-button-primary {
    display: inline-block;
    background: transparent;
    border: 1px solid var(--color-accent);
    color: var(--color-white);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 1rem 3rem;
    cursor: pointer;
    text-align: center;
    transition:
      background-color 0.3s cubic-bezier(0.25, 0.8, 0.2, 1),
      box-shadow 0.3s cubic-bezier(0.25, 0.8, 0.2, 1),
      transform 0.3s cubic-bezier(0.25, 0.8, 0.2, 1),
      opacity 0.3s cubic-bezier(0.25, 0.8, 0.2, 1);
  }

  .cta-button-primary:hover {
    background-color: var(--color-accent);
    box-shadow: 0 0 30px rgba(204, 0, 0, 0.4);
  }
</style>
