---
const { article } = Astro.props;
const { title, link, image, category, date, excerpt } = article;
---

<a
  class="acard reveal"
  href={link}
  target="_blank"
  rel="noopener noreferrer"
  data-category={(category || 'General').toLowerCase()}
>
  <div class="acard-media">
    <img src={image} alt={title} loading="lazy" />
    {category && <span class="badge">{category}</span>}
  </div>
  <div class="acard-body">
    {date && <span class="meta">{date}</span>}
    <h3 class="acard-title">{title}</h3>
    {excerpt && <p class="acard-excerpt">{excerpt}</p>}
    <span class="acard-cta">Read article →</span>
  </div>
</a>

<style>
  .acard {
    display: flex;
    flex-direction: column;
    background: var(--bg-1);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }
  .acard:hover {
    transform: translateY(-6px);
    border-color: var(--line-strong);
    box-shadow: var(--shadow);
  }
  .acard-media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg-2);
  }
  .acard-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .acard:hover .acard-media img {
    transform: scale(1.06);
  }
  .badge {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    background: rgba(9, 9, 11, 0.72);
    backdrop-filter: blur(6px);
    color: #fff;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.35rem 0.65rem;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
  }
  .acard-body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.35rem 1.4rem 1.6rem;
  }
  .meta {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
  }
  .acard-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    line-height: 1.25;
    color: var(--text);
  }
  .acard-excerpt {
    color: var(--text-2);
    font-size: 0.92rem;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .acard-cta {
    margin-top: auto;
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--accent-ink);
  }
</style>
