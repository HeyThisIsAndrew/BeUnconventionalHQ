---
/**
 * One Discovery Row card: a pure cinematic 9:16 thumbnail linking out to the
 * Short. No text below the image by design — the thumbnail is the content.
 *
 * Zero-CLS: aspect-[9/16] reserves the card's box before the image loads; the
 * <img> is absolutely positioned inside it, so a slow (or failed) thumbnail
 * never moves layout.
 *
 * `group` lives HERE on the anchor: group-hover:* utilities only respond to
 * an ANCESTOR .group being hovered, so the hover root must wrap the pieces
 * that react (scale, glow, zoom, overlay).
 */
export interface Props {
  id: string;
  title: string;
  thumbnailUrl: string;
}
const { id, title, thumbnailUrl } = Astro.props;
---

<a
  href={`https://youtube.com/shorts/${id}`}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`Watch short: ${title}`}
  class="group block rounded-xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-red-500"
>
  <article
    class="relative block w-full aspect-[9/16] rounded-xl overflow-hidden bg-neutral-900 cursor-pointer transition-transform duration-300 ease-out group-hover:scale-[1.03] group-hover:shadow-[0_0_20px_rgba(239,68,68,0.6)]"
  >
    <img
      src={thumbnailUrl}
      alt=""
      loading="lazy"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
    />

    {/* Gradient so the badge pops against any thumbnail art. */}
    <div
      class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-300"
      aria-hidden="true"
    >
    </div>

    {/* Glassmorphism "SHORT" badge. */}
    <span
      class="absolute bottom-3 right-3 flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-black/40 backdrop-blur-md border border-white/10"
    >
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="white" aria-hidden="true" focusable="false">
        <path
          d="M11 21h-1l1-7H7.5c-.58 0-.57-.32-.38-.66.19-.34.05-.08.07-.12C8.48 10.94 10.42 7.54 13 3h1l-1 7h3.5c.49 0 .56.33.47.51l-.07.15C12.96 17.55 11 21 11 21z"
        ></path>
      </svg>
      <span class="text-[10px] font-bold text-white uppercase tracking-wider">Short</span>
    </span>
  </article>
</a>
