---
// @ts-ignore - sanity:client is a virtual module resolved by @sanity/astro
import { sanityClient } from "sanity:client";
import { createImageUrlBuilder } from "@sanity/image-url";
import { parseEventDate } from '../lib/events';
import { parseVideoId } from '../lib/platforms/youtube';
import EventStatusIndicator from './EventStatusIndicator.astro';

const builder = createImageUrlBuilder(sanityClient);
const urlFor = (source: any) => {
  return builder.image(source);
};

const { event, index = 0 } = Astro.props;
const trailerId = parseVideoId(event.trailerUrl);

const heroUrl = event.heroImage 
  ? urlFor(event.heroImage).width(800).height(450).url() 
  : trailerId 
    ? `https://img.youtube.com/vi/${trailerId}/hqdefault.jpg`
    : '/placeholder-event.jpg';
---

<a href={`/events/${event.slug.current}`} class="content-card group flex flex-col h-full w-full bg-[var(--color-surface)] border border-white/5 overflow-hidden no-underline transition-all duration-300 ease-out hover:-translate-y-1 hover:border-[var(--color-accent)] hover:shadow-[0_8px_40px_rgba(204,0,0,0.15)] animate-on-scroll" style={`--index: ${index};`}>
  {/* Cinematic 16:9 Image Wrapper */}
  <div class="relative w-full aspect-video overflow-hidden bg-[#121212]">
    <img
      src={heroUrl}
      alt={event.title}
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      onerror="this.onerror=null;this.src=this.src.replace('maxresdefault','hqdefault')"
    />
  </div>

  {/* Content Wrapper */}
  <div class="flex flex-col flex-grow p-6">
    {/* Meta Row */}
    <div class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-2 flex items-center gap-1.5">
      <span>Event</span>
      <span>&bull;</span>
      <span>{parseEventDate(event.startDate)?.year ?? 'Recent'}</span>
    </div>

    {/* Title Row */}
    <h3 class="text-white font-display text-[1.1rem] font-bold leading-[1.4] mb-4 line-clamp-3">
      {event.title}
    </h3>
    
    {/* CTA Row - Pushed to bottom via mt-auto */}
    <span class="mt-auto inline-flex items-center text-[0.75rem] font-semibold text-white uppercase tracking-[0.15em] relative w-fit transition-colors duration-300 group-hover:text-[var(--color-accent)]">
      View Coverage &nbsp;<span class="text-[var(--color-accent)]">&rarr;</span>
      <span class="absolute -bottom-1 left-0 w-0 h-px bg-[var(--color-accent)] transition-all duration-300 ease-out group-hover:w-full"></span>
    </span>
  </div>
</a>
