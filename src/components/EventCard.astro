---
// @ts-ignore - sanity:client is a virtual module resolved by @sanity/astro
import { sanityClient } from "sanity:client";
import { createImageUrlBuilder } from "@sanity/image-url";
import { parseEventDate } from '../lib/events';
import { parseVideoId } from '../lib/platforms/youtube';
import EventStatusIndicator from './EventStatusIndicator.astro';

const builder = createImageUrlBuilder(sanityClient);
const urlFor = (source: any) => {
  return builder.image(source);
};

const { event, index = 0 } = Astro.props;
const trailerId = parseVideoId(event.trailerUrl);

const heroUrl = event.heroImage 
  ? urlFor(event.heroImage).width(800).height(450).url() 
  : trailerId 
    ? `https://img.youtube.com/vi/${trailerId}/hqdefault.jpg`
    : '/placeholder-event.jpg';
---

<a href={`/events/${event.slug.current}`} class="event-card animate-on-scroll" style={`--index: ${index};`}>
  <div class="event-image-wrapper">
    <img
      src={heroUrl}
      alt={event.title}
      loading="lazy"
      decoding="async"
      class="event-image"
    />
    <div class="event-overlay" style={event.brandColor ? `--hover-color: ${event.brandColor};` : ''}>
      <div class="event-header">
        {event.logo && (
          <img src={urlFor(event.logo).height(50).url()} alt={`${event.title} logo`} class="event-card-logo" loading="lazy" />
        )}
      </div>
      <div class="event-footer">
        <h3 class="event-title line-clamp-2">{event.title}</h3>
        <span class="event-date">
          <EventStatusIndicator event={event} size="sm" />
          <span>{parseEventDate(event.startDate)?.year ?? 'Recent'} Coverage</span>
        </span>
      </div>
    </div>
  </div>
</a>

<style>
  .event-card {
    display: block;
    position: relative;
    /* overflow: hidden; is removed from the card itself to prevent it from
       clipping the box-shadow glow effect on hover. */
    text-decoration: none;
    color: white;
    background: #111;
    aspect-ratio: 16/9;
    /* Add box-shadow to the transition for a smooth glow effect. */
    transition: box-shadow 0.3s ease;
  }
  .event-image-wrapper {
    width: 100%;
    height: 100%;
    position: relative;
    /* The border-radius and overflow are moved here, to the inner wrapper,
       to contain the scaling image while allowing the parent to have a glow. */
    overflow: hidden;
  }
  .event-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .event-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0.1) 100%);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: background 0.3s ease;
  }
  /* On hover/focus, apply the cinematic glow for brand consistency. */
  .event-card:hover,
  .event-card:focus-visible {
    box-shadow: 0 0 25px var(--hover-color, rgba(204, 0, 0, 0.5));
    outline: none;
  }
  .event-card:hover .event-image {
    transform: scale(1.05);
  }
  .event-card:hover .event-overlay {
    background: linear-gradient(to top, var(--hover-color, rgba(0,0,0,0.9)) 0%, rgba(0,0,0,0.5) 50%, rgba(0,0,0,0.2) 100%);
  }
  .event-card-logo {
    max-height: 40px;
    object-fit: contain;
    /* Removed filter: drop-shadow due to known iOS Safari rendering bugs */
  }
  .event-title {
    font-size: 1.5rem;
    margin: 0 0 0.25rem 0;
    font-family: 'Syne Variable', sans-serif;
    text-shadow: 0 2px 4px rgba(0,0,0,0.8);
  }
  .event-date {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    opacity: 0.8;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
</style>
