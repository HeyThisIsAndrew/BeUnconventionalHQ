---
import PageTitle from './PageTitle.astro';

export interface Props {
  events: any[];
}
const { events } = Astro.props;

// Basic logic to generate calendar grid for the current month.
const today = new Date();
const year = today.getFullYear();
const month = today.getMonth();

const firstDay = new Date(year, month, 1);
const lastDay = new Date(year, month + 1, 0);
const monthStart = new Date(year, month, 1);
const monthEnd = new Date(year, month + 1, 0, 23, 59, 59, 999);
const startingDayOfWeek = firstDay.getDay(); // 0 (Sun) to 6 (Sat)
const totalDays = lastDay.getDate();

const days = [];
for (let i = 0; i < startingDayOfWeek; i++) {
  days.push({ empty: true });
}
for (let i = 1; i <= totalDays; i++) {
  days.push({ day: i, empty: false });
}

const currentMonthEvents = events.filter((event) => {
  const start = new Date(event.startDate);
  const end = new Date(event.endDate || event.startDate);

  if (Number.isNaN(start.getTime()) || Number.isNaN(end.getTime())) {
    return false;
  }

  return start <= monthEnd && end >= monthStart;
});

const calendarSegments = currentMonthEvents.flatMap((event) => {
  const start = new Date(event.startDate);
  const end = event.endDate ? new Date(event.endDate) : start;

  if (Number.isNaN(start.getTime()) || Number.isNaN(end.getTime())) {
    return [];
  }

  const startDay = start < monthStart ? 1 : start.getDate();
  const endDay = end > monthEnd ? totalDays : end.getDate();

  const startIndex = startingDayOfWeek + startDay - 1;
  const endIndex = startingDayOfWeek + endDay - 1;

  const startRow = Math.floor(startIndex / 7) + 1;
  const startCol = (startIndex % 7) + 1;
  const endRow = Math.floor(endIndex / 7) + 1;
  const endCol = (endIndex % 7) + 1;

  const color = event.brandColor || 'var(--color-accent, #cc0000)';
  const segments = [];

  const slug = event.slug?.current ?? event.slug ?? '';

  for (let row = startRow; row <= endRow; row++) {
    const colStart = row === startRow ? startCol : 1;
    const colEnd = row === endRow ? endCol : 7;
    const span = colEnd - colStart + 1;
    const isStart = row === startRow;
    const isEnd = row === endRow;

    segments.push({
      row,
      colStart,
      span,
      color,
      slug,
      title: event.title,
      // Continuation rows repeat the title so no bar is ever blank; a leading
      // arrow marks the rows that flow on from the line above.
      isStart,
      isEnd,
      isContinuation: !isStart,
    });
  }

  return segments;
});

---

<dialog id="spanning-calendar-modal" class="fade-in-overlay">
  <div class="modal-inner">
    <div class="modal-header">
      <PageTitle 
        as="h2" 
        kicker="Calendar" 
        primary={today.toLocaleString('en-US', { month: 'long' })} 
        secondary={today.getFullYear().toString()} 
      />
      <button id="close-calendar-btn" class="close-btn">&times;</button>
    </div>
    
    <div class="calendar-grid-wrapper">
      <div class="calendar-header-row">
        <span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span>
      </div>
      
      <div class="calendar-grid">
        {days.map((d, i) => (
          <div class={`calendar-cell ${d.empty ? 'empty' : ''}`} style={`grid-column: ${(i % 7) + 1}; grid-row: ${Math.floor(i / 7) + 1};`}>
            {!d.empty && <span class="day-number">{d.day}</span>}
          </div>
        ))}
        
        <!-- Draw Highlighter Bars. Multi-week events emit one <a> per row, but
             they share a data-event-id so JS can sync hover across all pieces,
             and border-radius is only applied on the true start/end so the rows
             read as one continuous block. -->
        {calendarSegments.map((segment) => (
          <a
            href={`/events/${segment.slug}`}
            data-event-id={segment.slug}
            class:list={[
              'highlighter-bar',
              { 'is-start': segment.isStart, 'is-end': segment.isEnd, 'is-continuation': segment.isContinuation },
            ]}
            style={`grid-row: ${segment.row}; grid-column: ${segment.colStart} / span ${segment.span}; --bar-color: ${segment.color};`}
          >
            {segment.isContinuation && <span class="bar-cont" aria-hidden="true">↳ </span>}
            <span class="bar-label">{segment.title}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</dialog>

<style>
  #spanning-calendar-modal {
    background: transparent;
    border: none;
    margin: auto;
    padding: 0;
    max-width: 95vw;
    width: 1000px;
  }
  
  #spanning-calendar-modal::backdrop {
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(10px);
  }
  
  .modal-inner {
    background: #111;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 2rem;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
  }
  
  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 3rem;
  }
  
  .close-btn {
    background: transparent;
    border: none;
    color: white;
    font-size: 2.5rem;
    line-height: 1;
    cursor: pointer;
    transition: color 0.2s ease;
  }
  .close-btn:hover {
    color: var(--color-accent, #cc0000);
  }
  
  .calendar-grid-wrapper {
    width: 100%;
  }
  
  .calendar-header-row {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    text-align: right;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    color: #888;
    text-transform: uppercase;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 1px;
  }
  .calendar-header-row span {
    padding: 0 0.5rem;
  }
  
  .calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    grid-auto-rows: minmax(120px, auto);
    gap: 1px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.1);
    position: relative;
    /* this allows child elements (the highlighter bars) to live in the same grid cells as the background cells */
  }
  
  .calendar-cell {
    background: #111;
    padding: 0.5rem;
    position: relative;
    z-index: 1;
  }
  
  .day-number {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    font-weight: 600;
    color: #aaa;
  }
  
  .highlighter-bar {
    display: flex;
    align-items: center;
    background: var(--bar-color);
    color: white;
    border-radius: 0; /* squared by default; start/end round their outer edge */
    padding: 0.25rem 0.5rem;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
    margin-top: 2.5rem; /* Push it down below the date number */
    box-shadow: 0 4px 10px rgba(0,0,0,0.3);
    z-index: 10;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    /* No positional movement on hover — the whole event brightens together via
       the .hover-active class so multi-row events feel like one block. */
    transition: filter 0.2s ease, box-shadow 0.2s ease;
    align-self: start;
  }

  /* Round only the outer corners of the whole event so intermediate rows butt
     up flush, like a text-selection highlight flowing across lines. */
  .highlighter-bar.is-start {
    border-top-left-radius: 4px;
    border-bottom-left-radius: 4px;
    margin-left: 0.25rem;
  }
  .highlighter-bar.is-end {
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
    margin-right: 0.25rem;
  }

  .bar-cont {
    opacity: 0.75;
    margin-right: 0.15rem;
    flex-shrink: 0;
  }
  /* Continuation rows dim their repeated label slightly so the eye reads the
     first row as the event's "start" while later rows stay clearly labelled. */
  .highlighter-bar.is-continuation .bar-label {
    opacity: 0.8;
  }
  .bar-label {
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Applied by JS to every segment sharing the hovered event's id. */
  .highlighter-bar:hover,
  .highlighter-bar.hover-active {
    filter: brightness(1.15);
    box-shadow: 0 6px 15px rgba(0,0,0,0.5);
  }
  .highlighter-bar.hover-active .bar-label,
  .highlighter-bar:hover .bar-label {
    opacity: 1;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('open-calendar-btn');
    const modalElement = document.getElementById('spanning-calendar-modal');
    const modal = modalElement instanceof HTMLDialogElement ? modalElement : null;
    const closeBtn = document.getElementById('close-calendar-btn');

    if (btn && modal) {
      btn.addEventListener('click', () => {
        modal.showModal();
      });
    }

    if (closeBtn && modal) {
      closeBtn.addEventListener('click', () => {
        modal.close();
      });
    }

    if (modal) {
      modal.addEventListener('click', (event) => {
        const rect = modal.getBoundingClientRect();
        if (
          event.clientY < rect.top ||
          event.clientY > rect.bottom ||
          event.clientX < rect.left ||
          event.clientX > rect.right
        ) {
          modal.close();
        }
      });

      // Sync hover across every segment of the same event. Multi-week events
      // are split into one <a> per row to satisfy the grid, so :hover alone
      // only lights the piece under the cursor — this bridges them by data id.
      const setHover = (id: string | null, on: boolean) => {
        if (!id) return;
        modal
          .querySelectorAll(`.highlighter-bar[data-event-id="${CSS.escape(id)}"]`)
          .forEach((el) => el.classList.toggle('hover-active', on));
      };

      modal.addEventListener('mouseover', (event) => {
        const bar = (event.target as HTMLElement)?.closest?.('.highlighter-bar');
        if (bar) setHover(bar.getAttribute('data-event-id'), true);
      });
      modal.addEventListener('mouseout', (event) => {
        const bar = (event.target as HTMLElement)?.closest?.('.highlighter-bar');
        if (bar) setHover(bar.getAttribute('data-event-id'), false);
      });
      modal.addEventListener('focusin', (event) => {
        const bar = (event.target as HTMLElement)?.closest?.('.highlighter-bar');
        if (bar) setHover(bar.getAttribute('data-event-id'), true);
      });
      modal.addEventListener('focusout', (event) => {
        const bar = (event.target as HTMLElement)?.closest?.('.highlighter-bar');
        if (bar) setHover(bar.getAttribute('data-event-id'), false);
      });
    }
  });
</script>
