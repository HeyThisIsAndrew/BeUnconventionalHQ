---
import PageTitle from './PageTitle.astro';

export interface Props {
  events: any[];
}
const { events } = Astro.props;

// Basic logic to generate calendar grid for the current month.
const today = new Date();
const year = today.getFullYear();
const month = today.getMonth();

const firstDay = new Date(year, month, 1);
const lastDay = new Date(year, month + 1, 0);
const startingDayOfWeek = firstDay.getDay(); // 0 (Sun) to 6 (Sat)
const totalDays = lastDay.getDate();

const days = [];
for (let i = 0; i < startingDayOfWeek; i++) {
  days.push({ empty: true });
}
for (let i = 1; i <= totalDays; i++) {
  days.push({ day: i, empty: false });
}

// Find events spanning these days
const currentMonthEvents = events.filter(e => {
  const s = new Date(e.startDate);
  return s.getMonth() === month && s.getFullYear() === year;
});

---

<dialog id="spanning-calendar-modal" class="fade-in-overlay">
  <div class="modal-inner">
    <div class="modal-header">
      <PageTitle 
        as="h2" 
        kicker="Calendar" 
        primary={today.toLocaleString('en-US', { month: 'long' })} 
        secondary={today.getFullYear().toString()} 
      />
      <button id="close-calendar-btn" class="close-btn">&times;</button>
    </div>
    
    <div class="calendar-grid-wrapper">
      <div class="calendar-header-row">
        <span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span>
      </div>
      
      <div class="calendar-grid">
        {days.map((d, i) => (
          <div class={`calendar-cell ${d.empty ? 'empty' : ''}`} style={`grid-column: ${(i % 7) + 1}; grid-row: ${Math.floor(i / 7) + 1};`}>
            {!d.empty && <span class="day-number">{d.day}</span>}
          </div>
        ))}
        
        {/* Draw Highlighter Bars */}
        {currentMonthEvents.map((event, index) => {
          const s = new Date(event.startDate);
          const e = event.endDate ? new Date(event.endDate) : s;
          
          const startDay = s.getDate();
          const endDay = e.getDate();
          
          // Calculate grid positions
          const startIndex = startingDayOfWeek + startDay - 1;
          const endIndex = startingDayOfWeek + endDay - 1;
          
          const startRow = Math.floor(startIndex / 7) + 1;
          const startCol = (startIndex % 7) + 1;
          
          const endRow = Math.floor(endIndex / 7) + 1;
          const endCol = (endIndex % 7) + 1;
          
          const color = event.brandColor || 'var(--color-accent, #cc0000)';
          
          const bars = [];
          for (let row = startRow; row <= endRow; row++) {
            let colStart = row === startRow ? startCol : 1;
            let colEnd = row === endRow ? endCol : 7;
            let span = colEnd - colStart + 1;
            bars.push(
              <a href={`/events/${event.slug.current}`} class="highlighter-bar" style={"grid-row: " + row + "; grid-column: " + colStart + " / span " + span + "; --bar-color: " + color + ";"}>
                {row === startRow ? event.title : '\u00A0'}
              </a>
            );
          }
          return bars;
        })}
      </div>
    </div>
  </div>
</dialog>

<style>
  #spanning-calendar-modal {
    background: transparent;
    border: none;
    margin: auto;
    padding: 0;
    max-width: 95vw;
    width: 1000px;
  }
  
  #spanning-calendar-modal::backdrop {
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(10px);
  }
  
  .modal-inner {
    background: #111;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 2rem;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
  }
  
  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 3rem;
  }
  
  .close-btn {
    background: transparent;
    border: none;
    color: white;
    font-size: 2.5rem;
    line-height: 1;
    cursor: pointer;
    transition: color 0.2s ease;
  }
  .close-btn:hover {
    color: var(--color-accent, #cc0000);
  }
  
  .calendar-grid-wrapper {
    width: 100%;
  }
  
  .calendar-header-row {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    text-align: right;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    color: #888;
    text-transform: uppercase;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 1px;
  }
  .calendar-header-row span {
    padding: 0 0.5rem;
  }
  
  .calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    grid-auto-rows: minmax(120px, auto);
    gap: 1px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.1);
    position: relative;
    /* this allows child elements (the highlighter bars) to live in the same grid cells as the background cells */
  }
  
  .calendar-cell {
    background: #111;
    padding: 0.5rem;
    position: relative;
    z-index: 1;
  }
  
  .day-number {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    font-weight: 600;
    color: #aaa;
  }
  
  .highlighter-bar {
    background: var(--bar-color);
    color: white;
    border-radius: 4px;
    padding: 0.25rem 0.5rem;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
    margin-top: 2.5rem; /* Push it down below the date number */
    margin-left: 0.25rem;
    margin-right: 0.25rem;
    box-shadow: 0 4px 10px rgba(0,0,0,0.3);
    z-index: 10;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: transform 0.2s ease;
    align-self: start;
  }
  .highlighter-bar:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 15px rgba(0,0,0,0.5);
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('open-calendar-btn');
    const modal = document.getElementById('spanning-calendar-modal') as HTMLDialogElement;
    const closeBtn = document.getElementById('close-calendar-btn');
    
    if (btn && modal) {
      btn.addEventListener('click', () => {
        modal.showModal();
      });
    }
    
    if (closeBtn && modal) {
      closeBtn.addEventListener('click', () => {
        modal.close();
      });
    }
    
    // Close on backdrop click
    if (modal) {
      modal.addEventListener('click', (e) => {
        const rect = modal.getBoundingClientRect();
        if (e.clientY < rect.top || e.clientY > rect.bottom || e.clientX < rect.left || e.clientX > rect.right) {
          modal.close();
        }
      });
    }
  });
</script>
