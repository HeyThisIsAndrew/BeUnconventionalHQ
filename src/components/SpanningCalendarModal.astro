---
// Thin wrapper: renders the full interactive calendar (DesktopCalendar) inside a
// <dialog>. All month-grid math lives in DesktopCalendar itself — this component
// only owns the modal shell, open/close wiring, and scroll-lock behavior.
import DesktopCalendar from './DesktopCalendar.astro';

export interface Props {
  events: any[];
}
const { events } = Astro.props;
---

<dialog id="spanning-calendar-modal" class="fade-in-overlay">
  <!-- Unified Responsive Calendar View -->
  <div class="modal-inner">
    <div class="modal-close-bar">
      <button class="close-btn" aria-label="Close Calendar">&times;</button>
    </div>
    <DesktopCalendar events={events} />
  </div>
</dialog>

<style>
  #spanning-calendar-modal {
    background: transparent;
    border: none;
    margin: auto;
    padding: 0;
    max-width: 95vw;
    width: 800px;
  }

  #spanning-calendar-modal::backdrop {
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(10px);
  }

  .modal-inner {
    background: #111;
    border: 1px solid rgba(255,255,255,0.1);
    padding: 0;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    max-height: 95vh;
  }
  .modal-close-bar {
    display: flex;
    justify-content: flex-end;
    padding: 1rem 1rem 0 0;
  }

  /* Breakpoint Toggle */
  @media (min-width: 900px) {
    #spanning-calendar-modal {
      width: 1200px; /* Wider for desktop */
      max-width: 95vw;
    }
  }

.close-btn {
  -webkit-appearance: none;
  -moz-appearance: none;
  appearance: none;
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
  color: white;
  font-size: 2.5rem;
  line-height: 1;
  cursor: pointer;
  padding: 0;
  width: 2rem;
  height: 2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  transition:
    color 0.2s ease,
    transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  -webkit-tap-highlight-color: rgba(0,0,0,0);
  -webkit-user-select: none;
  user-select: none;
  outline: none !important;
}

.close-btn:hover {
  color: var(--color-accent, #cc0000);
  transform: rotate(90deg);
}

.close-btn:focus-visible,
.close-btn:focus,
.close-btn:active {
  background: transparent !important;
  outline: none !important;
  box-shadow: none !important;
}

.close-btn::-webkit-focus-inner {
  border: 0;
}
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const btns = document.querySelectorAll('.open-full-calendar-btn');
    const modalElement = document.getElementById('spanning-calendar-modal');
    const modal = modalElement instanceof HTMLDialogElement ? modalElement : null;
    const closeBtns = document.querySelectorAll('#spanning-calendar-modal .close-btn');

    const closeModal = () => {
      if (!modal) return;

      const scrollY = Math.abs(parseInt(document.body.style.top || '0'));
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.width = '';
      document.body.style.overflowY = '';

      const originalBehavior = document.documentElement.style.scrollBehavior;
      document.documentElement.style.scrollBehavior = 'auto'; // Force instant snap
      window.scrollTo(0, scrollY);

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          document.documentElement.style.scrollBehavior = originalBehavior;
        });
      });

      modal.close();
    };

    if (modal) {
      btns.forEach(btn => {
        btn.addEventListener('click', () => {
          if (document.body.style.position !== 'fixed') {
            const scrollY = window.scrollY;
            document.body.style.top = `-${scrollY}px`;
            document.body.style.position = 'fixed';
            document.body.style.width = '100%';
            document.body.style.overflowY = 'scroll';
          }
          modal.showModal();
        });
      });

      /*
        ARCHITECTURAL NOTE: The auto-close behavior on mobile landscape has been
        removed. Previously, this script would close the modal on short viewports
        to prevent a broken, scrolling UI. It has been replaced with a CSS-only
        solution within DesktopCalendar.astro that responsively scales the
        calendar down to fit the viewport, providing a much better user experience.
      */
      // const handleOrientationChange = () => {
      //   if (window.matchMedia('(max-height: 600px) and (orientation: landscape)').matches) {
      //     closeModal();
      //   }
      // };
      // window.addEventListener('orientationchange', () => { setTimeout(handleOrientationChange, 100); });
    }

    if (closeBtns.length > 0 && modal) {
      closeBtns.forEach(btn => btn.addEventListener('click', closeModal));
    }

    if (modal) {
      document.addEventListener('astro:before-preparation', closeModal, { once: true });

      modal.addEventListener('click', (event) => {
        const rect = modal.getBoundingClientRect();
        if (
          event.clientY < rect.top ||
          event.clientY > rect.bottom ||
          event.clientX < rect.left ||
          event.clientX > rect.right
        ) {
          closeModal();
        }
      });

      // Sync hover across every segment of the same event. Multi-week events
      // are split into one <a> per row to satisfy the grid, so :hover alone
      // only lights the piece under the cursor — this bridges them by data id.
      const setHover = (id: string | null, on: boolean) => {
        if (!id) return;
        modal
          .querySelectorAll(`.dc-highlighter-bar[data-event-id="${CSS.escape(id)}"]`)
          .forEach((el) => el.classList.toggle('hover-active', on));
      };

      modal.addEventListener('mouseover', (event) => {
        const bar = (event.target as HTMLElement)?.closest?.('.dc-highlighter-bar');
        if (bar) setHover(bar.getAttribute('data-event-id'), true);
      });
      modal.addEventListener('mouseout', (event) => {
        const bar = (event.target as HTMLElement)?.closest?.('.dc-highlighter-bar');
        if (bar) setHover(bar.getAttribute('data-event-id'), false);
      });
      modal.addEventListener('focusin', (event) => {
        const bar = (event.target as HTMLElement)?.closest?.('.dc-highlighter-bar');
        if (bar) setHover(bar.getAttribute('data-event-id'), true);
      });
      modal.addEventListener('focusout', (event) => {
        const bar = (event.target as HTMLElement)?.closest?.('.dc-highlighter-bar');
        if (bar) setHover(bar.getAttribute('data-event-id'), false);
      });
    }
  });
</script>
