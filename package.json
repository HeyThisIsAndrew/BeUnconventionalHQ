{
  "name": "beunconventionalhq",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.15.0"
  },
  "scripts": {
    "test": "node scripts/events.test.mjs && node scripts/live-status.test.mjs && node scripts/twitch.test.mjs && node scripts/videos.test.mjs && node scripts/shorts.test.mjs && node scripts/taxonomy.test.mjs && node scripts/dispatch.test.mjs && node scripts/metrics.test.mjs",
    "sync": "node scripts/sync-youtube.mjs",
    "metrics": "node scripts/update-metrics.mjs",
    "deploy": "npx wrangler deploy --config dist/server/wrangler.json",
    "refresh-content": "node scripts/fetch-feeds.mjs",
    "dev": "npm run refresh-content && node scripts/dev.mjs",
    "build:live": "npm run refresh-content && astro build",
    "build": "astro build",
    "preview": "astro preview",
    "devbuild": "npm run build && npm run dev",
    "start:full": "npm run refresh-content && npm run build && npm run dev",
    "start:clean": "rm -rf node_modules/.vite dist .astro && npm run refresh-content && npm run build && npm run dev"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/react": "^6.0.1",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/syne": "^5.2.7",
    "@sanity/astro": "^3.4.2",
    "@sanity/client": "^7.23.0",
    "@sanity/image-url": "^2.1.1",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.7",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^5.8.0",
    "qrcode-terminal": "^0.12.0",
    "sanity": "^6.4.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "puppeteer": "^25.3.0",
    "wrangler": "4.83.0"
  },
  "overrides": {
    "vite": "^7.0.0"
  }
}
